<style>
:root{--teal-night:#082A30;--teal-700:#14525B;--teal-300:#5E8C92;--mint:#5BE0A0;--mint-soft:#E6F7EE;--cream-card:#FFFDF8;--cream:#F6F0E6;--ink:#082A30;--ink-soft:#56655F;--ink-faint:#8A958F;--body:#3A4A42;--line:#E8E2D8;--serif:'Fraunces',Georgia,serif;--sans:'Inter Tight',system-ui,sans-serif}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--sans);background:var(--cream);color:var(--ink);font-size:16px;line-height:1.6}
a{color:var(--teal-700);text-decoration:none}
a:hover{text-decoration:underline;text-underline-offset:3px}
.wrap{max-width:960px;margin:0 auto;padding:0 24px}
.bc{padding:14px 0;font-size:12.5px;color:var(--ink-faint)}
.bc a{color:var(--ink-faint)}
.bc span{margin:0 6px}
.hero{padding:56px 0 48px;border-bottom:1px solid var(--line)}
.eyebrow{display:block;font-size:11.5px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--teal-300);margin-bottom:14px}
.hero h1{font-family:var(--serif);font-size:clamp(2rem,5vw,3rem);font-weight:500;color:var(--teal-night);line-height:1.15;margin-bottom:16px}
.hero h1 em{font-style:italic}
.hero p{font-size:17px;color:var(--ink-soft);max-width:600px;line-height:1.65;margin-bottom:28px}
.btn{display:inline-flex;align-items:center;gap:7px;font-family:var(--sans);font-size:14px;font-weight:600;padding:11px 22px;border-radius:5px;border:none;cursor:pointer;text-decoration:none;transition:opacity .18s}
.btn-primary{background:var(--teal-night);color:var(--mint)}
.btn-primary:hover{opacity:.88;text-decoration:none}
.btn-outline{background:transparent;color:var(--teal-700);border:1.5px solid var(--teal-700)}
.btn-outline:hover{background:var(--mint-soft);text-decoration:none}
.hero-ctas{display:flex;flex-wrap:wrap;gap:12px}
.spoke-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;padding:44px 0}
.spoke-card{background:var(--cream-card);border:1px solid var(--line);border-radius:6px;padding:26px 24px 22px;display:flex;flex-direction:column;gap:10px;transition:border-color .18s,box-shadow .18s}
.spoke-card:hover{border-color:var(--teal-700);box-shadow:0 4px 18px rgba(8,42,48,.07);text-decoration:none}
.spoke-tag{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--teal-300)}
.spoke-card h2{font-family:var(--serif);font-size:1.1rem;font-weight:500;color:var(--teal-night);line-height:1.25}
.spoke-card p{font-size:14px;color:var(--ink-soft);line-height:1.6;flex:1}
.spoke-link{font-size:13px;font-weight:600;color:var(--teal-700);margin-top:4px}
.spoke-primary{border-color:var(--teal-700);background:var(--mint-soft)}
.situations{padding:44px 0;border-top:1px solid var(--line)}
.situations h2{font-family:var(--serif);font-size:1.6rem;font-weight:500;color:var(--teal-night);margin-bottom:8px}
.lede{font-size:15.5px;color:var(--ink-soft);margin-bottom:28px;max-width:520px}
.sit-list{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.sit-item{background:var(--cream-card);border:1px solid var(--line);border-radius:5px;padding:16px 18px;display:flex;align-items:center;justify-content:space-between;gap:12px;color:var(--ink);font-size:14.5px;font-weight:500;text-decoration:none;transition:border-color .15s,background .15s}
.sit-item:hover{border-color:var(--teal-700);background:var(--mint-soft);text-decoration:none}
.sit-arrow{color:var(--teal-300);font-size:16px;flex-shrink:0}
.terms-section{padding:44px 0;border-top:1px solid var(--line)}
.terms-section h2{font-family:var(--serif);font-size:1.6rem;font-weight:500;color:var(--teal-night);margin-bottom:8px}
.term-pills{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px}
.term-pill{display:inline-block;background:var(--cream-card);border:1px solid var(--line);border-radius:999px;padding:6px 14px;font-size:13px;color:var(--teal-700);text-decoration:none;transition:background .15s,border-color .15s}
.term-pill:hover{background:var(--mint-soft);border-color:var(--teal-700);text-decoration:none}
.bottom-cta{background:var(--teal-night);padding:52px 0;margin-top:44px}
.bottom-cta h2{font-family:var(--serif);font-size:clamp(1.5rem,4vw,2.1rem);font-weight:500;color:#fff;margin-bottom:10px}
.bottom-cta h2 em{color:var(--mint);font-style:italic}
.bottom-cta p{font-size:15.5px;color:rgba(255,255,255,.68);margin-bottom:28px;max-width:480px}
.btn-mint{background:var(--mint);color:var(--teal-night);font-weight:700}
.btn-mint:hover{opacity:.9;text-decoration:none}
.btn-ghost{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.3)}
.btn-ghost:hover{background:rgba(255,255,255,.07);text-decoration:none}
.di-hub{padding:16px 0;background:var(--teal-night);border-bottom:1px solid rgba(255,255,255,.06)}
.di-hub-wrap{max-width:960px;margin:0 auto;padding:0 24px;display:flex;align-items:center;gap:18px;flex-wrap:wrap}
.di-hub-label{font-size:10.5px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--teal-300);flex-shrink:0}
.di-hub-links{list-style:none;margin:0;padding:0;display:flex;flex-wrap:wrap;gap:6px}
.di-hub-links li a{display:inline-block;font-size:12.5px;font-weight:500;color:rgba(255,255,255,.52);padding:5px 12px;border-radius:999px;border:1px solid rgba(255,255,255,.1);text-decoration:none;transition:background .15s,color .15s,border-color .15s;white-space:nowrap}
.di-hub-links li a:hover,.di-hub-links li a[aria-current="page"]{background:rgba(255,255,255,.07);color:#fff;border-color:rgba(255,255,255,.25)}
.di-hub-cta{background:var(--mint)!important;color:var(--teal-night)!important;border-color:var(--mint)!important;font-weight:700!important}
.site-footer{padding:28px 0;border-top:1px solid var(--line);text-align:center;font-size:12.5px;color:var(--ink-faint)}
.site-footer a{color:var(--ink-faint);text-decoration:underline;text-underline-offset:2px}
@media(max-width:720px){.spoke-grid{grid-template-columns:1fr 1fr}.sit-list{grid-template-columns:1fr}}
@media(max-width:520px){.spoke-grid{grid-template-columns:1fr}.hero-ctas,.hero-ctas .btn{flex-direction:column;width:100%}}

/* ===== SIDEBAR LAYOUT ===== */
.page-layout{display:grid;grid-template-columns:1fr 272px;gap:48px;max-width:1080px;margin:0 auto;padding:0 24px;align-items:start}
.main-col{max-width:720px;width:100%}
.sidebar-col{position:sticky;top:var(--cc-nav-h,68px);max-height:calc(100vh - 100px);overflow-y:auto;scrollbar-width:none}
.sidebar-col::-webkit-scrollbar{display:none}
.sb-cta-block{background:#082A30;border-radius:16px;padding:22px;margin-bottom:16px}
.sb-cta-eyebrow{font-family:'Inter Tight',system-ui;font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:rgba(91,224,160,.8);display:block;margin-bottom:8px}
.sb-cta-headline{font-family:'Fraunces',serif;font-size:16px;font-weight:500;color:#FFFDF8;line-height:1.3;margin:0 0 14px}
.sb-cta-headline em{color:#5BE0A0;font-style:italic}
.sb-cta-btn{display:block;width:100%;background:#5BE0A0;color:#082A30;font-family:'Inter Tight',system-ui;font-size:13px;font-weight:600;text-align:center;padding:11px 0;border-radius:999px;text-decoration:none;transition:opacity .15s}
.sb-cta-btn:hover{opacity:.88}
.sb-cta-sub{font-family:'Inter Tight',system-ui;font-size:11px;color:rgba(255,255,255,.4);margin-top:10px;display:block;text-align:center}
.sb-widget{background:#fff;border:1px solid #E8E2D8;border-radius:12px;padding:16px;margin-bottom:12px}
.sb-widget-title{font-family:'Inter Tight',system-ui;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#8A958F;margin:0 0 10px}
.sb-toc-list,.sb-related-list{list-style:none;margin:0;padding:0}
.sb-toc-list li a,.sb-related-list li a{font-family:'Inter Tight',system-ui;font-size:13px;color:#14525B;text-decoration:none;display:block;padding:5px 0;border-bottom:1px solid #F0EAE0;line-height:1.4}
.sb-toc-list li:last-child a,.sb-related-list li:last-child a{border-bottom:none}
.sb-toc-list li a:hover,.sb-related-list li a:hover{color:#082A30}
.sb-related-list li a{font-size:12.5px}
.sb-page-info{font-family:'Inter Tight',system-ui;font-size:11px;color:#8A958F;line-height:1.6;margin:0}
.sb-ghost-btn{display:block;width:100%;border:1px solid #14525B;color:#14525B;background:none;font-family:'Inter Tight',system-ui;font-size:13px;font-weight:500;text-align:center;padding:10px 0;border-radius:999px;text-decoration:none;margin-top:8px;transition:background .15s,color .15s}
.sb-ghost-btn:hover{background:#14525B;color:#fff}
@media(max-width:860px){
  .page-layout{grid-template-columns:1fr;gap:0}
  .sidebar-col{position:static;max-height:none;order:-1;margin-bottom:24px}
  .sb-widget,.sb-ghost-btn{display:none}
  .sb-cta-block{border-radius:10px;padding:16px}
}
</style>
<link rel="stylesheet" href="/assets/css/mega-nav.css">
<link rel="stylesheet" href="/assets/css/mega-nav-mobile.css">
<style>
/* ── Nav/footer mount placeholders ── */
#cc-nav-mount{min-height:72px}
#cc-footer-mount{min-height:420px}

/* ── Gold/Jade CSS vars ── */
:root{
  --teal-950:#0C3A42;--mint-500:#B8924F;
  --cream-50:#FAF8F5;--cream-100:#F4F0EA;
  --ink-950:#1E1714;--border:#E7E0D7;
}
[data-theme="jade"]{
  --teal-950:#12161B;--mint-500:#0FB5A6;
  --cream-50:#FFFFFF;--cream-100:#F5F7F8;
  --ink-950:#161A1F;--border:rgba(18,22,27,.12);
}

/* ── T5 Gold/Jade toggle pill ── */
.ts-wrap{display:flex;align-items:center;flex-shrink:0;margin-left:auto}
.theme-switch{
  position:relative;display:inline-flex;align-items:center;
  background:#1a1a1a;border:1.5px solid rgba(255,255,255,.08);border-radius:999px;
  padding:4px;cursor:pointer;user-select:none;flex-shrink:0;height:34px;
  box-shadow:0 2px 12px rgba(0,0,0,.32),inset 0 1px 0 rgba(255,255,255,.06);
  transition:border-color .35s,box-shadow .35s;
}
.theme-switch:hover{border-color:rgba(184,146,79,.5)}
.ts-thumb{
  position:absolute;top:4px;left:4px;
  width:calc(50% - 4px);height:calc(100% - 8px);border-radius:999px;
  background:#B8924F;
  box-shadow:0 3px 10px rgba(184,146,79,.55),0 1px 3px rgba(0,0,0,.3),inset 0 1px 0 rgba(255,255,255,.22);
  transition:transform 1.8s cubic-bezier(.34,1.18,.64,1),background .7s ease;will-change:transform;
}
[data-theme="jade"] .ts-thumb{background:#0FB5A6;box-shadow:0 3px 10px rgba(15,181,166,.5),0 1px 3px rgba(0,0,0,.3),inset 0 1px 0 rgba(255,255,255,.22)}
.theme-switch[data-active="jade"] .ts-thumb{transform:translateX(100%)}
.ts-opt{
  position:relative;z-index:1;display:flex;align-items:center;gap:5px;
  padding:0 14px;height:100%;
  font:700 11px/1 'Inter Tight',sans-serif;letter-spacing:.07em;text-transform:uppercase;
  color:rgba(255,255,255,.35);transition:color .35s;white-space:nowrap;
}
.ts-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;transition:opacity .35s;opacity:0}
.ts-opt.ts-gold .ts-dot{background:#B8924F}
.ts-opt.ts-jade .ts-dot{background:#0FB5A6}
.theme-switch[data-active="gold"] .ts-opt.ts-gold{color:#fff}
.theme-switch[data-active="gold"] .ts-opt.ts-gold .ts-dot{opacity:1}
.theme-switch[data-active="jade"] .ts-opt.ts-jade{color:#fff}
.theme-switch[data-active="jade"] .ts-opt.ts-jade .ts-dot{opacity:1}
@keyframes ts-pulse{
  0%,100%{box-shadow:0 2px 12px rgba(0,0,0,.32),0 0 0 0 rgba(184,146,79,0),inset 0 1px 0 rgba(255,255,255,.06)}
  50%{box-shadow:0 2px 12px rgba(0,0,0,.32),0 0 0 6px rgba(184,146,79,.18),inset 0 1px 0 rgba(255,255,255,.06)}
}
.theme-switch.flipping{animation:ts-pulse 1.8s ease-in-out}
html{transition:background .25s ease}

/* ── Footer CSS vars (matches universal footer component) ── */
:root{
  --paper:#F5F0E5;--paper-2:#EFE8D9;--card:#FCFAF4;
  --ink:#21302A;--ink-soft:#3A4A42;
  --green:#2E5E45;--green-d:#234A37;--green-l:#5C7A66;
  --sage:#E6EDE3;--sage-2:#DCE6D8;--muted:#6E7268;
  --line:#E3DAC8;--line-2:#D8CDB6;
  --gold:#C0902E;--rust:#B0542E;
  --panel:#21302A;--panel-ink:#F4EFE2;--panel-soft:#C7CEBE;--panel-eye:#A9C4AE;
  --shadow:0 1px 0 rgba(33,48,42,.03),0 4px 16px rgba(33,48,42,.08);
}
[data-theme="jade"]{
  --paper:#FFFFFF;--paper-2:#F5F7F8;--card:#FFFFFF;
  --ink:#161A1F;--ink-soft:#3A434D;
  --green:#0FB5A6;--green-d:#0C8C81;--green-l:#3FCFC0;
  --sage:rgba(15,181,166,.1);--sage-2:rgba(15,181,166,.18);
  --muted:#5A636E;--line:rgba(18,22,27,.12);--line-2:rgba(18,22,27,.2);
  --gold:#0C8C81;--rust:#D47452;
  --panel:#12161B;--panel-ink:#FFFFFF;--panel-soft:rgba(255,255,255,.7);--panel-eye:#0FB5A6;
  --shadow:0 1px 0 rgba(0,0,0,.04),0 12px 34px rgba(18,22,27,.1);
}
</style>
</head>
<body>
<!-- UNIVERSAL MEGA NAV -->
<div id="cc-nav-mount"></div>


<nav class="di-hub" aria-label="Dental insurance resource hub">
  <div class="wrap">
    <div class="di-hub-inner">
      <span class="di-hub-label"><span class="sp">&#10038;</span> Dental Insurance</span>
      <ul class="di-hub-links" role="list">
        <li><a href="/dental-insurance/" aria-current="page">Overview</a></li>
        <li><a href="/compare-ppo-dental-plans/">Compare plans</a></li>
        <li><a href="/guides/glossary/">Glossary</a></li>
        <li><a href="/guides/no-waiting-period/">No waiting period</a></li>
        <li><a href="/guides/between-jobs/">Between jobs</a></li>
        <li><a href="/guides/self-employed/">Self-employed</a></li>
        <li><a href="/guides/immediate-coverage/">Need coverage now</a></li>
        <li><a href="/find-my-dentist" class="di-hub-dentist">Find a dentist &rarr;</a></li>
      </ul>
      <div class="ts-wrap">
        <div class="theme-switch" id="cc-ts" data-active="gold" role="switch" aria-checked="false" tabindex="0" aria-label="Switch between Gold and Jade themes">
          <span class="ts-thumb"></span>
          <span class="ts-opt ts-gold"><span class="ts-dot"></span>Gold</span>
          <span class="ts-opt ts-jade"><span class="ts-dot"></span>Jade</span>
        </div>
      </div>
    </div>
  </div>
</nav>

<main>
<div class="wrap">
  <nav class="bc" aria-label="Breadcrumb">
    <a href="/">CoverCapy</a><span>/</span>Dental Insurance
  </nav>
</div>

<section class="hero">
  <div class="wrap">
    <span class="eyebrow">&#10038; PPO Dental Insurance</span>
    <h1>PPO dental insurance,<br><em>actually explained — 2026 guide.</em></h1>
    <p>Compare eight PPO plans side by side, look up any term in plain language, or find guidance for your specific situation: just laid off, self-employed, or needing coverage this week.</p>
    <div class="hero-ctas">
      <a href="/compare-ppo-dental-plans/" class="btn btn-primary">Compare all PPO plans &#8594;</a>
      <a href="/find-my-dentist" class="btn btn-outline">Find an in-network dentist</a>
    </div>
  </div>
</section>

<div class="page-layout">
<div class="main-col">
<div class="wrap" style="max-width:100%;padding:0">
  <div class="spoke-grid">
    <a href="/compare-ppo-dental-plans/" class="spoke-card spoke-primary">
      <span class="spoke-tag">Start here</span>
      <h2>Compare PPO dental plans</h2>
      <p>Eight individual PPO plans side by side. Sort by monthly cost, annual maximum, activation speed, or coverage tier. Match to your treatment in three questions.</p>
      <span class="spoke-link">Compare all plans &#8594;</span>
    </a>
    <a href="/guides/glossary/" class="spoke-card">
      <span class="spoke-tag">Learn</span>
      <h2>Dental insurance glossary</h2>
      <p>Plain-language definitions of 23 PPO terms: from annual maximum and waiting period to CDT codes and the missing tooth clause.</p>
      <span class="spoke-link">Browse all terms &#8594;</span>
    </a>
    <a href="/guides/no-waiting-period/" class="spoke-card">
      <span class="spoke-tag">Urgent need</span>
      <h2>Plans with no waiting period</h2>
      <p>Most plans make you wait six to twelve months for crowns and root canals. A few do not. Here is exactly which ones and how fast they activate.</p>
      <span class="spoke-link">See no-wait plans &#8594;</span>
    </a>
    <a href="/guides/between-jobs/" class="spoke-card">
      <span class="spoke-tag">Job change</span>
      <h2>Dental insurance between jobs</h2>
