<!-- UNIVERSAL COMPONENT LOADER -->
<script>
(function(){
  var components=[
    {mountId:'cc-nav-mount',   html:'/components/mega-nav.html', script:'/assets/js/mega-nav.js'},
    {mountId:'cc-footer-mount',html:'/components/footer.html',   script:'/assets/js/footer.js'}
  ];
  var loadScript=function(src){return new Promise(function(resolve){
    if(!src||document.querySelector('script[src="'+src+'"]'))return resolve();
    var s=document.createElement('script');
    s.src=src;s.defer=true;s.onload=function(){resolve()};s.onerror=function(){resolve()};
    document.body.appendChild(s);
  });};
  var replayScripts=function(scripts){scripts.forEach(function(old){
    if(!old.parentNode)return;
    var fresh=document.createElement('script');
    for(var i=0;i<old.attributes.length;i++)fresh.setAttribute(old.attributes[i].name,old.attributes[i].value);
    fresh.textContent=old.textContent;
    old.parentNode.replaceChild(fresh,old);
  });};
  var injectComponent=async function(c){
    var mount=document.getElementById(c.mountId);if(!mount)return;
    try{
      var res=await fetch(c.html,{cache:'no-cache'});
      if(!res.ok)throw new Error(c.html+' '+res.status);
      var wrapper=document.createElement('div');
      wrapper.innerHTML=await res.text();
      var injected=Array.from(wrapper.querySelectorAll('script'));
      var parent=mount.parentNode;
      while(wrapper.firstChild)parent.insertBefore(wrapper.firstChild,mount);
      parent.removeChild(mount);
      replayScripts(injected);
    }catch(e){console.warn('[CoverCapy loader]',c.html,e);}
  };
  var init=async function(){
    for(var i=0;i<components.length;i++)await injectComponent(components[i]);
    for(var i=0;i<components.length;i++)await loadScript(components[i].script);
  };
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init,{once:true});
  else init();
})();
</script>
<script>
/* Gold/Jade theme toggle — identical to T5 */
var ccHtml=document.documentElement,ccTs=document.getElementById('cc-ts');
function applyTheme(t,slow){
  var dur=slow?'1.4s':'0.45s';
  var st=document.getElementById('cc-theme-transition');
  if(!st){st=document.createElement('style');st.id='cc-theme-transition';document.head.appendChild(st);}
  st.textContent='html,html *{transition:background '+dur+' ease,color '+dur+' ease,border-color '+dur+' ease,box-shadow '+dur+' ease !important}';
  ccHtml.setAttribute('data-theme',t);
  if(ccTs){ccTs.setAttribute('data-active',t);ccTs.setAttribute('aria-checked',t==='jade'?'true':'false');}
  setTimeout(function(){if(st)st.textContent='';},slow?1600:600);
}
function initTheme(){
  applyTheme('gold',false);
  if(ccTs){
    ccTs.addEventListener('click',function(){applyTheme(ccHtml.getAttribute('data-theme')==='gold'?'jade':'gold',false);});
    ccTs.addEventListener('keydown',function(e){if(e.key==='Enter'||e.key===' '){e.preventDefault();ccTs.click();}});
  }
}
initTheme();
window.addEventListener('load',function(){
  setTimeout(function(){
    if(ccTs)ccTs.classList.add('flipping');
    applyTheme('jade',true);
    setTimeout(function(){if(ccTs)ccTs.classList.remove('flipping');},2000);
  },900);
});
</script>
<div id="cc-footer-mount"></div>
</body>
