#!/usr/bin/env node
/* ============================================================
   CoverCapy build step : generate-plans.js
   ============================================================
   Task 1 (original):
     Pulls active rows from public.ppo_plans and bakes them into
     the static comparison table + verified date inside
     compare-ppo-dental-plans.html, between HTML markers.

   Task 2 (new):
     Generates static SEO pages at:
       dental/{state}/{market}/index.html        — market hub
       dental/{state}/{market}/{city}/index.html — city page
     Uses real CoverCapy design tokens + Fraunces/Inter Tight fonts.
     Nav + footer loaded via the same component-loader pattern as
     all other covercapycodex pages.

   Usage:
     SUPABASE_ANON_KEY=xxx node generate-plans.js            # both tasks
     SUPABASE_ANON_KEY=xxx node generate-plans.js --plans-only
     SUPABASE_ANON_KEY=xxx node generate-plans.js --locations-only
     SUPABASE_ANON_KEY=xxx node generate-plans.js --market "Orange County"
     SUPABASE_ANON_KEY=xxx node generate-plans.js --dry-run
   ============================================================ */

