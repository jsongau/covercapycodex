/* ── Utilities ───────────────────────────────────────────── */

const esc = (s) => String(s ?? '')
  .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

const fmtDate = (iso) => {
  const d = new Date(iso + 'T00:00:00');
  return d.toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' });
};

function slugify(str) {
  return (str || '').toLowerCase()
    .replace(/['']/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

function stateSlug(s) {
  const m = {
    'California':'california','Illinois':'illinois','Texas':'texas',
    'Florida':'florida','Nevada':'nevada','Arizona':'arizona',
    'Pennsylvania':'pennsylvania','Connecticut':'connecticut',
    'Rhode Island':'rhode-island','New Jersey':'new-jersey',
    'New York':'new-york','Georgia':'georgia','Virginia':'virginia',
  };
  return m[s] || slugify(s);
}

function stateAbbr(s) {
  const m = {
    'Alabama':'AL','Alaska':'AK','Arizona':'AZ','Arkansas':'AR','California':'CA',
    'Colorado':'CO','Connecticut':'CT','Delaware':'DE','District of Columbia':'DC',
    'Florida':'FL','Georgia':'GA','Hawaii':'HI','Idaho':'ID','Illinois':'IL',
    'Indiana':'IN','Iowa':'IA','Kansas':'KS','Kentucky':'KY','Louisiana':'LA',
    'Maine':'ME','Maryland':'MD','Massachusetts':'MA','Michigan':'MI','Minnesota':'MN',
    'Mississippi':'MS','Missouri':'MO','Montana':'MT','Nebraska':'NE','Nevada':'NV',
    'New Hampshire':'NH','New Jersey':'NJ','New Mexico':'NM','New York':'NY',
    'North Carolina':'NC','North Dakota':'ND','Ohio':'OH','Oklahoma':'OK','Oregon':'OR',
    'Pennsylvania':'PA','Rhode Island':'RI','South Carolina':'SC','South Dakota':'SD',
    'Tennessee':'TN','Texas':'TX','Utah':'UT','Vermont':'VT','Virginia':'VA',
    'Washington':'WA','West Virginia':'WV','Wisconsin':'WI','Wyoming':'WY',
  };
  return m[s] || s.substring(0, 2).toUpperCase();
}

function nameHash(str) {
  let h = 0;
  for (let i = 0; i < str.length; i++) h = ((h << 5) - h) + str.charCodeAt(i);
  return Math.abs(h);
}

/* ── Carrier acceptance counts from dentist data ──────── */
// Preferred display order — matches CARRIER_PRIORITY in index.md
const CARRIER_DISPLAY = [
  { key:'delta dental', label:'Delta Dental' },
  { key:'united',       label:'UnitedHealthCare' },
  { key:'guardian',     label:'Guardian' },
  { key:'aetna',        label:'Aetna' },
  { key:'cigna',        label:'Cigna' },
  { key:'metlife',      label:'MetLife' },
  { key:'ameritas',     label:'Ameritas' },
  { key:'humana',       label:'Humana' },
];

function carrierCounts(dentists) {
  const counts = {};
  for (const d of dentists) {
    const nets = Array.isArray(d.insurance_networks) ? d.insurance_networks : [];
    for (const n of nets) {
      const nl = (n || '').toLowerCase();
      for (const c of CARRIER_DISPLAY) {
        if (nl.includes(c.key)) { counts[c.key] = (counts[c.key] || 0) + 1; break; }
      }
    }
  }
  return CARRIER_DISPLAY
    .filter(c => counts[c.key])
    .map(c => ({ label: c.label, count: counts[c.key] }))
    .sort((a, b) => b.count - a.count)
    .slice(0, 6);
}

function carrierRailCard(dentists, total) {
  return '';
  const carriers = carrierCounts(dentists);
  if (!carriers.length) return '';
  const rows = carriers.map(c => {
    const pct = Math.round((c.count / total) * 100);
    return `<div class="rail-city-row"><span style="font-weight:600;color:var(--dark)">${esc(c.label)}</span><span class="rail-city-count">${pct}% of offices</span></div>`;
  }).join('');
  return `<div class="rail-card">
  <div class="rail-head">Carriers Accepted</div>
  ${rows}
  <div style="padding:10px 16px;font-size:12px;color:var(--muted)">% of listed offices accepting each carrier</div>
</div>`;
}

/* ── Supabase fetch ──────────────────────────────────────── */

async function sb(path, opts = {}) {
  const url = SUPABASE_URL + path;
  const res = await fetch(url, {
    method: opts.method || 'GET',
    headers: {
      'apikey': ANON_KEY,
      'Authorization': 'Bearer ' + ANON_KEY,
      'Content-Type': 'application/json',
      'Prefer': opts.prefer || 'return=representation',
      ...opts.headers,
    },
    body: opts.body ? JSON.stringify(opts.body) : undefined,
  });
  if (!res.ok) {
    const err = await res.text();
    throw new Error(`Supabase ${res.status}: ${err.slice(0, 200)}`);
  }
  return res.json();
}

/* ══════════════════════════════════════════════════════════
   TASK 1 — Plan table injection (original logic, unchanged)
══════════════════════════════════════════════════════════ */

async function injectPlanTable() {
  const plans = await sb(
    '/rest/v1/ppo_plans?is_active=eq.true&order=sort_order.asc'
    + '&select=plan_key,name,name_em,sub_carrier,monthly_text,cap_text,'
    + 'table_preventive,table_basic,table_major,table_implant,table_ortho,table_watch,plan_page,verified_at'
  );
  if (!Array.isArray(plans) || plans.length === 0) {
    console.warn('[plans] WARNING: No active plans — deploying with existing HTML');
    return;
  }
  console.log('[plans] Loaded', plans.length, 'plans');

  const rows = plans.map((p) => {
    const href = String(p.plan_page || '#').replace(/^\//, '');
    return `            <tr>
              <th scope="row"><a href="${esc(href)}">${esc(p.name)} ${esc(p.name_em)}</a><span class="sub">${esc(p.sub_carrier)}</span></th>
              <td>${esc(p.monthly_text).replace('/mo','')}</td>
              <td>${esc(p.cap_text)}</td>
              <td>${esc(p.table_preventive)}</td>
              <td>${esc(p.table_basic)}</td>
              <td>${esc(p.table_major)}</td>
              <td>${esc(p.table_implant)}</td>
              <td>${esc(p.table_ortho)}</td>
              <td class="watch">${esc(p.table_watch)}</td>
            </tr>`;
  }).join('\n');

  const newest   = plans.map((p) => p.verified_at).sort().pop();
  const dateText = fmtDate(newest);

  let html = fs.readFileSync(PLANS_PAGE, 'utf8');

  const T1 = '<!-- PLANS_TABLE_ROWS_START -->';
  const T2 = '<!-- PLANS_TABLE_ROWS_END -->';
  const t1 = html.indexOf(T1), t2 = html.indexOf(T2);
  if (t1 === -1 || t2 === -1) {
    console.warn('[plans] WARNING: Table markers not found in', PLANS_PAGE, '— skipping');
    return;
  }
  html = html.slice(0, t1 + T1.length) + '\n' + rows + '\n            ' + html.slice(t2);

  html = html.replace(
    /(<!-- VERIFIED_DATE_START -->)([\s\S]*?)(<!-- VERIFIED_DATE_END -->)/g,
    `$1${dateText}$3`
  );
  html = html.replace(/"dateModified":\s*"[0-9-]+"/, `"dateModified": "${newest}"`);
  html = html.replace(/"lastReviewed":\s*"[0-9-]+"/, `"lastReviewed": "${newest}"`);
  html = html.split('__SUPABASE_PUBLISHABLE_KEY__').join(BROWSER_KEY);

  if (!DRY_RUN) fs.writeFileSync(PLANS_PAGE, html);
  console.log('[plans]', DRY_RUN ? '[DRY-RUN]' : 'Wrote', PLANS_PAGE, '| verified', dateText);
}

/* ══════════════════════════════════════════════════════════
   TASK 2 — Location page generator
══════════════════════════════════════════════════════════ */

/* ── Data queries ─────────────────────────────────────────── */

async function fetchAllRows(basePath, opts = {}) {
  // Supabase PostgREST hard-caps responses at 1000 rows server-side.
  // Paginate using Range header until we get a partial page (< 1000 rows).
  const PAGE = 1000;
  const all = [];
  let offset = 0;
  while (true) {
    const batch = await sb(basePath, {
      ...opts,
      headers: {
        ...(opts.headers || {}),
        'Range': `${offset}-${offset + PAGE - 1}`,
        'Range-Unit': 'items',
        'Prefer': 'count=none',
      },
    });
    if (!Array.isArray(batch)) break;
    all.push(...batch);
    if (batch.length < PAGE) break;  // last page
    offset += PAGE;
  }
  return all;
}

/* ── De-duplicate office rows ─────────────────────────────────
   Supabase sometimes holds the same physical office as two+ rows
   (same street, one copy just has a fuller address / a phone), each
   carrying its own hashed slug. Left alone, the generator emits one
   page per row = duplicate pages. This collapses true duplicate rows
   to the single best-quality row, while keeping genuinely different
   locations of a same-named practice separate. Build-time only — it
   never touches the database. */
function ccNormStreet(addr) {
  return String(addr || '')
    .split(',')[0]                                  // street portion only
    .toLowerCase()
    .replace(/\b(ste|suite|unit|apt|#).*$/, '')     // drop unit/suite noise
    .replace(/[^a-z0-9]/g, '');                     // strip punctuation/spaces
}
function ccBaseSlug(d) {
  return (d.slug || slugify(d.name || 'dentist')).replace(/-[0-9a-f]{6}$/, '');
}
function ccOfficeScore(d) {
  let s = 0;
  if (d.membership_tier && d.membership_tier !== 'free') s += 1000;
  if (d.is_claimed) s += 500;
  if (d.phone) s += 100;
  if (d.latitude && d.longitude) s += 50;
  s += String(d.address || '').length;              // prefer the fuller address
  return s;
}
function dedupeOffices(rows) {
  const groups = new Map();
  for (const d of rows) {
    const st = ccNormStreet(d.address);
    // Identity: same street + same base name, in the same city/state.
    // With no usable address, key on id so we never merge unrelated
    // offices that merely share a name.
    const key = st
      ? `${d.state}|${d.city}|${st}|${ccBaseSlug(d)}`
      : `${d.state}|${d.city}|${ccBaseSlug(d)}|${d.id}`;
    const cur = groups.get(key);
    if (!cur || ccOfficeScore(d) > ccOfficeScore(cur)) groups.set(key, d);
  }
  const out = [...groups.values()];
  const dropped = rows.length - out.length;
  if (dropped > 0) console.log(`  ↳ deduped ${dropped} duplicate office row(s) (${rows.length} -> ${out.length})`);
  return out;
}

async function fetchMarkets() {
  // Paginate to bypass Supabase's 1000-row server-side cap.
  const rows = await fetchAllRows(
    '/rest/v1/dentists?select=state,market_area,seo_area,city,weighted_rating,google_review_count,listing_type'
    + '&listing_type=not.eq.placeholder&order=market_area.asc'
  );
  console.log(`[debug] fetchMarkets: ${rows.length} rows fetched`);
  const mkts = {};
  for (const r of rows) {
    if (!r.market_area || !r.state) continue;
    if (!mkts[r.market_area]) mkts[r.market_area] = { state: r.state, market_area: r.market_area, seo_area: r.seo_area || r.market_area, offices: [], cities: new Set() };
    mkts[r.market_area].offices.push(r);
    if (r.city) mkts[r.market_area].cities.add(r.city);
  }
  return Object.values(mkts)
    .filter(m => m.offices.length >= MIN_OFFICES)
    .filter(m => !MARKET_FILTER || m.market_area === MARKET_FILTER)
    .map(m => {
      const ratings = m.offices.map(o => parseFloat(o.weighted_rating)).filter(v => v > 0);
      return {
        state: m.state,
        market_area: m.market_area,
        seo_area: m.seo_area,
        office_count: m.offices.length,
        avg_rating: ratings.length ? (ratings.reduce((a,b) => a+b, 0) / ratings.length).toFixed(1) : null,
        total_reviews: m.offices.reduce((s,o) => s + (parseInt(o.google_review_count)||0), 0),
        cities: [...m.cities].sort(),
      };
    })
    .sort((a,b) => b.office_count - a.office_count);
}

async function fetchDentists(marketArea) {
  const rows = await fetchAllRows(
    '/rest/v1/dentists?select=id,name,slug,city,state,market_area,seo_area,address,phone,email,website,'
    + 'membership_tier,accreditation_status,is_claimed,booking_url,'
    + 'weighted_rating,google_rating,google_review_count,'
    + 'insurance_networks,procedures,latitude,longitude,doctor_name,open_weekends'
    + '&market_area=eq.' + encodeURIComponent(marketArea)
    + '&listing_type=not.eq.placeholder'
    + '&order=membership_tier.asc,weighted_rating.desc.nullslast'
  );
  return dedupeOffices(rows.map(d => ({
    ...d,
    insurance_networks: (d.insurance_networks || []).filter(n =>
      !n.toLowerCase().includes('pending') &&
      !n.toLowerCase().includes('verify before')
    ),
  })));
}

async function fetchLocalAreaDentists(localArea) {
  const rows = await fetchAllRows(
    '/rest/v1/dentists?select=id,name,slug,city,state,market_area,seo_area,local_area,address,phone,email,website,'
    + 'membership_tier,accreditation_status,is_claimed,booking_url,'
    + 'weighted_rating,google_rating,google_review_count,'
    + 'insurance_networks,procedures,latitude,longitude,doctor_name,open_weekends'
    + '&local_area=eq.' + encodeURIComponent(localArea)
    + '&listing_type=not.eq.placeholder'
    + '&order=membership_tier.asc,weighted_rating.desc.nullslast'
  );
  return dedupeOffices(rows.map(d => ({
    ...d,
    insurance_networks: (d.insurance_networks || []).filter(n =>
      !n.toLowerCase().includes('pending') &&
      !n.toLowerCase().includes('verify before')
    ),
  })));
}

/* Fetch all dentists for a list of market_areas (for regional hubs) */
async function fetchRegionalDentists(marketAreas) {
  const rows = await fetchAllRows(
    '/rest/v1/dentists?select=id,name,slug,city,state,market_area,seo_area,local_area,address,phone,email,website,'
    + 'membership_tier,accreditation_status,is_claimed,booking_url,'
    + 'weighted_rating,google_rating,google_review_count,'
    + 'insurance_networks,procedures,latitude,longitude,doctor_name,open_weekends'
    + '&market_area=in.(' + marketAreas.map(m => encodeURIComponent(m)).join(',') + ')'
    + '&listing_type=not.eq.placeholder'
    + '&order=membership_tier.asc,weighted_rating.desc.nullslast'
  );
  return dedupeOffices(rows.map(d => ({
    ...d,
    insurance_networks: (d.insurance_networks || []).filter(n =>
      !n.toLowerCase().includes('pending') &&
      !n.toLowerCase().includes('verify before')
    ),
  })));
}

function groupByCities(dentists) {
  const map = {};
  for (const d of dentists) {
    if (!d.city) continue;
    if (!map[d.city]) map[d.city] = [];
    map[d.city].push(d);
  }
  return Object.entries(map)
    .filter(([, offices]) => offices.length >= MIN_OFFICES)
    .map(([city, offices]) => {
      const ratings = offices.map(o => parseFloat(o.weighted_rating)).filter(v => v > 0);
      return {
        city,
        office_count: offices.length,
        avg_rating: ratings.length ? (ratings.reduce((a,b) => a+b, 0) / ratings.length).toFixed(1) : null,
        total_reviews: offices.reduce((s,o) => s + (parseInt(o.google_review_count)||0), 0),
        dentists: offices,
      };
    })
    .sort((a,b) => b.office_count - a.office_count);
}

/* ── Copy variants ───────────────────────────────────────── */

function marketIntro(market, state, count, avgRating) {
  const OPENER_PATTERNS = ['stat', 'scenario', 'neighborhood', 'patient_voice', 'counter'];
  const pattern = OPENER_PATTERNS[nameHash(market) % 5];
  const rNote = avgRating && parseFloat(avgRating) > 3
    ? ` Patient reviews average ${avgRating} stars across verified practices here.` : '';

  const v = {
    stat: `${market} has ${count} dental offices currently verified as accepting one or more major PPO networks — ${count > 100 ? `one of the largest concentrations in ${state}` : `a strong selection for ${state} patients`}. Whether you're near the city center or across the metro, you'll find in-network options within a reasonable drive. CoverCapy shows which offices have current in-network status and contacts them so you never have to navigate hold music.${rNote}`,
    scenario: `Your HR email finally arrived: benefits start the first of next month. You've got a tooth that's been bothering you and you want an office that actually accepts your specific plan. The practical question is which ${market} dental offices take your coverage — not just "accepts PPO" but your exact carrier and plan tier. CoverCapy maintains verified network participation data and confirms new-patient status so you're not calling five offices from a parking lot.${rNote}`,
    neighborhood: `${market}'s dental market spans everything from solo practitioners who've been in the same location for two decades to modern multi-specialty group practices with digital imaging and same-day crowns. The common thread: ${count} of them are verified as participating in at least one major PPO network. What that means for you depends on your carrier — and CoverCapy can pull that answer before you ever pick up the phone.${rNote}`,
    patient_voice: `"I had no idea which ${market} dentist would take my Aetna plan after I switched jobs mid-year." That kind of uncertainty costs patients real money — calling offices that turn out to be out-of-network, paying full-freight on what should have been a covered cleaning. The ${count} offices listed here are confirmed PPO participants. Confirm which ones take your specific plan and what your out-of-pocket looks like before you go in.${rNote}`,
    counter: `Not every PPO-accepting office in ${market} is the same — some participate in Delta Dental Premier but not PPO, some are in UHC's network but dropped Cigna last renewal. The ${count} offices listed here have confirmed current network participation, not just a flag that says "accepts PPO" from three years ago. The difference matters when your deductible is $50 vs. $200 depending on in-network status.${rNote}`,
  };
  return v[pattern];
}

function cityIntro(city, market, state, count, avgRating) {
  const abbr  = stateAbbr(state);
  const OPENER_PATTERNS = ['stat', 'scenario', 'neighborhood', 'patient_voice', 'counter'];
  const pattern = OPENER_PATTERNS[nameHash(city) % 5];
  const ratingDisplay = avgRating && parseFloat(avgRating) > 3 ? (parseFloat(avgRating).toFixed(1)) : '4.7';

  const v = {
    stat: `${city} has ${count} dental offices currently verified as PPO-participating — more than most ${market} cities its size. Patient reviews average ${ratingDisplay} stars across verified practices here. CoverCapy confirms which offices are in-network for your specific plan and contacts them on your behalf.`,
    scenario: `Your deductible resets in January. You've been meaning to get that crown done and you finally have coverage — but which ${city} dental office actually accepts your specific plan? Not "accepts PPO" generically, but your exact carrier and tier. The ${count} offices below have confirmed current network participation. Verification takes under two minutes.`,
    neighborhood: `${city}'s dental landscape has changed over the past few years — more group practices, more digital workflows, more PPO carrier contracts. The ${count} offices listed here reflect current verified participation in at least one major PPO network. Use the carrier filter to narrow to your plan.`,
    patient_voice: `"Getting a cleaning scheduled in ${city} without knowing if my plan was actually accepted there was the most frustrating part of switching jobs." That friction is what CoverCapy removes. The ${count} offices below are verified PPO participants. Click Verify on any card to see your specific benefits — deductible remaining, annual max, co-insurance — before you book.`,
    counter: `${city} has plenty of dental offices that say they take PPO — the question is which tier of your carrier's network they're actually in. A Delta Dental Premier provider isn't necessarily Delta Dental PPO. The ${count} offices here have confirmed participation in the specific networks shown on each card. CoverCapy shows the listed networks, so you can confirm before paying out-of-network rates on what should be a covered visit.`,
  };
  return v[pattern];
}

/* ── Dentist card ─────────────────────────────────────────── */

function tierBadge(d) {
  if (d.membership_tier === 'platinum_elite' || d.accreditation_status === 'Platinum Elite')
    return `<span class="badge-platinum">★ Platinum Elite</span>`;
  if (d.accreditation_status === 'Capy Accredited' || d.membership_tier === 'capy_accredited')
    return `<span class="badge-accredited">Capy Accredited</span>`;
  if (d.accreditation_status === 'Verified')
    return `<span class="badge-verified">Verified</span>`;
  return '';
}

function dentistCard(d, stSlug, mkSlug, isFirst = false) {
  const r        = parseFloat(d.weighted_rating);
  const badge    = tierBadge(d);
  const isPlatinum = d.membership_tier === 'platinum_elite' || d.accreditation_status === 'Platinum Elite';
  const nets     = d.insurance_networks.slice(0, 5).map(n => `<span class="net-pill">${esc(n)}</span>`).join('');
  const profile = `${BASE_URL}/dental/${stSlug}/${mkSlug}/${slugify(d.city||'')}/${d.slug||slugify(d.name)}/`;
  const weekends = d.open_weekends ? `<span class="status-pill verified">Open weekends</span>` : '';
  const ratingHtml = r > 0
    ? `<div class="rating-row"><span class="star">★</span> <strong>${r.toFixed(1)}</strong> ${d.google_review_count ? `<span class="rev-count">(${parseInt(d.google_review_count).toLocaleString()} reviews)</span>` : ''}</div>`
    : '';
  const verifyUrl = `${BASE_URL}/find-my-dentist?q=${encodeURIComponent(d.city||'')}`;

  if (isFirst) {
    return `<div class="dcard featured">
  <div class="dcard-img" aria-hidden="true">Office photo</div>
  <div class="dcard-body">
    <div class="dcard-top">
      <div>
        <div class="dcard-name">${esc(d.name)}</div>
        ${d.doctor_name ? `<div class="dcard-doc">${esc(d.doctor_name)}</div>` : ''}
        ${ratingHtml}
      </div>
      <div class="dcard-badges">${badge}${weekends}</div>
    </div>
    ${d.address ? `<div class="dcard-meta">${esc(d.address)}</div>` : ''}
    ${nets ? `<div class="dcard-nets">${nets}</div>` : ''}
    <div class="dcard-actions">
      <a class="btn-verify-ppo" href="${verifyUrl}">Verify my PPO here, free</a>
      <a class="dcard__profile-link" href="${profile}">View full profile</a>
    </div>
  </div>
</div>`;
  }

  const cardClass = isPlatinum ? 'dcard platinum' : 'dcard';
  return `<div class="${cardClass}">
  <div class="dcard-top">
    <div>
      <div class="dcard-name">${esc(d.name)}</div>
      ${d.doctor_name ? `<div class="dcard-doc">${esc(d.doctor_name)}</div>` : ''}
      ${ratingHtml}
    </div>
    <div class="dcard-badges">${badge}${weekends}</div>
  </div>
  ${d.address ? `<div class="dcard-meta">${esc(d.address)}</div>` : ''}
  ${nets ? `<div class="dcard-nets">${nets}</div>` : ''}
  <div class="dcard-actions">
    <a class="btn-verify-ppo" href="${verifyUrl}">Verify my PPO here, free</a>
    <a class="dcard__profile-link" href="${profile}">View full profile</a>
  </div>
</div>`;
}

/* ── FAQ builder ──────────────────────────────────────────── */

function marketFAQs(market, state, count) {
  const abbr = stateAbbr(state);
  return [
    { q: `How many PPO dentists are in ${market}?`,
      a: `CoverCapy lists ${count} verified PPO-participating offices across ${market}, ${abbr}. The count reflects confirmed network participation. Use the city links to narrow to your neighborhood.` },
    { q: `Can I verify my insurance before booking a ${market} dentist?`,
      a: `Yes. Create a free CoverCapy account, enter your carrier and member ID, and we pull a live eligibility snapshot — deductible, annual maximum remaining, and coverage percentages — before you pick up the phone.` },
    { q: `What PPO plans are accepted by dentists in ${market}?`,
      a: `Delta Dental PPO, UnitedHealthCare, Guardian, Aetna, Cigna, and MetLife are the carriers with the widest acceptance across ${market} offices. Ameritas and Mutual of Omaha are accepted at a growing number of practices. Verify your specific plan — network participation varies by individual office and plan tier.` },
    { q: `What if I don't have dental insurance in ${market}?`,
      a: `CoverCapy sells PPO plans starting at $30/month with next-day activation (UHC) and day-one major coverage options (Ameritas PrimeStar). After purchase, you're routed directly to a nearby in-network office.` },
    { q: `How is CoverCapy different from Zocdoc for finding a dentist in ${market}?`,
      a: `Zocdoc shows you dentists with open appointments. CoverCapy shows you which of those dentists are in-network for your specific PPO plan, what your out-of-pocket looks like before you go in, and will sell you coverage on the spot if you need it.` },
    { q: `Does "accepts PPO" mean my plan is covered at every ${market} office?`,
      a: `No. "Accepts PPO" is a broad claim. Some offices participate in Delta Dental Premier but not Delta Dental PPO. Others are in UHC's network but not Cigna's. Confirm participation at the plan-tier level with the office before your appointment, not after.` },
    { q: `How often is the ${market} dentist directory updated?`,
      a: `Network participation data is refreshed regularly through carrier feeds and direct outreach. The date on each page shows the last verified date. If you notice an out-of-date listing, use the "Report" link on any card.` },
    { q: `What does a PPO eligibility check include?`,
      a: `A CoverCapy eligibility check pulls your current deductible balance, annual maximum remaining, co-insurance percentages for preventive, basic, and major services, and whether the specific office participates in your plan tier — all in real time before you call.` },
    { q: `Can I find a same-day or emergency dentist in ${market} through CoverCapy?`,
      a: `Yes. Filter the map for "accepting new patients" and sort by distance. Many offices in ${market} offer same-day appointments for emergencies. CoverCapy confirms in-network status so emergency care doesn't come as a financial surprise.` },
    { q: `Is CoverCapy free to use for finding dentists in ${market}?`,
      a: `Finding and verifying dentists is free. CoverCapy earns revenue when you purchase a dental plan — plans start at $30/month. Eligibility checks for plans you already have are always free.` },
  ];
}

function cityFAQs(city, market, state, count) {
  const abbr = stateAbbr(state);
  return [
    { q: `Are there PPO dentists in ${city}, ${abbr}?`,
      a: `Yes — ${count} PPO-participating offices are listed for ${city}. These practices accept at least one major PPO carrier network, and eligibility for your specific plan can be confirmed with the office at no cost.` },
    { q: `How do I find an in-network dentist in ${city} for my PPO plan?`,
      a: `Browse the offices below and look for your carrier in the listed insurance networks. Then click "Verify my PPO here" on any listing — CoverCapy pulls your live benefits (deductible, max, co-insurance) in real time. No phone calls, no fax.` },
    { q: `What's the difference between a PPO and HMO dentist in ${city}?`,
      a: `A PPO lets you see any provider, with better cost coverage for in-network offices and some out-of-network coverage. An HMO requires you stay within a specific panel. All offices listed here are PPO-compatible — you get the in-network cost advantage.` },
    { q: `I just moved to ${city} — how do I set up dental coverage?`,
      a: `If you have employer coverage, your HR portal will list in-network offices. If you need individual coverage, CoverCapy sells PPO plans starting at $30/month with next-day activation. After buying, you're matched to nearby in-network offices in ${city} automatically.` },
    { q: `Does "accepts PPO" mean my Delta Dental or Aetna plan is covered in ${city}?`,
      a: `Not automatically. PPO participation is carrier- and tier-specific. An office might accept Delta Dental Premier but not Delta Dental PPO. CoverCapy's verification confirms which networks each ${city} office participates in at the tier level.` },
    { q: `How quickly can I get a dental appointment in ${city}?`,
      a: `Availability varies by office. New-patient appointments in ${city} are typically available within one to two weeks; offices with emergency availability often have same-day openings. Use CoverCapy to verify in-network status first, then contact the office directly to schedule.` },
    { q: `What does a routine cleaning cost out-of-pocket in ${city} for PPO patients?`,
      a: `For in-network PPO patients, preventive services (cleaning, exam, X-rays) are typically covered at 80–100% — meaning $0–$40 out-of-pocket depending on your plan. Out-of-network, the same visit can run $150–$300. CoverCapy shows your exact cost before you go.` },
  ];
}

/* ── City-page SEO helpers (template brief, 2026-06-25) ────────
   All derive their output from per-city dentist data so every
   city page self-varies (prevents duplicate-meta/thin penalties).  */

// Distinct carrier display labels actually present in this city's listings,
// in CARRIER_DISPLAY priority order. Returns [] when no carrier data exists.
function cityCarrierLabels(dentists) {
  const seen = new Set();
  const out = [];
  for (const c of CARRIER_DISPLAY) {
    for (const d of dentists) {
      const nets = Array.isArray(d.insurance_networks) ? d.insurance_networks : [];
      if (nets.some(n => (n || '').toLowerCase().includes(c.key))) {
        if (!seen.has(c.key)) { seen.add(c.key); out.push(c.label); }
        break;
      }
    }
  }
  return out;
}

// Map a carrier display label to its on-site hub URL (or null if none).
function cityCarrierHubUrl(label) {
  return carrierHubLink(label) || carrierHubLink((label || '').toLowerCase());
}

// Pull distinct ZIP codes that appear in the listing addresses for this city.
function cityZips(dentists) {
  const zips = new Set();
  for (const d of dentists) {
    const m = String(d.address || '').match(/\b(\d{5})(?:-\d{4})?\b/g);
    if (m) m.forEach(z => zips.add(z.slice(0, 5)));
  }
  return [...zips].slice(0, 3);
}

// Plural-safe helper: "1 office" / "3 offices", "1 city" / "4 cities".
function plural(n, singular, pluralWord) {
  return `${n} ${n === 1 ? singular : (pluralWord || singular + 's')}`;
}

// Data-driven local-context paragraph (brief block #1). Varies by ZIP,
// carriers present, and real neighbor cities — no single reused sentence.
function cityLocalContext(city, market, state, dentists, nearby) {
  const abbr  = stateAbbr(state);
  const count = dentists.length;
  const zips  = cityZips(dentists);
  const carriers = cityCarrierLabels(dentists);
  const neighborNames = (nearby || []).filter(c => c && c.city && c.city !== city).slice(0, 3).map(c => c.city);

  const zipPart = zips.length
    ? ` Listed offices serve ${zips.length === 1 ? 'ZIP code' : 'ZIP codes'} ${zips.join(', ')}.`
    : '';
  const carrierPart = carriers.length
    ? ` PPO carriers accepted by ${city} offices in this directory include ${carriers.slice(0, 4).join(', ')}.`
    : ` Each listing shows the PPO carriers that office is recorded as accepting.`;
  const neighborPart = neighborNames.length
    ? ` Nearby ${plural(neighborNames.length, 'city', 'cities')} in the ${market} area ${neighborNames.length === 1 ? 'is' : 'include'} ${neighborNames.join(', ')}.`
    : '';

  return `${city}, ${abbr} is part of the ${market} area.${zipPart} CoverCapy lists ${plural(count, 'PPO-participating office', 'PPO-participating offices')} here.${carrierPart}${neighborPart} Network participation is set at the plan-tier level, not just the carrier, so confirm your specific plan with the office before booking.`;
}

// "How to verify your plan in {City}" steps (brief block #4).
function cityVerifySteps(city) {
  return [
    `Find your carrier in the listed networks on any ${city} office card below.`,
    `Click Verify my PPO here to start a free eligibility check, no phone calls or fax.`,
    `Confirm the office takes your exact tier (for example Delta Dental PPO versus Delta Dental Premier), not just the carrier name.`,
    `Confirm new-patient availability with the office before you book your visit.`,
  ];
}

// Carrier-summary line + pill-links into the carrier hubs and find-my-dentist
// (brief block #2/#3 + carrier-cluster internal links). Returns '' when no
// carrier data exists, so nothing unsourced is printed.
function cityCarrierSection(city, dentists, stSlug, mkSlug) {
  const carriers = cityCarrierLabels(dentists);
  const verifyQ  = `${BASE_URL}/find-my-dentist?q=${encodeURIComponent(city)}`;
  if (!carriers.length) {
    return `<div class="carrier-summary">
      <p>Each ${esc(city)} office card lists the PPO carriers that office is recorded as accepting. <a href="${verifyQ}">Verify your plan free before booking.</a></p>
    </div>`;
  }
  const pills = carriers.slice(0, 8).map(label => {
    const hub = cityCarrierHubUrl(label);
    return hub
      ? `<a class="carrier-pill" href="${hub}">${esc(label)}</a>`
      : `<span class="carrier-pill carrier-pill--plain">${esc(label)}</span>`;
  }).join('');
  return `<div class="carrier-summary">
      <p>PPO carriers accepted by ${esc(city)} offices in this directory include ${esc(carriers.slice(0, 4).join(', '))}. <a href="${BASE_URL}/compare-ppo-dental-plans">Compare PPO plans</a> or <a href="${verifyQ}">verify your plan free</a>.</p>
      <div class="carrier-pills">${pills}</div>
    </div>`;
}

// Localized, carrier/ZIP-aware FAQ (brief block #5). Light per-city logic so
// no two pages ship identical block text. Mirrored to FAQPage schema.
function cityLocalFAQs(city, market, state, dentists) {
  const abbr     = stateAbbr(state);
  const count    = dentists.length;
  const carriers = cityCarrierLabels(dentists);
  const zips     = cityZips(dentists);
  const faqs = [];

  faqs.push({
    q: `Are there in-network PPO dentists in ${city}, ${abbr}?`,
    a: `Yes. CoverCapy lists ${plural(count, 'PPO-participating office', 'PPO-participating offices')} in ${city}${zips.length ? ` covering ${plural(zips.length, 'ZIP code', 'ZIP codes')} ${zips.join(', ')}` : ''}. Each card shows that office's recorded carriers, and you can confirm your specific plan free before booking.`,
  });

  if (carriers.length) {
    const first = carriers[0];
    faqs.push({
      q: `Which dentists in ${city} accept ${first}?`,
      a: `Several ${city} offices in this directory are recorded as accepting ${first}${carriers.length > 1 ? ` along with ${carriers.slice(1, 3).join(' and ')}` : ''}. Look for ${first} in the carrier pills on each office card, then verify your exact plan tier with the office.`,
    });
  }

  faqs.push({
    q: count <= 3
      ? `Do I have to leave ${city} to find an in-network office?`
      : `How do I choose between PPO dentists in ${city}?`,
    a: count <= 3
      ? `Not necessarily. ${city} has ${plural(count, 'listed PPO office', 'listed PPO offices')}, and nearby cities in the ${market} area add more in-network choices. Use the nearby-cities links below to widen your search without leaving the ${market} area.`
      : `Compare the offices below by their listed carriers, patient ratings shown from public Google data, and location. Then verify your specific plan free before you call so you know your coverage at that office's plan tier.`,
  });

  faqs.push({
    q: `Does the ${city} office accept new patients on my plan?`,
    a: `New-patient availability is set by each office and can change. Confirm it directly with the ${city} office when you verify your PPO coverage, so you know both that your plan is in-network and that the office can see you.`,
  });

  faqs.push({
    q: `What does "PPO-participating" mean for ${city} offices?`,
    a: `It means the office is recorded as participating in at least one PPO carrier network. It is a starting point, not a guarantee for your specific plan or tier. CoverCapy's free verification confirms participation at the plan-tier level before you book.`,
  });

  return faqs;
}

/* ── Component loader script (matches existing site pattern) */
const COMPONENT_LOADER = `<script>
(function(){
  const components = [
    { mountId: 'cc-nav-mount',    html: '/components/mega-nav.html', script: '/assets/js/mega-nav.js' },
    { mountId: 'cc-footer-mount', html: '/components/footer.html',   script: '/assets/js/footer.js' }
  ];
  const loadScript = (src) => new Promise(resolve => {
    if (!src || document.querySelector('script[src="'+src+'"]')) return resolve();
    const sc = document.createElement('script');
    sc.src = src; sc.defer = true;
    sc.onload = () => resolve();
    sc.onerror = () => { console.warn('[CoverCapy loader] script failed:', src); resolve(); };
    document.body.appendChild(sc);
  });
  const replayScripts = (scripts) => {
    scripts.forEach(old => {
      if (!old.parentNode) return;
      const fresh = document.createElement('script');
      for (const attr of old.attributes) fresh.setAttribute(attr.name, attr.value);
      fresh.textContent = old.textContent;
      old.parentNode.replaceChild(fresh, old);
    });
  };
  const injectComponent = async ({ mountId, html: url }) => {
    const mount = document.getElementById(mountId);
    if (!mount) return;
    try {
      const res = await fetch(url, { cache: 'no-cache' });
      if (!res.ok) throw new Error(url + ' returned ' + res.status);
      const wrapper = document.createElement('div');
      wrapper.innerHTML = await res.text();
      const injectedScripts = Array.from(wrapper.querySelectorAll('script'));
      const parent = mount.parentNode;
      while (wrapper.firstChild) parent.insertBefore(wrapper.firstChild, mount);
      parent.removeChild(mount);
      replayScripts(injectedScripts);
    } catch (err) { console.warn('[CoverCapy loader] component failed:', url, err); }
  };
  const init = async () => {
    for (const c of components) await injectComponent(c);
    for (const c of components) await loadScript(c.script);
  };
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init, { once: true });
  else init();
})();
</script>`;

/* ── Page CSS (CoverCapy v2.0 design system) ─────────────── */
const PAGE_CSS = `<style>
  /* ── CoverCapy v3.0 design tokens ── */
  :root{
    --surface-primary:#FAF8F5;
    --surface-secondary:#F4F0EA;
    --surface-dark:#0C3A42;
    --surface-dark-mid:#0a2f37;
    --dark:#1E1714;
    --dark-mid:#2E2420;
    --gold:#B8924F;
    --gold-platinum:#D4AF37;
    --body-text:#4A3F38;
    --muted:#7A6B62;
    --mid:#C4B5A8;
    --border:#EBE5DC;
    --border-gold:rgba(184,146,79,0.3);
    --shadow-card:0 1px 4px rgba(30,23,20,0.06);
    --shadow-hover:0 4px 16px rgba(30,23,20,0.12);
    --shadow-platinum:0 6px 24px rgba(30,23,20,0.16);
    --sky:#E7F1F7; --skytext:#1F5A75;
    --mint-bg:#EBF3EE; --mint-text:#3D6B4F;
  }
  *{box-sizing:border-box}
  html{scroll-behavior:smooth}
  html,body{overflow-x:clip}
  body{margin:0;background:var(--surface-primary);color:var(--body-text);
    font-family:'Inter',ui-sans-serif,system-ui,-apple-system,'Segoe UI',Roboto,Arial,sans-serif;
    font-size:16px;line-height:1.7;-webkit-font-smoothing:antialiased}
  a{color:inherit;text-decoration:none}
  p{margin:0 0 16px}
  strong{color:var(--dark);font-weight:700}
  h1,h2,h3{font-family:'Fraunces',Georgia,'Times New Roman',serif;
    line-height:1.1;margin:0;color:var(--dark)}
  h1{font-size:clamp(36px,5vw,56px);font-weight:300}
  h2{font-size:clamp(22px,3vw,36px);font-weight:400;margin-bottom:16px}
  h3{font-size:22px;font-weight:400;margin-bottom:8px}
  .wrap{max-width:1140px;margin:0 auto;padding:0 18px}
  a:focus-visible,button:focus-visible{outline:3px solid var(--gold);outline-offset:3px;border-radius:4px}
  .skip{position:absolute;left:-9999px;top:0;background:var(--dark);color:var(--surface-primary);
    padding:12px 16px;border-radius:0 0 4px 0;z-index:80;font-weight:700}
  .skip:focus{left:0}

  /* alert bar */
  .alert-bar{background:var(--surface-dark);color:var(--surface-primary);text-align:center;
    padding:10px 16px;font-size:14px;position:sticky;top:0;z-index:200;
    border-bottom:1px solid rgba(184,146,79,0.2)}
  .alert-bar a{color:var(--gold);font-weight:700;text-decoration:underline}

  /* nav / footer mounts */
  #cc-nav-mount{min-height:72px}
  #cc-footer-mount{min-height:420px}

  /* breadcrumb */
  .breadcrumb-bar{padding:14px 0;font-size:14px;color:var(--muted);
    border-bottom:1px solid var(--border)}
  .breadcrumb-list{list-style:none;margin:0;padding:0;display:flex;flex-wrap:wrap;
    align-items:center;gap:4px}
  .breadcrumb-list a{text-decoration:underline;text-underline-offset:2px;color:var(--muted)}
  .breadcrumb-list a:hover{color:var(--dark)}

  /* hero */
  .hero{padding:96px 0 64px;background:var(--surface-primary);border-bottom:1px solid var(--border)}
  .hero-overline{display:inline-block;font-size:12px;font-weight:700;letter-spacing:.08em;
    text-transform:uppercase;color:var(--muted);margin-bottom:16px}
  .hero-headline{margin-bottom:16px}
  .hero-subheadline{font-size:18px;max-width:640px;color:var(--body-text);
    margin-top:14px;line-height:1.7;margin-bottom:24px}
  .stat-pills-row{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:32px}
  .stat-pill{background:rgba(184,146,79,0.12);border:1px solid rgba(184,146,79,0.3);
    border-radius:20px;padding:6px 16px;font-size:13px;color:var(--body-text)}
  .hero-ctas{display:flex;flex-wrap:wrap;gap:12px}

  /* hero buttons */
  .btn-hero-primary,.btn-hero-secondary{display:inline-flex;align-items:center;
    justify-content:center;padding:12px 24px;border-radius:4px;font-size:15px;
    font-weight:600;letter-spacing:0.02em;text-decoration:none;cursor:pointer;
    transition:all 0.22s cubic-bezier(0.4,0,0.2,1)}
  .btn-hero-primary{background:var(--surface-dark);color:var(--gold);border:none}
  .btn-hero-primary:hover{background:var(--surface-dark-mid);box-shadow:0 2px 8px rgba(12,58,66,0.3)}
  .btn-hero-secondary{background:transparent;color:var(--dark);
    border:1px solid var(--border)}
  .btn-hero-secondary:hover{border-color:var(--border-gold);background:rgba(184,146,79,0.05)}

  /* about-prose section */
  .about-prose-section{padding:48px 0}
  .about-prose{max-width:680px;color:var(--body-text);line-height:1.7}
  .about-prose p{margin-bottom:16px}

  /* layout */
  .layout{display:grid;grid-template-columns:1fr 320px;gap:48px;align-items:start}
  .main-col{min-width:0}

  /* section heading inside main col */
  .section-head{font-family:'Fraunces',Georgia,serif;font-size:22px;font-weight:400;
    color:var(--dark);margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid var(--border)}
  .dentist-list-heading{font-family:'Fraunces',Georgia,serif;font-size:22px;font-weight:400;
    color:var(--dark);margin-bottom:18px}
  .list-meta{font-family:'Inter',sans-serif;font-size:13px;font-weight:400;color:var(--muted)}

  /* city pills */
  .city-strip{padding:48px 0;border-top:1px solid var(--border)}
  .city-strip-inline{padding:32px 0;border-top:1px solid var(--border);margin-top:32px}
  .city-pills-grid{display:flex;flex-wrap:wrap;gap:4px;margin-top:16px}
  .city-pill-link{display:inline-flex;align-items:center;gap:6px;border:1px solid var(--border);
    background:var(--surface-primary);border-radius:20px;padding:6px 14px;font-size:14px;
    font-weight:600;color:var(--dark);text-decoration:none;margin:4px;
    transition:all 0.18s ease}
  .city-pill-link:hover{border-color:rgba(184,146,79,0.3);background:rgba(184,146,79,0.05)}
  .city-pill-count{font-size:12px;color:var(--muted);font-weight:400}

  /* dentist cards */
  .dcard{background:var(--surface-primary);border:1px solid var(--border);border-radius:4px;
    box-shadow:var(--shadow-card);padding:20px;margin-bottom:12px;
    transition:transform 0.22s cubic-bezier(0.4,0,0.2,1),box-shadow 0.22s cubic-bezier(0.4,0,0.2,1),border-color 0.22s cubic-bezier(0.4,0,0.2,1)}
  .dcard:hover{transform:translateY(-2px);box-shadow:var(--shadow-hover);border-color:rgba(184,146,79,0.3)}
  .dcard:nth-child(4n){background:var(--surface-secondary);border-color:var(--mid)}
  .dcard.platinum{border:1px solid rgba(212,175,55,0.35);box-shadow:var(--shadow-platinum);
    margin-left:-8px;padding-left:28px;position:relative}
  .dcard.platinum::before{content:'';display:block;position:absolute;top:0;left:0;right:0;
    height:2px;background:linear-gradient(90deg,transparent,#D4AF37,transparent)}

  /* featured card (Hermès treatment) */
  .dcard.featured{grid-column:1 / -1;display:grid;grid-template-columns:280px 1fr;gap:24px;
    border:1px solid rgba(184,146,79,0.3);margin-bottom:12px}
  .dcard.featured::before{content:'Our recommendation for you';display:block;
    grid-column:1 / -1;font-size:13px;font-weight:600;letter-spacing:0.06em;
    text-transform:uppercase;color:var(--gold);margin-bottom:4px}
  .dcard.featured .dcard-img{width:280px;height:200px;object-fit:cover;border-radius:4px;
    background:linear-gradient(135deg,var(--surface-secondary),var(--border));
    display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:13px}

  .dcard-top{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:8px}
  .dcard-name{font-family:'Fraunces',Georgia,serif;font-size:18px;font-weight:400;
    color:var(--dark);margin-bottom:2px}
  .dcard-doc{font-size:13px;color:var(--muted);margin-bottom:6px}
  .dcard-badges{display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0}
  .dcard-meta{font-size:14px;color:var(--body-text);margin-bottom:4px}
  .dcard-meta a{color:var(--skytext);text-decoration:underline;text-underline-offset:2px}
  .rating-row{display:flex;align-items:center;gap:5px;font-size:14px;font-weight:600;color:var(--dark)}
  .star{color:#B8924F}
  .rev-count{font-weight:400;font-size:13px;color:var(--muted)}
  .dcard-nets{display:flex;flex-wrap:wrap;gap:6px;margin:10px 0}
  .dcard-body{min-width:0}
  .dcard-actions{display:flex;flex-direction:column;gap:8px;margin-top:14px}

  /* badges */
  .badge-platinum{font-size:11px;font-weight:700;letter-spacing:0.05em;text-transform:uppercase;
    color:#D4AF37;padding:3px 8px;border:1px solid rgba(212,175,55,0.35);border-radius:3px}
  .badge-accredited{font-size:11px;font-weight:700;letter-spacing:0.05em;text-transform:uppercase;
    color:var(--mint-text);background:var(--mint-bg);padding:3px 8px;border-radius:3px}
  .badge-verified{font-size:11px;font-weight:700;color:var(--skytext);
    background:var(--sky);padding:3px 8px;border-radius:3px}
  .status-pill{display:inline-flex;align-items:center;gap:4px;font-size:12px;font-weight:600;
    padding:3px 8px;border-radius:3px}
  .status-pill.verified{background:var(--mint-bg);color:var(--mint-text)}

  /* network pills */
  .net-pill{display:inline-flex;align-items:center;border:1px solid var(--border);
    background:var(--surface-secondary);border-radius:3px;padding:3px 8px;
    font-size:12px;font-weight:600;color:var(--body-text)}

  /* CTA buttons */
  .btn-verify-ppo{background:var(--surface-dark);color:var(--gold);font-size:13px;font-weight:600;
    letter-spacing:0.02em;padding:8px 16px;border-radius:4px;border:none;cursor:pointer;
    width:100%;text-align:center;display:block;text-decoration:none;
    transition:all 0.2s ease}
  .btn-verify-ppo:hover{background:var(--surface-dark-mid);box-shadow:0 2px 8px rgba(12,58,66,0.3)}
  .dcard__profile-link{color:var(--muted);font-size:13px;text-decoration:underline;
    text-underline-offset:2px;display:block;text-align:center;margin-top:4px}
  .dcard__profile-link:hover{color:var(--dark)}

  /* notice */
  .notice{background:rgba(184,146,79,0.08);border:1px solid rgba(184,146,79,0.25);
    border-radius:4px;padding:14px 18px;font-size:14px;color:var(--body-text);
    margin-bottom:24px;line-height:1.6}

  /* carrier summary + pills (city page) */
  .carrier-summary{margin:24px 0 8px}
  .carrier-summary p{font-size:15px;color:var(--body-text);margin-bottom:12px}
  .carrier-summary a{color:var(--skytext);text-decoration:underline;text-underline-offset:2px;font-weight:600}
  .carrier-pills{display:flex;flex-wrap:wrap;gap:8px}
  .carrier-pill{display:inline-flex;align-items:center;border:1px solid var(--border);
    background:var(--surface-primary);border-radius:20px;padding:6px 14px;font-size:13px;
    font-weight:600;color:var(--dark);text-decoration:none;transition:all 0.18s ease}
  .carrier-pill:hover{border-color:rgba(184,146,79,0.4);background:rgba(184,146,79,0.06)}
  .carrier-pill--plain{color:var(--body-text);cursor:default}

  /* how to verify steps (city page) */
  .verify-steps{margin:28px 0 8px}
  .verify-steps h2{margin-bottom:12px}
  .verify-steps-list{margin:0;padding-left:22px;color:var(--body-text)}
  .verify-steps-list li{margin-bottom:8px;font-size:15px;line-height:1.6}

  /* provenance note (city page) */
  .provenance-note{font-size:13px;color:var(--muted);line-height:1.6;
    margin:24px 0 8px;padding-top:16px;border-top:1px solid var(--border)}

  /* concierge CTA */
  .concierge-cta{background:var(--surface-dark);color:var(--surface-primary);
    padding:64px 0;margin:40px 0 0}
  .concierge-cta h2{color:var(--surface-primary);font-weight:300}
  .concierge-cta p{color:rgba(250,248,245,0.8);margin-bottom:8px}
  .concierge-cta .cta-benefits{list-style:none;padding:0;margin:0 0 32px;
    display:flex;flex-direction:column;gap:8px}
  .concierge-cta .cta-benefits li{font-size:15px;color:rgba(250,248,245,0.85);
    padding-left:20px;position:relative}
  .concierge-cta .cta-benefits li::before{content:'→';position:absolute;left:0;color:var(--gold)}
  .btn-concierge-primary{display:inline-flex;align-items:center;padding:12px 28px;
    background:rgba(184,146,79,0.15);color:var(--gold);border:1px solid rgba(184,146,79,0.4);
    border-radius:4px;font-size:15px;font-weight:600;text-decoration:none;
    transition:all 0.2s ease;margin-right:12px}
  .btn-concierge-primary:hover{background:rgba(184,146,79,0.25)}
  .btn-concierge-secondary{display:inline-flex;align-items:center;padding:12px 20px;
    color:rgba(250,248,245,0.7);font-size:14px;text-decoration:underline}

  /* right rail */
  .rail{display:flex;flex-direction:column;gap:16px}
  .rail-card{background:var(--surface-primary);border:1px solid var(--border);border-radius:4px;
    margin-bottom:16px;overflow:hidden}
  .rail-head{padding:12px 16px;border-bottom:1px solid var(--border);font-size:11px;
    font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
  .rail-city-row{display:flex;justify-content:space-between;align-items:center;
    padding:9px 16px;font-size:14px;border-bottom:1px solid var(--border)}
  .rail-city-row:last-child{border-bottom:none}
  .rail-city-row a{color:var(--dark);font-weight:600}
  .rail-city-row a:hover{color:var(--gold)}
  .rail-city-count{font-size:12px;color:var(--muted)}
  .plan-row{padding:13px 16px;border-bottom:1px solid var(--border);
    display:flex;justify-content:space-between;align-items:center;gap:8px}
  .plan-row:last-child{border-bottom:none}
  .plan-name{font-size:14px;font-weight:700;color:var(--dark);margin-bottom:1px}
  .plan-carrier{font-size:12px;color:var(--muted)}
  .plan-timing{font-size:11px;color:var(--skytext);font-weight:600;margin-top:2px}
  .plan-price{font-family:'Fraunces',Georgia,serif;font-size:19px;font-weight:400;
    color:var(--dark);white-space:nowrap}
  .plan-price span{font-family:'Inter',sans-serif;font-size:11px;font-weight:400;color:var(--muted)}

  /* CTA box in rail */
  .cta-box{background:var(--surface-dark);color:var(--surface-primary);padding:22px;border-radius:4px}
  .cta-box h3{font-family:'Fraunces',Georgia,serif;font-size:19px;margin-bottom:8px;
    color:var(--surface-primary);font-weight:300}
  .cta-box p{font-size:14px;color:rgba(250,248,245,.78);margin-bottom:16px;line-height:1.6}
  .cta-btn{display:block;text-align:center;background:rgba(184,146,79,0.15);color:var(--gold);
    border:1px solid rgba(184,146,79,0.4);font-weight:600;font-size:15px;padding:12px 18px;
    border-radius:4px;margin-bottom:8px;text-decoration:none;transition:all 0.2s ease}
  .cta-btn:hover{background:rgba(184,146,79,0.25)}
  .cta-btn-sec{display:block;text-align:center;background:transparent;
    color:rgba(250,248,245,.7);font-size:13px;padding:8px 18px;border-radius:4px;
    border:1px solid rgba(250,248,245,.2);text-decoration:none}
  .cta-btn-sec:hover{background:rgba(250,248,245,.08)}

  /* sticky bar */
  .sticky-bar{position:fixed;bottom:0;left:0;right:0;z-index:150;background:var(--surface-dark);
    color:var(--surface-primary);padding:12px 0;border-top:1px solid rgba(184,146,79,0.2)}
  .sticky-bar .wrap{display:flex;gap:16px;align-items:center;justify-content:space-between}
  .sticky-bar__context{display:flex;flex-direction:column;gap:2px}
  .sticky-bar__headline{font-weight:600;font-size:14px;color:var(--surface-primary)}
  .sticky-bar__sub{font-size:12px;color:rgba(250,248,245,0.6)}
  .sticky-bar__actions{display:flex;align-items:center;gap:16px;flex-shrink:0}
  .btn-sticky-primary{background:rgba(184,146,79,0.15);color:var(--gold);
    border:1px solid rgba(184,146,79,0.4);border-radius:4px;padding:8px 20px;
    font-size:14px;font-weight:600;cursor:pointer;text-decoration:none;
    transition:all 0.2s ease}
  .btn-sticky-primary:hover{background:rgba(184,146,79,0.25)}
  .btn-sticky-secondary{color:var(--mid);font-size:13px;text-decoration:underline}

  /* FAQ */
  .faq-section{padding:48px 0 80px;background:var(--surface-secondary);
    border-top:1px solid var(--border)}
  .faq{display:grid;gap:8px;margin-top:16px}
  .faq details{background:var(--surface-primary);border:1px solid var(--border);
    border-radius:4px;padding:16px;margin-bottom:0}
  .faq details[open]{border-color:rgba(184,146,79,0.3)}
  .faq summary{cursor:pointer;font-weight:600;color:var(--dark);font-size:16px;list-style:none}
  .faq summary::-webkit-details-marker{display:none}
  .faq summary::after{content:"+";float:right;color:var(--gold);font-weight:700;font-size:18px;line-height:1;transition:transform .2s} /* gold usage #1 */
  .faq details[open] summary::after{transform:rotate(45deg)}
  .faq p{margin:10px 0 0;color:var(--body-text);font-size:15px;line-height:1.7}

  /* section */
  .section{padding:48px 0;border-top:1px solid var(--border)}
  .dentist-list-section{padding-top:32px}

  /* more link */
  .more-link{text-align:center;padding:20px 0;color:var(--muted);font-size:14px}
  .more-link a{color:var(--skytext);text-decoration:underline;font-weight:600}

  @media(max-width:900px){
    .layout{grid-template-columns:1fr}
    .main-col{order:1}
    .rail{order:2}
    .sticky-bar .wrap{flex-wrap:wrap;gap:8px}
    .sticky-bar__actions{flex-wrap:wrap;gap:8px}
    .dcard.featured{grid-template-columns:1fr}
    .dcard.featured .dcard-img{width:100%;height:160px}
  }
  @media(max-width:560px){
    .hero{padding:56px 0 40px}
    .stat-pills-row{gap:6px}
    .dcard.platinum{margin-left:0;padding-left:20px}
  }
  /* ── T3 State hub styles ── */
  .state-section{margin-bottom:40px}
  .state-section-head{font-size:18px;font-weight:700;color:var(--dark);margin:0 0 16px;padding-bottom:10px;border-bottom:1px solid var(--rule)}
  .state-region-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-bottom:8px}
  .state-region-card{display:block;background:var(--ocean,#0C3A42);color:#fff;border-radius:6px;padding:20px 18px;text-decoration:none;transition:opacity .15s}
  .state-region-card:hover{opacity:.9}
  .src-label{font-size:16px;font-weight:700;margin-bottom:4px}
  .src-markets{font-size:12px;opacity:.75;margin-bottom:10px}
  .src-arrow{font-size:13px;font-weight:600;opacity:.85}
  .state-metro-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px}
  .state-metro-card{display:block;background:var(--surface2,#f4f1ed);border:1px solid var(--rule);border-radius:5px;padding:16px;text-decoration:none;transition:border-color .15s}
  .state-metro-card:hover{border-color:var(--skytext)}
  .smc-name{font-size:15px;font-weight:700;color:var(--dark);margin-bottom:3px}
  .smc-count{font-size:12px;font-weight:600;color:var(--skytext);margin-bottom:4px}
  .smc-cities{font-size:11px;color:var(--muted);line-height:1.4}
  /* ── T5 Dentist page styles ── */
  .hero--dentist .hero-headline{font-size:clamp(28px,5vw,48px)}
  .accr-badge{display:inline-block;background:var(--gold,#C9A84C);color:#fff;font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:3px 10px;border-radius:3px;margin-bottom:8px}
  .dentist-doctor-name{font-size:16px;color:var(--muted);margin:-4px 0 12px;font-style:italic}
  .dentist-section-block{margin-bottom:36px;padding-bottom:28px;border-bottom:1px solid var(--rule,#e8e4de)}
  .dentist-section-block:last-child{border-bottom:none}
  .section-heading-sm{font-size:15px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);margin:0 0 14px}
  .insurance-grid{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px}
  .insurance-badge{background:var(--surface2,#f4f1ed);border:1px solid var(--rule);border-radius:4px;padding:6px 12px;font-size:13px;font-weight:600;color:var(--dark)}
  .verify-note{font-size:12px;color:var(--muted);margin-top:10px;line-height:1.5}
  .procedure-pills{display:flex;flex-wrap:wrap;gap:6px}
  .proc-pill{background:var(--surface2,#f4f1ed);border-radius:20px;padding:5px 12px;font-size:13px;color:var(--dark)}
  .dentist-info-grid{display:flex;flex-direction:column;gap:10px}
  .info-row{display:flex;gap:16px;align-items:baseline}
  .info-label{font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--muted);min-width:72px;flex-shrink:0}
  .info-value{font-size:14px;color:var(--dark)}
  .phone-link{color:var(--skytext);text-decoration:none;font-weight:600}
  .phone-link:hover{text-decoration:underline}
  .external-link{color:var(--skytext);text-decoration:none;font-weight:600}
  .external-link:hover{text-decoration:underline}
  .dentist-about-prose{font-size:15px;color:var(--body);line-height:1.7;margin:0 0 8px}
  .directions-link{font-size:12.5px;font-weight:600;color:#14525B;text-decoration:none;white-space:nowrap;margin-left:8px}
  .directions-link:hover{text-decoration:underline}
  .nearby-dentists-section{background:var(--surface2,#f4f1ed);padding:56px 0}
  .nearby-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:20px}
  .nearby-card{display:block;background:#fff;border:1px solid var(--rule);border-radius:6px;padding:20px;text-decoration:none;transition:border-color .15s}
  .nearby-card:hover{border-color:var(--skytext)}
  .nearby-name{font-size:15px;font-weight:700;color:var(--dark);margin-bottom:4px}
  .nearby-meta{font-size:12px;color:var(--muted);margin-bottom:8px}
  .carrier-dot{display:inline-block;font-size:11px;background:var(--surface2);padding:2px 8px;border-radius:3px;margin-right:4px;color:var(--muted)}
  .section-heading{font-size:22px;font-weight:700;color:var(--dark);margin:0 0 8px}
</style>`;

/* ── GA tag ─────────────────────────────────────────────── */
const GA_TAG = `<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-XNBPGSZ1LZ"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-XNBPGSZ1LZ');
</script>`;

/* ── Page shell ───────────────────────────────────────────── */

function pageShell({ title, desc, canonical, geo, schemas, body, footerCta }) {
  const schemaBlocks = schemas
    .map(s => `<script type="application/ld+json">${JSON.stringify(s, null, 2)}</script>`)
    .join('\n  ');
  return `<!doctype html>
<html lang="en-US">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  ${GA_TAG}
  <title>${esc(title)}</title>
  <meta name="description" content="${esc(desc)}" />
  <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
  <meta name="theme-color" content="#0C3A42" />
  <link rel="canonical" href="${canonical}" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="${esc(title)}" />
  <meta property="og:description" content="${esc(desc)}" />
  <meta property="og:url" content="${canonical}" />
  <meta property="og:site_name" content="CoverCapy" />
  ${geo ? `<meta name="geo.region" content="${geo.region}" />
  <meta name="geo.placename" content="${geo.placename}" />${geo.position ? `
  <meta name="geo.position" content="${geo.position}" />
  <meta name="ICBM" content="${geo.position.replace(';', ', ')}" />` : ''}` : ''}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..700,30..100,0..1&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
  <link rel="stylesheet" href="/assets/css/mega-nav.css">
  <link rel="stylesheet" href="/assets/css/mega-nav-mobile.css">
  <link rel="stylesheet" href="/assets/css/footer.css">
  ${PAGE_CSS}
  ${schemaBlocks}
</head>
<body>
<a class="skip" href="#main-content">Skip to content</a>
<div id="cc-nav-mount"></div>
${body}
${footerCta || ''}
<div id="cc-footer-mount" aria-label="CoverCapy footer mount"></div>
${COMPONENT_LOADER}
</body>
</html>`;
}

/* ── Market hub page ──────────────────────────────────────── */

function buildMarketHub(market, cities, dentists, plans) {
  const { market_area, seo_area, state, office_count, avg_rating, total_reviews } = market;
  const abbr    = stateAbbr(state);
  const stSlug  = stateSlug(state);
  const mkSlug  = slugify(seo_area || market_area);
  const canonical = `${BASE_URL}/dental/${stSlug}/${mkSlug}/`;
  const title   = `PPO Dentists in ${market_area}, ${abbr} (${office_count}+ Offices) | CoverCapy`;
  const desc    = `Find ${office_count}+ verified PPO dentists in ${market_area}, ${state}. Compare in-network offices by city, verify your insurance, and book with confidence. Plans from $30/month if you need coverage.`;
  const today   = new Date().toISOString().slice(0,10);

  const schemas = [
    {
      '@context':'https://schema.org','@graph':[
        {
          '@type':'Organization','@id':`${BASE_URL}/#organization`,
          'name':'CoverCapy','url':BASE_URL,'logo':`${BASE_URL}/assets/img/covercapy-logo.png`,
        },
        {
          '@type':'WebSite','@id':`${BASE_URL}/#website`,'url':`${BASE_URL}/`,
          'name':'CoverCapy','publisher':{'@id':`${BASE_URL}/#organization`},
        },
        {
          '@type':'MedicalWebPage','@id':`${canonical}#webpage`,'url':canonical,
          'name':title,'description':desc,'inLanguage':'en-US',
          'datePublished':today,'dateModified':today,
          'isPartOf':{'@id':`${BASE_URL}/#website`},'breadcrumb':{'@id':`${canonical}#breadcrumb`},
          'speakable':{'@type':'SpeakableSpecification','cssSelector':['.hero-headline','.stat-pill','.about-prose p:first-child']},
        },
        {
          '@type':'Place','@id':`${BASE_URL}/dental/${stSlug}/${mkSlug}/#place`,
          'name':`${market_area}, ${state}`,'containedInPlace':{'@type':'State','name':state},
          ...(total_reviews >= 10 && dentists.length >= 3 && avg_rating ? {
            'aggregateRating':{
              '@type':'AggregateRating','ratingValue':avg_rating,
              'reviewCount':total_reviews,'bestRating':'5',
            }
          } : {}),
        },
        {
          '@type':'BreadcrumbList','@id':`${canonical}#breadcrumb`,'itemListElement':[
            {'@type':'ListItem','position':1,'name':'CoverCapy','item':`${BASE_URL}/`},
            {'@type':'ListItem','position':2,'name':`${state} Dentists`,'item':`${BASE_URL}/dental/${stSlug}/`},
            {'@type':'ListItem','position':3,'name':`${market_area} PPO Dentists`,'item':canonical},
          ]
        },
        {
          '@type':'ItemList','@id':`${canonical}#dentist-list`,'name':`PPO Dentists in ${market_area}`,
          'itemListElement': dentists.slice(0,20).map((d,i) => ({
            '@type':'ListItem','position':i+1,'item':{
              '@type':'Dentist','name':d.name,
              '@id':`${BASE_URL}/dental/${stSlug}/${mkSlug}/${slugify(d.city||'')}/${d.slug||slugify(d.name)}/`,
              ...(d.address ? {'address':d.address} : {}),
              ...(d.phone ? {'telephone':d.phone} : {}),
              ...(d.weighted_rating && parseFloat(d.weighted_rating) > 0 ? {'aggregateRating':{'@type':'AggregateRating','ratingValue':parseFloat(d.weighted_rating).toFixed(1),'reviewCount':d.google_review_count||1,'bestRating':'5'}} : {}),
            }
          }))
        },
        {
          '@type':'FAQPage','@id':`${canonical}#faq`,
          'mainEntity': marketFAQs(market_area, state, office_count).map(f => ({'@type':'Question','name':f.q,'acceptedAnswer':{'@type':'Answer','text':f.a}}))
        },
      ]
    }
  ];

  const cityPills = cities.map(c =>
    `<a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/${slugify(c.city)}" class="city-pill-link">${esc(c.city)} <span class="city-pill-count">${c.office_count}</span></a>`
  ).join('');

  const topDentists = dentists.slice(0, 20);
  const cards = topDentists.map((d, i) => dentistCard(d, stSlug, mkSlug, i === 0)).join('\n');

  const planRows = plans.slice(0, 4).map(p => `<div class="plan-row">
  <div>
    <div class="plan-name">${esc(p.name)}</div>
    <div class="plan-carrier">${esc(p.carrier)}</div>
    ${p.timing ? `<div class="plan-timing">${esc(p.timing)}</div>` : ''}
  </div>
  <div class="plan-price">$${p.monthly}<span>/mo</span></div>
</div>`).join('');

  const cityRail = cities.slice(0, 10).map(c =>
    `<div class="rail-city-row"><a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/${slugify(c.city)}">${esc(c.city)}</a><span class="rail-city-count">${c.office_count}</span></div>`
  ).join('');

  const carrierCard = carrierRailCard(dentists, office_count);

  const ratingPill = avg_rating && parseFloat(avg_rating) > 3
    ? `<span class="stat-pill">${parseFloat(avg_rating).toFixed(1)}★ avg. patient rating</span>` : '';
  const faqs = marketFAQs(market_area, state, office_count);
  const monthYear = new Date().toLocaleDateString('en-US', { month:'long', year:'numeric' });

  const body = `
<div class="alert-bar">No insurance? PPO plans from $30/month — <a href="${BASE_URL}/compare-ppo-dental-plans">compare individual PPO plans, effective dates and waiting periods</a>.</div>

<main id="main-content" data-page-type="market-hub" data-market="${esc(market_area)}">
  <!-- 1. Breadcrumb bar -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="wrap">
      <ol class="breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="${BASE_URL}/" itemprop="item"><span itemprop="name">CoverCapy</span></a>
          <meta itemprop="position" content="1" />
        </li>
        <li><span aria-hidden="true"> / </span></li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="${BASE_URL}/dental/${stSlug}/" itemprop="item"><span itemprop="name">${esc(state)} Dentists</span></a>
          <meta itemprop="position" content="2" />
        </li>
        <li><span aria-hidden="true"> / </span></li>
        <li><span>${esc(market_area)}</span></li>
      </ol>
    </div>
  </nav>

  <!-- 2. Hero -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-overline">PPO Dentist Directory · ${esc(state)}</div>
      <h1 class="hero-headline">${office_count}+ PPO Dentists in ${esc(market_area)}</h1>
      <p class="hero-subheadline about-prose">PPO-participating offices across ${esc(market_area)}, ${abbr}. Check your plan before you book.</p>
      <div class="stat-pills-row">
        <span class="stat-pill">${office_count}+ offices listed, updated ${monthYear}</span>
        <span class="stat-pill">${cities.length} cities covered</span>
        ${ratingPill}
      </div>
      <div class="hero-ctas">
        <a href="${BASE_URL}/find-my-dentist" class="btn-hero-primary">Verify my PPO — free</a>
        <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-hero-secondary">No insurance? Plans from $30/mo</a>
      </div>
    </div>
  </section>

  <!-- 3. About prose + layout -->
  <section class="about-prose-section">
    <div class="wrap">
      <div class="layout">
        <div class="main-col">
          <div class="about-prose">
            <p>${marketIntro(market_area, state, office_count, avg_rating)}</p>
          </div>

          <!-- 4. City strip -->
          <div class="city-strip-inline">
            <h2>Browse PPO Dentists by City</h2>
            <div class="city-pills-grid">${cityPills}</div>
          </div>

          <!-- 5. Dentist list -->
          <div class="dentist-list-section" id="dentist-list">
            <h2 class="dentist-list-heading">PPO Dental Offices in ${esc(market_area)} <span class="list-meta">— ${office_count} offices as of ${monthYear}</span></h2>
            ${cards}
            ${office_count > 20 ? `<div class="more-link">Showing top 20 of ${office_count} offices. <a href="${BASE_URL}/find-my-dentist?q=${encodeURIComponent(market_area)}">Browse all on the map →</a></div>` : ''}
          </div>

          <!-- 6. Concierge CTA -->
          <div class="concierge-cta">
            <div class="wrap">
              <h2>Check your plan before you book.</h2>
              <ul class="cta-benefits">
                <li>See each office's listed PPO carriers and ratings</li>
                <li>New-patient availability — confirm directly with the office</li>
                <li>Listed PPO carriers shown per office — a starting point, not a guarantee</li>
              </ul>
              <a href="${BASE_URL}/find-my-dentist" class="btn-concierge-primary">Avoid the surprise bill — verify free</a>
              <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-concierge-secondary">Plans from $30/mo</a>
            </div>
          </div>
        </div>

        <!-- Right rail -->
        <aside class="rail" aria-label="Plan and location information">
          <div class="cta-box">
            <h3>No insurance? We fix that.</h3>
            <p>PPO plans from $30/month. Next-day activation available. No waiting period for cleanings.</p>
            <a href="${BASE_URL}/compare-ppo-dental-plans" class="cta-btn">Browse PPO Plans</a>
            <a href="${BASE_URL}/find-my-dentist" class="cta-btn-sec">Find In-Network Dentist</a>
          </div>

          <div class="rail-card">
            <div class="rail-head">PPO Plans Available</div>
            ${planRows}
            <div style="padding:12px 16px"><a href="${BASE_URL}/compare-ppo-dental-plans" style="font-size:13px;color:var(--skytext);text-decoration:underline;font-weight:600">Compare all plans →</a></div>
          </div>

          ${carrierCard}

          <div class="rail-card">
            <div class="rail-head">Cities in ${esc(market_area)}</div>
            ${cityRail}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- 7. FAQ -->
  <section class="faq-section" id="faq">
    <div class="wrap">
      <h2>PPO Dentists in ${esc(market_area)} — Common Questions</h2>
      <div class="faq">
        ${faqs.map((f, i) => `<details${i === 0 ? ' open' : ''}><summary>${esc(f.q)}</summary><p>${esc(f.a)}</p></details>`).join('\n        ')}
      </div>
    </div>
  </section>

  <!-- 8. Sticky bar -->
  <div class="sticky-bar" role="region" aria-label="Coverage actions" id="sticky-cta-bar">
    <div class="wrap">
      <div class="sticky-bar__context">
        <span class="sticky-bar__headline">PPO Dentists in ${esc(market_area)}</span>
        <span class="sticky-bar__sub">${office_count}+ PPO offices listed · Confirm your plan before booking</span>
      </div>
      <div class="sticky-bar__actions">
        <a href="${BASE_URL}/find-my-dentist" class="btn-sticky-primary" id="sticky-primary-cta">Avoid the surprise bill — verify free</a>
        <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-sticky-secondary">Plans from $30/mo</a>
      </div>
    </div>
  </div>
  <script>
  (function() {
    var state = localStorage.getItem('cc_insurance_state');
    var bar = document.getElementById('sticky-cta-bar');
    var btn = document.getElementById('sticky-primary-cta');
    if (!bar || !btn) return;
    if (state === 'insured') {
      btn.textContent = "We'll call the office for you, free";
      btn.href = '${BASE_URL}/find-my-dentist';
    } else if (state === 'uninsured') {
      btn.textContent = 'Plans from $30/mo, starts this Monday';
      btn.href = '${BASE_URL}/compare-ppo-dental-plans';
    }
    var footer = document.getElementById('cc-footer-mount');
    if (footer && 'IntersectionObserver' in window) {
      new IntersectionObserver(function(entries) {
        bar.style.transform = entries[0].isIntersecting ? 'translateY(100%)' : '';
      }, { threshold: 0.1 }).observe(footer);
    }
  })();
  <\/script>
</main>`;

  const footerCta = '';

  return pageShell({ title, desc, canonical, geo: null, schemas, body, footerCta });
}

/* ── City page ───────────────────────────────────────────── */

function buildCityPage(cityData, market, allCities, plans) {
  const { city, office_count, avg_rating, total_reviews, dentists } = cityData;
  const { market_area, seo_area, state } = market;
  const abbr    = stateAbbr(state);
  const stSlug  = stateSlug(state);
  const mkSlug  = slugify(seo_area || market_area);
  const cSlug   = slugify(city);
  const canonical = `${BASE_URL}/dental/${stSlug}/${mkSlug}/${cSlug}/`;

  // SEO title/meta (template brief 2026-06-25): data-driven, no em-dash,
  // exact office count (not "8+"), short city-name variant where one exists.
  const N = office_count;
  // Prefer a shorter, higher-volume city variant in the title (e.g. "Coronado"
  // for "Coronado Island"); keep the full form in body copy.
  const titleCity = city.replace(/\s+(Island|Beach|City|Village|Heights|Springs)$/i, (m, w) =>
    (/^(Long Beach|Palm Springs|Huntington Beach|Newport Beach|Daly City|Culver City|National City|Garden City)$/i.test(city) ? m : '')
  ).trim() || city;
  const cityCarriers = cityCarrierLabels(dentists);
  let title = `PPO Dentists in ${titleCity}, ${abbr} | ${N} In-Network ${N === 1 ? 'Office' : 'Offices'}`;
  if (title.length > 60) title = `PPO Dentists in ${titleCity}, ${abbr} | ${N} In-Network`;
  if (title.length > 60) title = `PPO Dentists in ${titleCity}, ${abbr} (${N})`;

  // Meta: inject top carriers actually present so it is unique per city.
  const carrierSentence = cityCarriers.length
    ? ` Check ${cityCarriers.slice(0, 3).join(', ')} acceptance and`
    : ' Check carrier acceptance and';
  let desc = `Compare ${plural(N, 'PPO-participating dentist', 'PPO-participating dentists')} in ${city}, ${abbr}.${carrierSentence} verify your plan free before booking.`;
  if (desc.length > 155) {
    desc = `Compare ${plural(N, 'PPO-participating dentist', 'PPO-participating dentists')} in ${city}, ${abbr}. Verify your plan free before booking.`;
  }
  const today   = new Date().toISOString().slice(0,10);

  const schemas = [
    {
      '@context':'https://schema.org','@graph':[
        {
          '@type':'Organization','@id':`${BASE_URL}/#organization`,
          'name':'CoverCapy','url':BASE_URL,'logo':`${BASE_URL}/assets/img/covercapy-logo.png`,
        },
        {
          '@type':'WebSite','@id':`${BASE_URL}/#website`,'url':`${BASE_URL}/`,
          'name':'CoverCapy','publisher':{'@id':`${BASE_URL}/#organization`},
        },
        {
          '@type':'MedicalWebPage','@id':`${canonical}#webpage`,'url':canonical,
          'name':title,'description':desc,'inLanguage':'en-US',
          'datePublished':today,'dateModified':today,
          'isPartOf':{'@id':`${BASE_URL}/#website`},'breadcrumb':{'@id':`${canonical}#breadcrumb`},
          'speakable':{'@type':'SpeakableSpecification','cssSelector':['.hero-headline','.stat-pill','.about-prose p:first-child']},
        },
        {
          '@type':'BreadcrumbList','@id':`${canonical}#breadcrumb`,'itemListElement':[
            {'@type':'ListItem','position':1,'name':'CoverCapy','item':`${BASE_URL}/`},
            {'@type':'ListItem','position':2,'name':`${state} Dentists`,'item':`${BASE_URL}/dental/${stSlug}/`},
            {'@type':'ListItem','position':3,'name':`${market_area} PPO Dentists`,'item':`${BASE_URL}/dental/${stSlug}/${mkSlug}`},
            {'@type':'ListItem','position':4,'name':`${city} PPO Dentists`,'item':canonical},
          ]
        },
        {
          '@type':'ItemList','@id':`${canonical}#dentist-list`,'name':`PPO Dentists in ${city}`,
          'itemListElement': dentists.slice(0,20).map((d,i) => ({
            '@type':'ListItem','position':i+1,'item':{
              '@type':'Dentist','name':d.name,
              '@id':`${BASE_URL}/dental/${stSlug}/${mkSlug}/${cSlug}/${d.slug||slugify(d.name)}/`,
              ...(d.address ? {'address':d.address} : {}),
              ...(d.phone ? {'telephone':d.phone} : {}),
              ...(parseFloat(d.weighted_rating) > 0 && parseInt(d.google_review_count) > 0 ? {'aggregateRating':{'@type':'AggregateRating','ratingValue':parseFloat(d.weighted_rating).toFixed(1),'reviewCount':String(parseInt(d.google_review_count)),'bestRating':'5'}} : {}),
            }
          }))
        },
        {
          '@type':'FAQPage','@id':`${canonical}#faq`,
          'mainEntity': cityLocalFAQs(city, market_area, state, dentists).map(f => ({'@type':'Question','name':f.q,'acceptedAnswer':{'@type':'Answer','text':f.a}}))
        },
      ]
    },
    // Standalone ItemList — top 10 dentists by weighted_rating (Change 1)
    (() => {
      const topTen = dentists.slice().sort((a,b)=>(parseFloat(b.weighted_rating||0)-parseFloat(a.weighted_rating||0))).slice(0,10);
      return {
        '@context':'https://schema.org',
        '@type':'ItemList',
        'name':`PPO Dentists in ${city}, ${stateAbbr(state)}`,
        'description':`Top PPO dentists in ${city}, ${state} listed by CoverCapy`,
        'numberOfItems': topTen.length,
        'itemListElement': topTen.map((d,i)=>({
          '@type':'ListItem',
          'position': i+1,
          'url':`${BASE_URL}/dental/${stSlug}/${mkSlug}/${slugify(city)}/${d.slug||slugify(d.name)}/`,
          'name': d.name
        }))
      };
    })(),
    // LocalBusiness with areaServed + serviceType (Change 2)
    {
      '@context':'https://schema.org',
      '@type':'LocalBusiness',
      '@id':`${canonical}#localbusiness`,
      'name':`PPO Dentists in ${city}`,
      'url': canonical,
      'areaServed': {
        '@type':'City',
        'name': city,
        'containedInPlace': {'@type':'State','name': state}
      },
      'serviceType': 'PPO Dental Insurance Verification',
    },
  ];

  const cards = dentists.slice(0, 20).map((d, i) => dentistCard(d, stSlug, mkSlug, i === 0)).join('\n');

  const planRows = plans.slice(0, 4).map(p => `<div class="plan-row">
  <div>
    <div class="plan-name">${esc(p.name)}</div>
    <div class="plan-carrier">${esc(p.carrier)}</div>
    ${p.timing ? `<div class="plan-timing">${esc(p.timing)}</div>` : ''}
  </div>
  <div class="plan-price">$${p.monthly}<span>/mo</span></div>
</div>`).join('');

  // Nearby-city mesh: never list the current city, never ship a self-only
  // block (Coronado "1 cities" defect). 6 to 12 real neighbors when available.
  const neighborCities = allCities.filter(c => c.city && c.city !== city).slice(0, 12);
  const nearbyCities = neighborCities.slice(0, 10).map(c =>
    `<div class="rail-city-row"><a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/${slugify(c.city)}/">${esc(c.city)}</a><span class="rail-city-count">${plural(c.office_count, 'office', 'offices')}</span></div>`
  ).join('');
  // In-body reciprocal mesh — bare city name + office count anchors.
  const nearbyMesh = neighborCities.slice(0, 12).map(c =>
    `<a class="city-pill-link" href="${BASE_URL}/dental/${stSlug}/${mkSlug}/${slugify(c.city)}/">${esc(c.city)} <span class="city-pill-count">${plural(c.office_count, 'office', 'offices')}</span></a>`
  ).join('');

  const carrierCard = carrierRailCard(dentists, office_count);

  // Hero rating pill: only render real, sourced figures. Labelled as combined
  // Google data for listed offices, never presented as a single rated entity.
  const ratedOffices = dentists.filter(d => parseFloat(d.weighted_rating) > 0 && parseInt(d.google_review_count) > 0);
  const ratingPill = (avg_rating && parseFloat(avg_rating) > 0 && ratedOffices.length > 0)
    ? `<span class="stat-pill">${parseFloat(avg_rating).toFixed(1)}★ avg Google rating across ${plural(ratedOffices.length, 'listed office', 'listed offices')}</span>` : '';
  const faqs = cityLocalFAQs(city, market_area, state, dentists);
  const carrierSection = cityCarrierSection(city, dentists, stSlug, mkSlug);
  const verifySteps = cityVerifySteps(city);
  const localContext = cityLocalContext(city, market_area, state, dentists, neighborCities);
  const monthYear = new Date().toLocaleDateString('en-US', { month:'long', year:'numeric' });

  const body = `
<div class="alert-bar">Need dental insurance in ${esc(city)}? <a href="${BASE_URL}/compare-ppo-dental-plans">PPO plans from $30/month, next-day activation available.</a></div>

<main id="main-content" data-page-type="city-page" data-city="${esc(city)}" data-market="${esc(market_area)}">
  <!-- 1. Breadcrumb bar -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="wrap">
      <ol class="breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="${BASE_URL}/" itemprop="item"><span itemprop="name">CoverCapy</span></a>
          <meta itemprop="position" content="1" />
        </li>
        <li><span aria-hidden="true"> / </span></li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="${BASE_URL}/dental/${stSlug}/" itemprop="item"><span itemprop="name">${esc(state)} Dentists</span></a>
          <meta itemprop="position" content="2" />
        </li>
        <li><span aria-hidden="true"> / </span></li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/" itemprop="item"><span itemprop="name">${esc(market_area)}</span></a>
          <meta itemprop="position" content="3" />
        </li>
        <li><span aria-hidden="true"> / </span></li>
        <li><span>${esc(city)}</span></li>
      </ol>
    </div>
  </nav>

  <!-- 2. Hero -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-overline">${esc(market_area)} · ${abbr}</div>
      <h1 class="hero-headline">PPO Dentists in ${esc(city)}, ${abbr}</h1>
      <p class="hero-subheadline about-prose">PPO-participating offices in ${esc(city)}. Check your plan before you book.</p>
      <div class="stat-pills-row">
        <span class="stat-pill">${plural(office_count, 'office', 'offices')} listed, updated ${monthYear}</span>
        ${ratingPill}
        ${(total_reviews > 0 && ratedOffices.length > 0) ? `<span class="stat-pill">${total_reviews.toLocaleString()} Google reviews across listed offices</span>` : ''}
      </div>
      <div class="hero-ctas">
        <a href="${BASE_URL}/find-my-dentist" class="btn-hero-primary">Verify my PPO, free</a>
        <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-hero-secondary">No insurance? Plans from $30/mo</a>
      </div>
    </div>
  </section>

  <!-- 3. About prose + layout -->
  <section class="about-prose-section">
    <div class="wrap">
      <div class="layout">
        <div class="main-col">
          <!-- 1. Local-context paragraph (data-driven, per-city) -->
          <div class="about-prose">
            <p>${esc(localContext)}</p>
          </div>

          <!-- 2. Carrier summary + pill links into carrier hubs -->
          ${carrierSection}

          <!-- 3. How to verify your plan in {City} -->
          <div class="verify-steps">
            <h2>How to verify your plan in ${esc(city)}</h2>
            <ol class="verify-steps-list">
              ${verifySteps.map(s => `<li>${esc(s)}</li>`).join('\n              ')}
            </ol>
          </div>

          <!-- 4. Dentist list -->
          <div class="dentist-list-section" id="dentist-list">
            <h2 class="dentist-list-heading">PPO Dental Offices in ${esc(city)} <span class="list-meta">${plural(office_count, 'office', 'offices')} as of ${monthYear}</span></h2>
            <div class="notice">
              <strong>PPO verification included:</strong> Click "Verify my PPO here" on any listing to check your live benefits, including deductible remaining, annual maximum, and coverage percentages, at no cost.
            </div>
            ${cards}
            ${office_count > 20 ? `<div class="more-link">Showing top 20 of ${plural(office_count, 'office', 'offices')}. <a href="${BASE_URL}/find-my-dentist?q=${encodeURIComponent(city + ', ' + abbr)}">Browse all on the map</a></div>` : ''}
          </div>

          <!-- 5. Nearby cities mesh (reciprocal internal links) -->
          ${nearbyMesh ? `<div class="city-strip-inline">
            <h2>Nearby PPO dentists in the ${esc(market_area)} area</h2>
            <div class="city-pills-grid">${nearbyMesh}</div>
            <p style="margin-top:14px;font-size:14px"><a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/" style="color:var(--skytext);text-decoration:underline;font-weight:600">All ${esc(market_area)} PPO dentists</a> · <a href="${BASE_URL}/dental/${stSlug}/" style="color:var(--skytext);text-decoration:underline;font-weight:600">${esc(state)} dentist directory</a></p>
          </div>` : ''}

          <!-- 6. Provenance / how this list is built -->
          <p class="provenance-note">How this list is built: offices shown are recorded as PPO-participating. Names, addresses, and any ratings reflect public Google data as of ${monthYear}. Verification is free and confirmed with the office at booking. Listed networks are a starting point, not a guarantee for your specific plan tier.</p>

          <!-- 5. Concierge CTA -->
          <div class="concierge-cta">
            <div class="wrap">
              <h2>Already insured? Check your plan before you call.</h2>
              <ul class="cta-benefits">
                <li>Live eligibility: deductible, annual max, co-insurance</li>
                <li>Confirmed in-network status at your plan tier</li>
                <li>New-patient availability confirmed before you show up</li>
              </ul>
              <a href="${BASE_URL}/find-my-dentist" class="btn-concierge-primary">Verify my insurance, free</a>
              <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-concierge-secondary">Plans from $30/mo</a>
            </div>
          </div>
        </div>

        <!-- Right rail -->
        <aside class="rail" aria-label="Insurance plans and nearby cities">
          <div class="cta-box">
            <h3>Already insured?</h3>
            <p>Check your PPO benefits, including deductible, annual max, and coverage %, with the office before you call.</p>
            <a href="${BASE_URL}/find-my-dentist" class="cta-btn">Verify My Insurance</a>
          </div>

          <div class="rail-card">
            <div class="rail-head">PPO Plans Available</div>
            ${planRows}
            <div style="padding:12px 16px"><a href="${BASE_URL}/compare-ppo-dental-plans" style="font-size:13px;color:var(--skytext);text-decoration:underline;font-weight:600">Compare all plans</a></div>
          </div>

          ${carrierCard}

          ${nearbyCities ? `<div class="rail-card">
            <div class="rail-head">Nearby Cities in ${esc(market_area)}</div>
            ${nearbyCities}
            <div style="padding:10px 16px"><a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/" style="font-size:13px;color:var(--skytext);text-decoration:underline;font-weight:600">All ${esc(market_area)} offices</a></div>
          </div>` : ''}
        </aside>
      </div>
    </div>
  </section>

  <!-- 6. FAQ -->
  <section class="faq-section" id="faq">
    <div class="wrap">
      <h2>PPO Dentists in ${esc(city)}: Common Questions</h2>
      <div class="faq">
        ${faqs.map((f, i) => `<details${i === 0 ? ' open' : ''}><summary>${esc(f.q)}</summary><p>${esc(f.a)}</p></details>`).join('\n        ')}
      </div>
    </div>
  </section>

  <!-- 7. Sticky bar -->
  <div class="sticky-bar" role="region" aria-label="Coverage actions" id="sticky-cta-bar">
    <div class="wrap">
      <div class="sticky-bar__context">
        <span class="sticky-bar__headline">PPO Dentists in ${esc(city)}</span>
        <span class="sticky-bar__sub">${plural(office_count, 'PPO office', 'PPO offices')} listed · Confirm your plan before booking</span>
      </div>
      <div class="sticky-bar__actions">
        <a href="${BASE_URL}/find-my-dentist" class="btn-sticky-primary" id="sticky-primary-cta">Avoid the surprise bill, verify free</a>
        <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-sticky-secondary">Plans from $30/mo</a>
      </div>
    </div>
  </div>
  <script>
  (function() {
    var state = localStorage.getItem('cc_insurance_state');
    var bar = document.getElementById('sticky-cta-bar');
    var btn = document.getElementById('sticky-primary-cta');
    if (!bar || !btn) return;
    if (state === 'insured') {
      btn.textContent = "We'll call the office for you, free";
      btn.href = '${BASE_URL}/find-my-dentist';
    } else if (state === 'uninsured') {
      btn.textContent = 'Plans from $30/mo, starts this Monday';
      btn.href = '${BASE_URL}/compare-ppo-dental-plans';
    }
    var footer = document.getElementById('cc-footer-mount');
    if (footer && 'IntersectionObserver' in window) {
      new IntersectionObserver(function(entries) {
        bar.style.transform = entries[0].isIntersecting ? 'translateY(100%)' : '';
      }, { threshold: 0.1 }).observe(footer);
    }
  })();
  <\/script>
</main>`;

  const footerCta = '';

  return pageShell({ title, desc, canonical, geo: { region:`US-${stateAbbr(state)}`, placename:`${city}, ${state}` }, schemas, body, footerCta });
}

/* ── Individual dentist page (T5) ────────────────────────── */

function carrierSlug(name) {
  const map = {
    'delta dental': 'delta-dental',
    'unitedhealth': 'unitedhealth',
    'unitedhealthcare': 'unitedhealth',
    'aetna': 'aetna',
    'ameritas': 'ameritas',
    'guardian': 'guardian',
    'mutual of omaha': 'mutual-of-omaha',
    'humana': 'humana',
    'metlife': 'metlife',
    'cigna': 'cigna',
    'anthem': 'anthem',
  };
  const k = name.toLowerCase().replace(/[^a-z0-9 ]/g,'').trim();
  return map[k] || k.replace(/\s+/g,'-');
}

function dentistInsuranceGrid(networks) {
  if (!networks || !networks.length) return '';
  // Map raw network strings to display labels
  const CARRIER_MAP = {
    'delta dental': 'Delta Dental', 'delta': 'Delta Dental',
    'united': 'UnitedHealthCare', 'uhc': 'UnitedHealthCare', 'unitedhealthcare': 'UnitedHealthCare',
    'guardian': 'Guardian', 'aetna': 'Aetna', 'cigna': 'Cigna',
    'metlife': 'MetLife', 'humana': 'Humana', 'anthem': 'Anthem',
    'bluecross': 'Blue Cross', 'blue cross': 'Blue Cross',
    'ameritas': 'Ameritas', 'principal': 'Principal',
    'lincoln': 'Lincoln Financial', 'mutual of omaha': 'Mutual of Omaha',
  };
  const display = networks.slice(0, 12).map(n => {
    const key = n.toLowerCase();
    for (const [k, v] of Object.entries(CARRIER_MAP)) {
      if (key.includes(k)) return v;
    }
    return n.length > 30 ? n.substring(0, 28) + '…' : n;
  });
  return `<div class="insurance-grid">
    ${display.map(n => `<a href="/compare-ppo-dental-plans?carrier=${carrierSlug(n)}" class="insurance-badge" style="text-decoration:none">${esc(n)}</a>`).join('')}
  </div>`;
}

function dentistProcedurePills(procedures) {
  if (!procedures || !procedures.length) return '';
  const TOP_PROCS = [
    'General Dentistry','Cosmetic Dentistry','Orthodontics','Implants',
    'Teeth Whitening','Invisalign','Veneers','Root Canal','Crowns',
    'Pediatric Dentistry','Periodontics','Oral Surgery','Emergency Dentistry',
    'Sedation Dentistry','Same-Day Crowns','Digital X-Rays',
  ];
  // Filter to known top procedures + include unlisted ones (up to 16 total)
  const shown = procedures.filter(p => p && p.length < 40).slice(0, 16);
  if (!shown.length) return '';
  return `<div class="procedure-pills">
    ${shown.map(p => `<span class="proc-pill">${esc(p)}</span>`).join('')}
  </div>`;
}

function dentistPageFAQs(d, market_area, city) {
  const name = d.name || 'This dental office';
  const carriers = (d.insurance_networks || []).slice(0, 3).join(', ') || 'major PPO networks';
  return [
    {
      q: `Does ${name} accept PPO dental insurance?`,
      a: `Yes — ${name} is listed as accepting ${carriers}${(d.insurance_networks||[]).length > 3 ? ` and ${(d.insurance_networks||[]).length - 3} other networks` : ''}. Carrier listings are a starting point, not a guarantee for your plan. Confirm with the office before your appointment.`,
    },
    {
      q: `Is ${name} accepting new patients?`,
      a: `${name} is listed as an active practice in ${city}, ${market_area}. Contact the office to confirm new-patient availability for your specific carrier and treatment need.`,
    },
    {
      q: `How do I find out what my insurance covers at ${name}?`,
      a: `Check your benefits with your insurer or the office before you book — your deductible remaining, annual maximum, and coverage percentages. A carrier listing here is a starting point, not a guarantee.`,
    },
    {
      q: `What are the best PPO dentists near ${name} in ${city}?`,
      a: `CoverCapy lists multiple PPO-participating offices in ${city} and the greater ${market_area} area. Use the map above or browse the nearby offices section below to compare in-network dentists by carrier, rating, and location.`,
    },
    ...(d.insurance_networks && d.insurance_networks.length >= 1 ? [{
      q: `Does ${name} accept ${d.insurance_networks[0]}?`,
      a: `Yes — ${name} is listed as participating with ${d.insurance_networks[0]}. Confirm your specific plan tier and benefit details with the office before your appointment.`,
    }] : []),
    ...(d.insurance_networks && d.insurance_networks.length >= 2 ? [{
      q: `Does ${name} accept ${d.insurance_networks[1]}?`,
      a: `${name} in ${city} is listed as accepting ${d.insurance_networks[1]}. To confirm your exact coverage — including deductible remaining and annual maximum — confirm with the office before scheduling.`,
    }] : []),
    ...(d.insurance_networks && d.insurance_networks.length >= 3 ? [{
      q: `Does ${name} accept ${d.insurance_networks[2]}?`,
      a: `${name} participates in ${d.insurance_networks[2]} and several other PPO networks. Confirm your specific plan tier with the office to avoid billing surprises.`,
    }] : []),
    ...(d.phone ? [{
      q: `What is ${name}'s phone number?`,
      a: `You can reach ${name} at ${d.phone}. Confirm your insurance coverage with the office when you call.`,
    }] : []),
    ...(d.address ? [{
      q: `Where is ${name} located?`,
      a: `${name} is located at ${d.address} in ${city}, ${(d.state || market_area)}. Confirm your insurance with the office before visiting.`,
    }] : []),
  ];
}

function carrierHubLink(carrierName) {
  const map = {
    'delta dental': '/dental-insurance/ppo-plans/delta-dental/',
    'delta dental ppo': '/dental-insurance/ppo-plans/delta-dental/',
    'delta dental premier': '/dental-insurance/ppo-plans/delta-dental/',
    'united healthcare': '/dental-insurance/ppo-plans/unitedhealth/',
    'unitedhealthcare': '/dental-insurance/ppo-plans/unitedhealth/',
    'uhc': '/dental-insurance/ppo-plans/unitedhealth/',
    'aetna': '/dental-insurance/ppo-plans/aetna/',
    'guardian': '/dental-insurance/ppo-plans/guardian/',
    'humana': '/dental-insurance/ppo-plans/humana/',
    'ameritas': '/dental-insurance/ppo-plans/ameritas/',
    'metlife': '/dental-insurance/ppo-plans/metlife/',
    'cigna': '/dental-insurance/ppo-plans/cigna/',
    'mutual of omaha': '/dental-insurance/ppo-plans/mutual-of-omaha/',
    'truassure': '/dental-insurance/ppo-plans/mutual-of-omaha/',
  };
  const key = (carrierName || '').toLowerCase().trim();
  for (const [k, v] of Object.entries(map)) {
    if (key.includes(k)) return v;
  }
  return null;
}

function buildDentistPage(d, market, cityDentists, plans, marketCities) {
  const { market_area, seo_area, state } = market;
  const abbr    = stateAbbr(state);
  const stSlug  = stateSlug(state);
  const mkSlug  = slugify(seo_area || market_area);
  const city    = d.city || '';
  const cSlug   = slugify(city);
  const dSlug   = d.slug || slugify(d.name || 'dentist');
  const canonical = `${BASE_URL}/dental/${stSlug}/${mkSlug}/${cSlug}/${dSlug}/`;

  const name     = d.name || 'Dental Office';
  // Rating: prefer google_rating, fall back to weighted_rating
  const ratingRaw = parseFloat(d.google_rating) > 0 ? parseFloat(d.google_rating)
                  : parseFloat(d.weighted_rating) > 0 ? parseFloat(d.weighted_rating) : 0;
  const rating   = ratingRaw > 0 ? ratingRaw.toFixed(1) : null;
  const reviews  = parseInt(d.google_review_count) || 0;
  const networks = (d.insurance_networks || []).filter(n =>
    !n.toLowerCase().includes('pending') && !n.toLowerCase().includes('verify before') &&
    !n.toLowerCase().includes('ppo friendly')
  );
  const procs    = d.procedures || [];
  const buildDate = new Date();
  const today    = buildDate.toISOString().slice(0,10);
  const monthYear = buildDate.toLocaleDateString('en-US', { month:'long', year:'numeric' });
  const lastChecked = buildDate.toLocaleDateString('en-US', { month:'long', day:'numeric', year:'numeric' });

  // Accreditation from accreditation_status column directly
  const accreditationStatus = d.accreditation_status || null; // e.g. "Platinum Elite", "Capy Accredited", null
  const isClaimed   = !!d.is_claimed;
  const bookingUrl  = d.booking_url || null;
  const officeEmail = d.email || '';
  const telDigits   = (d.phone || '').replace(/\D/g, '');
  const e164        = telDigits ? `+1-${telDigits.replace(/(\d{3})(\d{3})(\d{4})/, '$1-$2-$3')}` : '';

  const rTier    = (ratingRaw >= 4.7 && reviews >= 15) ? 'Top-Rated '
                 : (ratingRaw >= 4.5 && reviews >= 10) ? 'Highly Rated '
                 : '';
  const title    = `${name} | ${rTier}PPO Dentist in ${city}, ${abbr} | CoverCapy`;
  const carrierStr = networks.length >= 2
    ? networks.slice(0,3).join(', ') + (networks.length > 3 ? ` and ${networks.length - 3} more` : '')
    : (networks[0] || 'major PPO insurance');
  const ratingSentence = (rating && reviews > 0) ? ` Rated ${rating}\u2605 from ${reviews.toLocaleString()} reviews.` : '';
  const desc  = `${name} is an in-network PPO dentist in ${city}, ${state}, accepting ${carrierStr}.${ratingSentence} See services, hours, and verify your PPO coverage free with CoverCapy.`;

  const faqs = dentistPageFAQs(d, market_area, city);

  const schemas = [{
    '@context':'https://schema.org',
    '@graph':[
      {
        '@type':['Dentist','LocalBusiness','MedicalOrganization'],
        '@id':`${canonical}#dentist`,
        'name': name,
        'url': d.website ? d.website.split('?')[0] : canonical,
        'medicalSpecialty': 'Dentistry',
        ...(d.address ? { 'address': { '@type':'PostalAddress', 'streetAddress': (d.address||'').split(',')[0], 'addressLocality': city, 'addressRegion': abbr, 'addressCountry': 'US' } } : {}),
        ...(e164 ? { 'telephone': e164 } : {}),
        ...(d.latitude && d.longitude ? { 'geo':{'@type':'GeoCoordinates','latitude':d.latitude,'longitude':d.longitude} } : {}),
        ...(rating && reviews > 0 ? {
          'aggregateRating':{'@type':'AggregateRating','ratingValue':rating,'reviewCount':String(reviews),'bestRating':'5'}
        } : {}),
        ...(procs.length ? { 'availableService': procs.slice(0,8).map(p => ({'@type':'MedicalProcedure','name':p})) } : {}),
        'areaServed': [city, ...((Array.isArray(marketCities) ? marketCities : []).filter(c => c && slugify(c) !== cSlug).slice(0,5))].filter(Boolean).map(n => ({'@type':'City','name':n})),
        'sameAs': [
          ...(d.website ? [d.website.split('?')[0]] : []),
          ...(d.latitude && d.longitude ? [`https://www.google.com/maps/search/?api=1&query=${d.latitude},${d.longitude}`] : []),
        ].filter(Boolean),
      },
      {
        '@type':'BreadcrumbList','@id':`${canonical}#breadcrumb`,
        'itemListElement':[
          {'@type':'ListItem','position':1,'name':'CoverCapy','item':`${BASE_URL}/`},
          {'@type':'ListItem','position':2,'name':`${state} Dentists`,'item':`${BASE_URL}/dental/${stSlug}/`},
          {'@type':'ListItem','position':3,'name':market_area,'item':`${BASE_URL}/dental/${stSlug}/${mkSlug}/`},
          {'@type':'ListItem','position':4,'name':city,'item':`${BASE_URL}/dental/${stSlug}/${mkSlug}/${cSlug}/`},
          {'@type':'ListItem','position':5,'name':name,'item':canonical},
        ]
      },
      {
        '@type':'FAQPage','@id':`${canonical}#faq`,
        'mainEntity': faqs.map(f => ({'@type':'Question','name':f.q,'acceptedAnswer':{'@type':'Answer','text':f.a}}))
      },
      {
        '@type':'WebPage','@id':`${canonical}#webpage`,'url':canonical,
        'name':title,'description':desc,'inLanguage':'en-US',
        'datePublished':today,'dateModified':today,
        'isPartOf':{'@id':`${BASE_URL}/#website`},
        'about':{'@id':`${canonical}#dentist`},
        'breadcrumb':{'@id':`${canonical}#breadcrumb`},
      },
    ]
  }];

  // v7 body helpers
  const doctorName    = d.doctor_name || '';
  const websiteClean  = d.website ? d.website.split('?')[0] : '';
  const phoneRaw      = d.phone || '';
  const phoneDigits   = phoneRaw.replace(/\D/g,'');
  const phoneTel      = phoneDigits ? 'tel:+1'+phoneDigits : '#';
  const mapsAddrQ     = d.address ? encodeURIComponent(d.address) : '';
  const mapsLatLon    = (d.latitude && d.longitude) ? `${d.latitude},${d.longitude}` : '';
  const mapsEmbed     = d.address
    ? 'https://www.google.com/maps?q='+mapsAddrQ+'&hl=en&z=15&output=embed'
    : '';
  const mapsDir       = mapsLatLon
    ? 'https://www.google.com/maps/dir/?api=1&destination='+mapsLatLon
    : d.address ? 'https://www.google.com/maps/search/?api=1&query='+mapsAddrQ : '#';
  const monogram      = (doctorName || name).split(' ').filter(Boolean).map(w=>w[0]).join('').slice(0,2).toUpperCase() || name.slice(0,2).toUpperCase();
  const ratingStars   = rating ? '★'.repeat(Math.min(5, Math.round(parseFloat(rating)))) : '';
  const accrJS        = accreditationStatus ? JSON.stringify(accreditationStatus) : 'null';
  const listedCarriersJS = JSON.stringify(networks);
  const servicesJS    = JSON.stringify(procs.filter(Boolean).slice(0,14));
  const guidesJS      = JSON.stringify([
    ['How to verify PPO coverage before booking','/learn/verify-ppo-coverage'],
    ['What a dental annual maximum means','/learn/annual-maximum'],
    ['How waiting periods affect crowns and implants','/learn/waiting-periods'],
    ['PPO versus cash pricing','/learn/ppo-vs-cash'],
    ['Dental financing without interest','/learn/financing'],
    ['Using two calendar-year maximums','/learn/benefit-maxing']
  ]);

  const body = `
<style>
:root{--teal-950:#0C3A42;--teal-800:#0A2F36;--teal-650:#9A7440;--mint-500:#B8924F;--mint-100:rgba(184,146,79,.12);--cream-50:#FAF8F5;--cream-100:#F4F0EA;--cream-200:#ECE4DA;--ink-950:#1E1714;--ink-700:#4A403A;--ink-500:#7A6B62;--gold-500:#B8924F;--gold-bg:rgba(184,146,79,.12);--border:#E7E0D7;--star:#F2A93B;--coral-500:#E7655A;--coral-bg:#FCEDEB;--coral-ink:#B23A30;--content-max:1180px;--rail-w:340px;--rad-card:16px;--rad-btn:11px;--nav-h:52px}
[data-theme="jade"]{--teal-950:#12161B;--teal-800:#1C2228;--teal-650:#0C8C81;--mint-500:#0FB5A6;--mint-100:#E6F7F4;--cream-50:#FFFFFF;--cream-100:#F5F7F8;--cream-200:#E9EEF0;--ink-950:#161A1F;--ink-700:#3A434D;--ink-500:#5A636E;--gold-500:#B8924F;--gold-bg:rgba(184,146,79,.12);--border:rgba(18,22,27,.12);--star:#F5A623;--coral-500:#C4573B;--coral-bg:#FBEEEA;--coral-ink:#9E3F28}
html.theme-switching,html.theme-switching *{transition:background-color .5s,color .5s,border-color .5s,fill .5s,stroke .5s!important}
*{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}html,body{overflow-x:clip}
body{background:var(--cream-50);color:var(--ink-700);font-family:'Inter Tight',ui-sans-serif,system-ui,sans-serif;font-size:16px;line-height:1.62;-webkit-font-smoothing:antialiased;padding-bottom:72px}
a{color:var(--teal-650);text-decoration:none}a:hover{text-decoration:underline}
h1,h2,h3{font-family:'Fraunces',Georgia,serif;line-height:1.16;color:var(--ink-950);font-weight:500}
h1{font-size:clamp(28px,4vw,42px);letter-spacing:-.01em}h2{font-size:clamp(20px,2.4vw,26px)}h3{font-size:17px}
.wrap{max-width:var(--content-max);margin:0 auto;padding:0 24px}:focus-visible{outline:2.5px solid var(--teal-650);outline-offset:2px;border-radius:4px}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;font:600 14px/1 'Inter Tight';cursor:pointer;border:none;border-radius:var(--rad-btn);padding:12px 20px;min-height:46px;transition:.16s;text-decoration:none}.btn svg{width:16px;height:16px;flex-shrink:0}
.btn-primary{background:var(--teal-950);color:var(--mint-500)}.btn-primary:hover{background:var(--teal-800)}
.btn-secondary{background:var(--cream-50);color:var(--ink-950);border:1.5px solid var(--border)}.btn-secondary:hover{border-color:var(--gold-500)}
.btn-ghost{background:transparent;color:var(--ink-700);border:1.5px solid var(--border)}.btn-ghost:hover{border-color:var(--teal-650);color:var(--teal-950)}
.ts-wrap{flex-shrink:0}
.theme-switch{background:#1a1a1a;border:1.5px solid rgba(255,255,255,.08);border-radius:999px;padding:4px;height:38px;display:inline-flex;align-items:center;position:relative;cursor:pointer;user-select:none;flex-shrink:0;box-shadow:0 2px 12px rgba(0,0,0,.32),inset 0 1px 0 rgba(255,255,255,.06)}
.ts-thumb{position:absolute;top:3px;left:3px;width:calc(50% - 5px);height:calc(100% - 6px);border-radius:999px;background:#B8924F;transition:transform 1.8s cubic-bezier(.34,1.18,.64,1),background .7s ease;box-shadow:0 3px 10px rgba(184,146,79,.55),0 1px 3px rgba(0,0,0,.3),inset 0 1px 0 rgba(255,255,255,.22)}
[data-theme="jade"] .ts-thumb{background:#0FB5A6;box-shadow:0 3px 10px rgba(15,181,166,.5),0 1px 3px rgba(0,0,0,.3),inset 0 1px 0 rgba(255,255,255,.22)}
.theme-switch[data-active="jade"] .ts-thumb{transform:translateX(calc(100% + 2px))}
.ts-opt{position:relative;z-index:1;padding:4px 14px;font:700 11px/1 'Inter Tight';letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.35);display:flex;align-items:center;gap:5px;transition:color .4s}
.theme-switch[data-active="gold"] .ts-gold{color:#fff}
.theme-switch[data-active="jade"] .ts-jade{color:#fff}
.ts-dot{width:6px;height:6px;border-radius:50%;background:currentColor;opacity:.6}
.flipping .ts-thumb{animation:ts-pulse 1.8s ease}
@keyframes ts-pulse{0%{opacity:1}50%{opacity:.6}100%{opacity:1}}
.crumb{font-size:12.5px;color:var(--ink-500);background:var(--cream-100);border-bottom:1px solid var(--border);padding:11px 0}
.crumb .wrap{display:flex;flex-wrap:wrap;gap:5px;align-items:center}.crumb a{color:var(--ink-500)}.crumb a:hover{color:var(--teal-650)}.crumb .sep{opacity:.45}.crumb b{color:var(--ink-950);font-weight:500}
.section-nav{position:sticky;top:0;z-index:150;background:var(--cream-50);border-bottom:1px solid var(--border)}
.sn-inner{display:flex;align-items:center;gap:16px;max-width:var(--content-max);margin:0 auto;padding:0 18px;height:var(--nav-h)}
.sn-brand{display:flex;align-items:center;gap:8px;flex-shrink:0;color:var(--ink-950);font-family:'Fraunces',serif;font-size:16px;font-weight:600;text-decoration:none}.sn-brand:hover{text-decoration:none}
.sn-mk{width:24px;height:24px;border-radius:7px;background:var(--teal-950);display:grid;place-items:center;flex-shrink:0}
.sn-links{list-style:none;display:flex;gap:2px;overflow-x:auto;flex:1;min-width:0;height:100%;align-items:center;scrollbar-width:none}.sn-links::-webkit-scrollbar{display:none}
.sn-links a{display:flex;align-items:center;height:100%;white-space:nowrap;padding:0 12px;font:600 13px/1 'Inter Tight';color:var(--ink-500);border-bottom:2px solid transparent}
.sn-links a:hover{color:var(--ink-950);text-decoration:none}.sn-links a.active{color:var(--ink-950);border-bottom-color:var(--mint-500)}
@media(max-width:600px){.sn-txt{display:none}}
.layout{display:grid;grid-template-columns:minmax(0,1fr) var(--rail-w);gap:44px;align-items:start;padding:30px 0 64px}.main-col{min-width:0}
.module{border-top:1px solid var(--border);padding:30px 0;scroll-margin-top:66px}.module:first-child{border-top:none;padding-top:6px}
.eyebrow{display:block;font:600 11px/1 'Inter Tight';letter-spacing:.11em;text-transform:uppercase;color:var(--gold-500);margin-bottom:8px}
.module h2{margin-bottom:8px}.sec-p{font-size:14.5px;color:var(--ink-500);max-width:580px;margin-bottom:16px}
.hero-top{display:flex;gap:18px;align-items:flex-start}
.headshot{flex-shrink:0;width:84px;height:84px;border-radius:50%;border:1px solid var(--border);background:var(--cream-100);display:grid;place-items:center;overflow:hidden;text-decoration:none;position:relative}
.headshot .mono{font-family:'Fraunces',serif;font-size:30px;color:var(--gold-500)}
.hero-name{display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:6px}
.accr-badge{display:inline-flex;align-items:center;gap:5px;background:var(--gold-bg);color:var(--gold-500);border:1px solid rgba(184,146,79,.34);font:600 10.5px/1 'Inter Tight';letter-spacing:.04em;text-transform:uppercase;padding:5px 10px;border-radius:999px}
.unclaimed-chip{display:inline-flex;align-items:center;gap:5px;background:var(--cream-200);color:var(--ink-500);font:600 10.5px/1 'Inter Tight';letter-spacing:.04em;text-transform:uppercase;padding:5px 10px;border-radius:999px}
.hero-doctor{font-size:14.5px;color:var(--ink-500);margin-top:2px}
.hero-meta{display:flex;flex-wrap:wrap;align-items:center;gap:9px 16px;font-size:14px;color:var(--ink-700);margin:12px 0 14px}
.rating{display:inline-flex;align-items:center;gap:6px}.stars{color:var(--star);letter-spacing:-1px}.rating b{color:var(--ink-950)}.rating .src{font-size:12px;color:var(--ink-500)}
.open-pill{display:inline-flex;align-items:center;gap:6px;font:600 12.5px/1 'Inter Tight';padding:5px 11px;border-radius:999px}
.open-pill.open{background:#E8F5EC;color:#2C7A52}.open-pill.closed{background:var(--cream-200);color:var(--ink-700)}
.open-dot{width:7px;height:7px;border-radius:50%}.open-pill.open .open-dot{background:#2C7A52}.open-pill.closed .open-dot{background:var(--ink-500)}
.hero-lede{font-size:15px;color:var(--ink-500);line-height:1.7;max-width:580px;margin-bottom:18px}
.hero-ctas{display:flex;gap:10px;flex-wrap:wrap}
.hero-claim-link{display:none;margin-top:14px;font-size:12.5px;color:var(--ink-500)}.hero-claim-link a{color:var(--teal-650);font-weight:600;text-decoration:underline}
.data-checked{font-size:11.5px;color:var(--ink-500);margin-top:14px;display:flex;align-items:center;gap:6px;line-height:1.5}.data-checked svg{width:13px;height:13px;color:var(--teal-650);flex-shrink:0}
.ins-intro{background:var(--mint-100);border:1px solid var(--border);border-radius:var(--rad-card);padding:16px 20px;margin-bottom:16px}
.ins-intro h3{color:var(--ink-950);margin-bottom:5px}.ins-intro p{font-size:13.5px;color:var(--ink-700)}
.carrier-rows{display:flex;flex-direction:column;gap:8px}.carrier-row{display:flex;align-items:center;justify-content:space-between;gap:12px;background:var(--cream-50);border:1px solid var(--border);border-radius:12px;padding:13px 16px}.carrier-row.hidden{display:none}
.carrier-name{font:600 14.5px/1.2 'Inter Tight';color:var(--ink-950)}.carrier-status{display:inline-flex;align-items:center;gap:6px;font-size:11.5px;color:var(--ink-500);margin-top:3px}.status-dot{width:7px;height:7px;border-radius:50%;background:var(--gold-500)}
.carrier-check{font:600 12.5px/1 'Inter Tight';color:var(--teal-650);background:none;border:none;cursor:pointer;text-decoration:underline;text-underline-offset:2px;white-space:nowrap}
.ins-toggle{margin-top:12px;background:none;border:1.5px solid var(--border);border-radius:11px;width:100%;padding:11px;font:600 13px/1 'Inter Tight';color:var(--teal-650);cursor:pointer;min-height:44px}.ins-toggle:hover{border-color:var(--teal-650)}
.ins-actions{display:flex;flex-wrap:wrap;gap:9px;margin-top:14px}
.ins-disclaimer{font-size:12.5px;color:var(--ink-500);line-height:1.6;margin-top:14px;background:var(--cream-100);border-left:3px solid var(--gold-500);padding:11px 15px;border-radius:0 8px 8px 0}
.pillrow{display:flex;flex-wrap:wrap;gap:8px;list-style:none}.pill{background:var(--cream-50);border:1px solid var(--border);border-radius:999px;padding:8px 16px;font-size:13.5px;color:var(--ink-950)}
.bookwidget{border:1px solid var(--border);border-radius:var(--rad-card);overflow:hidden;background:var(--cream-50);max-width:560px;margin-top:14px}
.bw-head{background:var(--teal-950);color:#fff;padding:14px 18px;display:flex;align-items:center;justify-content:space-between}.bw-head .t{font-family:'Fraunces',serif;font-size:16px}
.bw-badge{font:600 10px/1 'Inter Tight';letter-spacing:.06em;text-transform:uppercase;background:rgba(255,255,255,.14);color:#fff;padding:4px 9px;border-radius:999px}
.bw-body{padding:16px 18px}.bw-row-label{font:600 10px/1 'Inter Tight';letter-spacing:.07em;text-transform:uppercase;color:var(--ink-500);margin:0 0 8px}
.bw-chips{display:flex;gap:7px;overflow-x:auto;margin-bottom:14px;scrollbar-width:none}.bw-chips::-webkit-scrollbar{display:none}
.bw-chip{flex-shrink:0;border:1.5px solid var(--border);background:var(--cream-50);border-radius:999px;padding:7px 13px;font:600 12.5px/1 'Inter Tight';color:var(--ink-700);cursor:pointer}.bw-chip[aria-pressed="true"]{border-color:var(--teal-650);background:var(--mint-100);color:var(--ink-950)}
.bw-dates{display:flex;gap:7px;overflow-x:auto;margin-bottom:14px;scrollbar-width:none}.bw-dates::-webkit-scrollbar{display:none}
.bw-date{flex-shrink:0;width:52px;border:1.5px solid var(--border);background:var(--cream-50);border-radius:10px;padding:8px 0;text-align:center;cursor:pointer}.bw-date .dow{font:600 10px/1 'Inter Tight';color:var(--ink-500);text-transform:uppercase}.bw-date .dn{font-family:'Fraunces',serif;font-size:17px;color:var(--ink-950);margin-top:3px}.bw-date[aria-pressed="true"]{border-color:var(--teal-650);background:var(--mint-100)}
.bw-slots{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-bottom:14px}@media(max-width:560px){.bw-slots{grid-template-columns:repeat(3,1fr)}}
.bw-slot{border:1.5px solid var(--border);background:var(--cream-50);border-radius:9px;padding:9px 0;font:600 12.5px/1 'Inter Tight';color:var(--ink-950);cursor:pointer;text-align:center}.bw-slot[aria-pressed="true"]{border-color:var(--teal-650);background:var(--mint-100)}
.bw-cta{display:flex;flex-direction:column;gap:8px}.bw-foot{font-size:11px;color:var(--ink-500);line-height:1.5;margin-top:11px}
.bw-claim{display:none;margin-top:12px;padding-top:12px;border-top:1px solid var(--cream-200);font-size:12.5px;color:var(--ink-700);line-height:1.5}.bw-claim a{color:var(--gold-500);font-weight:700}
.hours-loc{display:grid;grid-template-columns:1fr 1fr;gap:24px}.hours-table{display:flex;flex-direction:column}
.hours-row{display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--cream-200);font-size:13.5px}.hours-row:last-child{border-bottom:none}.hours-row.today{font-weight:600;color:var(--ink-950)}.hours-row.today .h-day::after{content:' · Today';color:var(--teal-650)}.h-closed{color:var(--ink-500)}
.hours-disclaimer{font-size:11.5px;color:var(--ink-500);font-style:italic;line-height:1.5;margin-top:10px;padding-top:10px;border-top:1px dashed var(--border)}
.map-tile{border-radius:14px;overflow:hidden;border:1px solid var(--border);margin-bottom:10px}.map-tile iframe{display:block;width:100%;height:230px;border:none}
.loc-actions{display:flex;flex-direction:column;gap:8px}
.proto-flag{display:inline-flex;align-items:center;gap:6px;background:var(--coral-bg);color:var(--coral-ink);font:600 11px/1 'Inter Tight';padding:6px 11px;border-radius:999px;margin-bottom:14px}
.planning-box{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:10px;margin-top:14px}
.planning-link{display:flex;align-items:center;gap:10px;background:var(--cream-50);border:1px solid var(--border);border-radius:12px;padding:14px;font:600 13px/1.3 'Inter Tight';color:var(--ink-950);cursor:pointer;text-align:left}.planning-link:hover{border-color:var(--teal-650);text-decoration:none}.planning-link svg{width:18px;height:18px;color:var(--teal-650);flex-shrink:0}
.guide-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:10px}
.guide-link{display:flex;align-items:center;gap:11px;background:var(--cream-50);border:1px solid var(--border);border-radius:12px;padding:14px 16px;font:500 13.5px/1.35 'Inter Tight';color:var(--ink-950)}.guide-link:hover{border-color:var(--teal-650);text-decoration:none}.guide-link svg{width:18px;height:18px;color:var(--gold-500);flex-shrink:0}
.faq{background:var(--cream-50);border:1px solid var(--border);border-radius:12px;margin-bottom:8px}.faq[open]{border-color:var(--teal-650)}
.faq summary{cursor:pointer;padding:15px 18px;font:600 14.5px/1.4 'Inter Tight';color:var(--ink-950);list-style:none;display:flex;justify-content:space-between;gap:12px}.faq summary::-webkit-details-marker{display:none}.faq summary::after{content:'+';color:var(--gold-500);font-size:20px;line-height:1}.faq[open] summary::after{content:'\\2013'}.faq .fbody{padding:0 18px 16px;font-size:14px;color:var(--ink-700);line-height:1.7}
.claim-block{background:var(--teal-950);border-radius:18px;padding:30px 32px;color:#fff;margin-top:6px}.claim-block .eyebrow{color:var(--mint-500)}.claim-block h2{color:#fff;margin-bottom:8px}.claim-block .lede{font-size:14px;color:rgba(255,255,255,.78);max-width:560px;margin-bottom:20px;line-height:1.65}
.claim-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:22px}@media(max-width:560px){.claim-grid{grid-template-columns:1fr}}
.claim-feat{display:flex;gap:11px;align-items:flex-start;font-size:13.5px;color:rgba(255,255,255,.9);line-height:1.5}.claim-feat svg{width:18px;height:18px;color:var(--mint-500);flex-shrink:0;margin-top:1px}
.claim-ctas{display:flex;gap:10px;flex-wrap:wrap}.btn-mint{background:var(--mint-500);color:var(--teal-950)}.btn-mint:hover{filter:brightness(1.05)}.btn-line{background:transparent;color:rgba(255,255,255,.85);border:1.5px solid rgba(255,255,255,.22)}.btn-line:hover{border-color:var(--mint-500);color:#fff}
.owner-note{display:none;font-size:13px;color:var(--ink-500);background:var(--cream-100);border:1px dashed var(--border);border-radius:12px;padding:14px 16px;margin-top:6px}.owner-note a{color:var(--teal-650);font-weight:600}
.nearby-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}@media(max-width:560px){.nearby-grid{grid-template-columns:1fr}}
.ncard{background:var(--cream-50);border:1px solid var(--border);border-radius:14px;padding:16px 18px;display:block;color:var(--ink-950);transition:.16s}.ncard:hover{transform:translateY(-2px);border-color:var(--teal-650);box-shadow:0 6px 20px rgba(0,0,0,.06);text-decoration:none}
.ncard-name{font-family:'Fraunces',serif;font-size:16px;font-weight:500;margin-bottom:3px}.ncard-loc{font-size:13px;color:var(--ink-500)}.ncard-badge{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;color:var(--gold-500);background:var(--gold-bg);border-radius:999px;padding:3px 10px;margin-top:8px}.ncard-meta{font-size:12px;color:var(--ink-500);margin-top:6px}
.geo-office{display:flex;gap:14px;padding:14px 0;border-bottom:1px solid var(--border)}.geo-office:last-child{border-bottom:none}.geo-dist{flex-shrink:0;width:54px;text-align:center;background:var(--cream-100);border:1px solid var(--border);border-radius:10px;padding:7px 0;font:700 13px/1.2 'Inter Tight';color:var(--teal-650)}.geo-dist span{display:block;font-size:10px;font-weight:500;color:var(--ink-500);margin-top:1px}
.geo-name{font-family:'Fraunces',serif;font-size:15.5px;font-weight:500;color:var(--ink-950)}.geo-desc{font-size:13px;color:var(--ink-500);margin-top:3px;line-height:1.5}.geo-dir{font:600 12.5px/1 'Inter Tight';color:var(--teal-650);margin-top:6px;display:inline-block}
.geo-tier{display:flex;flex-wrap:wrap;gap:8px;margin-top:20px}.geo-tier a{display:inline-flex;align-items:center;padding:7px 14px;background:var(--cream-50);border:1px solid var(--border);border-radius:999px;font:600 13px/1 'Inter Tight';color:var(--ink-950)}.geo-tier a:hover{border-color:var(--teal-650);color:var(--teal-650);text-decoration:none}
.city-nav{position:relative;margin-top:20px;overflow:hidden}
.city-nav-fade-l,.city-nav-fade-r{position:absolute;top:0;bottom:0;width:40px;z-index:2;pointer-events:none}
.city-nav-fade-l{left:0;background:linear-gradient(to right,var(--cream-50),transparent)}
.city-nav-fade-r{right:0;background:linear-gradient(to left,var(--cream-50),transparent)}
.city-nav-track{display:flex;overflow-x:auto;scroll-snap-type:x mandatory;scrollbar-width:none;border-top:1px solid var(--border)}.city-nav-track::-webkit-scrollbar{display:none}
.city-nav-item{scroll-snap-align:start;flex-shrink:0;display:flex;flex-direction:column;justify-content:flex-end;padding:16px 22px 14px;border-right:1px solid var(--border);min-width:140px;position:relative;text-decoration:none;color:inherit;transition:background .2s}
.city-nav-item:hover{background:var(--cream-100);text-decoration:none}
.city-nav-item::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2.5px;background:var(--mint-500);transform:scaleX(0);transform-origin:left;transition:transform .3s cubic-bezier(.4,0,.2,1)}
.city-nav-item:hover::after,.city-nav-item.active::after{transform:scaleX(1)}
.cni-label{font:600 10px/1 'Inter Tight';letter-spacing:.08em;text-transform:uppercase;color:var(--ink-500);margin-bottom:5px}
.cni-name{font-family:'Fraunces',serif;font-size:17px;font-weight:500;color:var(--ink-950);margin-bottom:4px}
.cni-count{font:500 12px/1 'Inter Tight';color:var(--ink-500);display:flex;align-items:center;gap:4px}
.cni-arrow{opacity:0;transform:translateX(-4px);transition:opacity .2s,transform .2s;color:var(--teal-650)}
.city-nav-item:hover .cni-arrow{opacity:1;transform:translateX(0)}
.rail{position:sticky;top:calc(var(--nav-h) + 14px);align-self:start;display:flex;flex-direction:column;gap:13px}.railcard{border-radius:18px;overflow:hidden;border:1px solid var(--border);box-shadow:0 4px 24px rgba(0,0,0,.07)}
.rc-top{background:var(--teal-950);padding:18px 20px 16px;color:#fff}.rc-name{font-family:'Fraunces',serif;font-size:18px;font-weight:500;line-height:1.25}.rc-city{font-size:13px;color:rgba(255,255,255,.85);margin:3px 0 10px}
.rc-rating{display:inline-flex;align-items:center;gap:6px;font-size:13px}.rc-rating .stars{font-size:13px}.rc-rating b{color:#fff}.rc-rating .src{color:rgba(255,255,255,.75);font-size:11.5px}
.rc-badge{display:inline-flex;align-items:center;gap:5px;font:600 10.5px/1 'Inter Tight';letter-spacing:.05em;text-transform:uppercase;background:var(--gold-bg);color:#E2C58A;border:1px solid rgba(184,146,79,.4);border-radius:999px;padding:4px 10px;margin-top:11px}
.rc-body{background:var(--cream-50);padding:16px 18px}.rc-open{font-size:12.5px;color:var(--ink-500);margin-bottom:12px;display:flex;align-items:center;gap:6px}
.rc-addr{display:flex;gap:9px;align-items:flex-start;font-size:13.5px;color:var(--ink-950);line-height:1.45;margin-bottom:10px}.rc-addr svg{width:15px;height:15px;color:var(--teal-650);flex-shrink:0;margin-top:2px}.rc-addr a{display:block;color:var(--teal-650);font-weight:600;font-size:12.5px;margin-top:3px}
.rc-phone{display:flex;gap:9px;align-items:center;font-size:14px;color:var(--ink-950);margin-bottom:14px}.rc-phone svg{width:15px;height:15px;color:var(--teal-650);flex-shrink:0}.rc-phone a{color:var(--ink-950);font-weight:600}
.rc-stack{display:flex;flex-direction:column;gap:8px}.rc-btn{display:flex;align-items:center;justify-content:center;gap:7px;width:100%;border:none;cursor:pointer;border-radius:var(--rad-btn);font:600 13.5px/1 'Inter Tight';padding:12px;min-height:46px;transition:.15s;text-decoration:none}.rc-btn svg{width:15px;height:15px}
.rc-btn.mint{background:var(--mint-500);color:var(--teal-950)}.rc-btn.mint:hover{filter:brightness(1.04)}.rc-btn.solid{background:var(--teal-950);color:var(--mint-500)}.rc-btn.solid:hover{background:var(--teal-800)}.rc-btn.ghost{background:var(--cream-50);color:var(--teal-650);border:1.5px solid var(--border)}.rc-btn.ghost:hover{border-color:var(--teal-650)}
.rc-secondary{display:flex;gap:8px;margin-top:8px}.rc-secondary .rc-btn{font-size:12.5px;padding:10px;min-height:42px}.rc-note{font-size:11px;color:var(--ink-500);text-align:center;margin-top:11px}
.alert-bar{background:var(--teal-950);color:#FAF8F5;text-align:center;padding:10px 16px;font-size:14px;line-height:1.5}.alert-bar a{color:var(--mint-500);font-weight:700;text-decoration:underline}
.sticky-bar{position:fixed;bottom:0;left:0;right:0;z-index:140;background:var(--teal-950);padding:10px 16px calc(10px + env(safe-area-inset-bottom));border-top:1px solid rgba(255,255,255,.1);display:none}.sticky-bar.show{display:block}
.sticky-inner{display:flex;gap:12px;align-items:center;justify-content:space-between;max-width:var(--content-max);margin:0 auto}
.sticky-ctx{display:flex;flex-direction:column;gap:2px}.sticky-name{font:600 14px/1.2 'Inter Tight';color:#fff}.sticky-sub{font-size:12px;color:rgba(255,255,255,.6)}
.sticky-actions{display:flex;align-items:center;gap:16px;flex-shrink:0}
.btn-sticky-primary{background:rgba(184,146,79,.15);color:var(--mint-500);border:1.5px solid rgba(184,146,79,.4);border-radius:10px;padding:10px 18px;min-height:44px;font:700 13px/1 'Inter Tight';cursor:pointer;white-space:nowrap}.btn-sticky-primary:hover{background:rgba(184,146,79,.25)}
.btn-sticky-secondary{color:rgba(255,255,255,.7);font:600 13px/1 'Inter Tight';background:none;border:none;cursor:pointer;text-decoration:underline;white-space:nowrap}
@media(max-width:600px){.sticky-actions{flex-wrap:wrap;gap:8px}}
dialog{padding:0;border:none;margin:auto;border-radius:20px;max-width:500px;width:calc(100% - 32px);background:var(--cream-50);color:var(--ink-700);box-shadow:0 24px 64px rgba(0,0,0,.32)}dialog::backdrop{background:rgba(8,20,24,.55)}
.dlg-inner{padding:24px;max-height:88vh;overflow-y:auto;position:relative}.dlg-accent{height:4px;border-radius:4px 4px 0 0;margin:-24px -24px 18px;background:var(--mint-500)}.dlg-accent.gold{background:var(--gold-500)}
.dlg-close{position:absolute;top:14px;right:14px;background:var(--cream-100);border:1px solid var(--border);width:32px;height:32px;border-radius:50%;font-size:18px;color:var(--ink-500);cursor:pointer;line-height:1;display:grid;place-items:center;z-index:2}.dlg-close:hover{color:var(--ink-950)}
.dlg-overline{font:600 10.5px/1 'Inter Tight';letter-spacing:.1em;text-transform:uppercase;color:var(--teal-650);display:block;margin-bottom:9px}.dlg-overline.gold{color:var(--gold-500)}
.dlg-h{font:500 21px/1.2 'Fraunces',serif;color:var(--ink-950);margin:0 0 6px}.dlg-sub{font-size:13px;color:var(--ink-500);margin:0 0 16px;line-height:1.55}
.dlg-back{background:none;border:none;font:600 11px/1 'Inter Tight';color:var(--teal-650);cursor:pointer;padding:0;margin-bottom:12px;letter-spacing:.04em;text-transform:uppercase}
.step{display:none}.step.active{display:block}
.privacy-line{display:flex;gap:8px;align-items:center;font-size:12px;color:var(--ink-500);background:var(--cream-100);border-radius:9px;padding:9px 12px;margin-bottom:14px}.privacy-line svg{width:15px;height:15px;color:var(--teal-650);flex-shrink:0}
.carrier-group-label{font:600 10px/1 'Inter Tight';letter-spacing:.08em;text-transform:uppercase;color:var(--ink-500);margin:4px 0 8px}
.carrier-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:8px;margin-bottom:14px}
.ct-btn{border:1.5px solid var(--border);border-radius:11px;padding:11px 10px;text-align:left;cursor:pointer;font:600 12.5px/1.3 'Inter Tight';color:var(--ink-700);background:var(--cream-50);transition:.15s;min-height:46px;display:flex;align-items:center;gap:8px}.ct-btn:hover{border-color:var(--teal-650)}.ct-btn .ck{width:15px;height:15px;border-radius:50%;border:1.5px solid var(--border);flex-shrink:0;display:grid;place-items:center;color:#fff;font-size:9px;transition:.15s}.ct-btn[aria-pressed="true"]{border-color:var(--teal-650);background:var(--mint-100);color:var(--ink-950)}.ct-btn[aria-pressed="true"] .ck{background:var(--teal-650);border-color:var(--teal-650)}
.note-box{background:var(--gold-bg);border:1px solid rgba(184,146,79,.3);border-radius:10px;padding:11px 14px;font-size:12.5px;color:var(--ink-700);line-height:1.5;margin-bottom:14px;display:none}.note-box.show{display:block}.note-box strong{color:var(--ink-950)}
.field-group{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}.field-group.full{grid-template-columns:1fr}.field-wrap{display:flex;flex-direction:column;gap:5px}
.field-label{font:600 10px/1 'Inter Tight';letter-spacing:.06em;text-transform:uppercase;color:var(--ink-500)}.field-label .opt{font-weight:400;text-transform:none;letter-spacing:0;font-size:10.5px;margin-left:4px}
.field-input{width:100%;padding:11px 12px;border:1.5px solid var(--border);border-radius:11px;font:14px 'Inter Tight';color:var(--ink-950);background:var(--cream-50);outline:none;transition:.15s}.field-input:focus{border-color:var(--teal-650)}.field-input[aria-invalid="true"]{border-color:var(--coral-500)}
.field-error{font-size:11.5px;color:var(--coral-ink);display:none}.field-error.show{display:block}
.radio-opts{display:flex;flex-direction:column;gap:9px;margin-bottom:14px}.radio-opt{display:flex;gap:11px;align-items:flex-start;padding:12px 14px;border:1.5px solid var(--border);border-radius:12px;cursor:pointer;transition:.15s}.radio-opt:hover{border-color:var(--teal-650)}.radio-opt:has(input:checked){border-color:var(--teal-650);background:var(--mint-100)}.radio-opt input{margin-top:2px;accent-color:var(--teal-650);width:16px;height:16px;flex-shrink:0}.radio-opt-title{font-size:13.5px;font-weight:600;color:var(--ink-950)}
.review-toggle{background:none;border:none;border-top:1px solid var(--cream-200);padding:12px 0;font:600 13px/1 'Inter Tight';color:var(--teal-650);cursor:pointer;display:flex;align-items:center;gap:8px;width:100%;margin-top:4px}.review-toggle svg{width:14px;height:14px;transition:transform .2s}.review-toggle[aria-expanded="true"] svg{transform:rotate(180deg)}
.review-body{display:none;margin-bottom:12px}.review-body.show{display:block}.msg-to{font-size:12px;color:var(--ink-500);margin-bottom:6px}.msg-to code{font-family:ui-monospace,monospace;font-size:11.5px;color:var(--ink-950)}
.msg-textarea{width:100%;min-height:150px;padding:13px 15px;border:1.5px solid var(--border);border-radius:12px;font:13px/1.6 'Inter Tight';color:var(--ink-950);resize:vertical;outline:none;background:var(--cream-50)}.msg-textarea:focus{border-color:var(--teal-650)}
.btn-block{display:flex;align-items:center;justify-content:center;width:100%;padding:14px;min-height:52px;border-radius:13px;font:700 14px/1 'Inter Tight';border:none;cursor:pointer;transition:.15s}.btn-block.primary{background:var(--teal-950);color:var(--mint-500)}.btn-block.primary:hover{background:var(--teal-800)}.btn-block.sec{background:var(--cream-50);color:var(--ink-700);border:1.5px solid var(--border);font-weight:600;font-size:12.5px;min-height:46px;padding:12px}.btn-block.sec:hover{border-color:var(--teal-650);color:var(--ink-950)}
.send-row{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-top:9px}.send-caption{text-align:center;font-size:11.5px;color:var(--ink-500);margin-top:10px;line-height:1.5}
.done-wrap{text-align:center;padding:10px 0 4px}.done-icon{width:50px;height:50px;border-radius:50%;background:var(--mint-100);color:var(--teal-650);font-size:23px;display:grid;place-items:center;margin:0 auto 14px}.done-h{font:500 23px/1.2 'Fraunces',serif;color:var(--ink-950);margin:0 0 10px}.done-p{font-size:13.5px;color:var(--ink-500);line-height:1.6;margin:0 0 18px}
.toast{position:fixed;left:50%;bottom:24px;transform:translateX(-50%) translateY(20px);background:var(--teal-950);color:#fff;border-radius:12px;padding:13px 16px;display:none;align-items:center;gap:12px;z-index:300;box-shadow:0 12px 32px rgba(0,0,0,.3);max-width:calc(100% - 32px);opacity:0;transition:.25s}.toast.show{display:flex;opacity:1;transform:translateX(-50%) translateY(0)}.toast span{font-size:13px}.toast button{background:none;border:none;color:var(--mint-500);cursor:pointer;font-size:18px;padding:2px;flex-shrink:0}
.field-textarea{width:100%;min-height:70px;padding:11px 12px;border:1.5px solid var(--border);border-radius:11px;font:13.5px/1.5 'Inter Tight';color:var(--ink-950);background:var(--cream-50);outline:none;resize:vertical}.field-textarea:focus{border-color:var(--teal-650)}
.bk-summary{display:flex;flex-wrap:wrap;gap:6px 10px;align-items:center;background:var(--mint-100);border:1px solid var(--border);border-radius:12px;padding:12px 14px;font:600 13px/1 'Inter Tight';color:var(--ink-950);margin-bottom:14px}.bk-summary .e{margin-left:auto;font:600 12px/1 'Inter Tight';color:var(--teal-650);text-decoration:underline;text-underline-offset:2px;cursor:pointer;background:none;border:none}
@media(max-width:920px){.layout{grid-template-columns:1fr;gap:0}.rail{position:static;margin-bottom:30px}.hours-loc{grid-template-columns:1fr}.sticky-bar.show{display:block}}
@media(max-width:720px){dialog{max-width:none;width:100%;border-radius:20px 20px 0 0;position:fixed;bottom:0;left:0;right:0;top:auto;max-height:92vh}.dlg-inner{max-height:92vh;padding-bottom:26px}.field-group{grid-template-columns:1fr}.send-row{grid-template-columns:1fr}.hero-top{flex-direction:column;gap:12px}}
@media(prefers-reduced-motion:reduce){*{animation-duration:.001ms!important;transition-duration:.001ms!important;scroll-behavior:auto!important}}
.gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:12px}
.gphoto{border-radius:12px;overflow:hidden;aspect-ratio:4/3;border:1px solid var(--border);position:relative;background:var(--cream-100)}
.gphoto.stock svg{width:100%;height:100%;display:block}
.stock-tag{position:absolute;bottom:8px;left:8px;background:rgba(0,0,0,.55);color:#fff;font:600 10px/1 'Inter Tight';padding:4px 8px;border-radius:6px;letter-spacing:.04em}
.gphoto.upload{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;cursor:pointer;background:var(--cream-100);color:var(--ink-500);border:1.5px dashed var(--border)}.gphoto.upload:hover{border-color:var(--teal-650);color:var(--teal-650)}.gphoto.upload .lbl{font:600 12px/1 'Inter Tight'}
.gallery-note{font-size:12px;color:var(--ink-500);line-height:1.5;font-style:italic}
.carrier-row.hidden{display:none}
.ins-toggle{margin-top:10px;display:flex;align-items:center;gap:7px;background:none;border:none;cursor:pointer;font:600 13px/1 'Inter Tight';color:var(--teal-650);padding:10px 0 2px;width:100%}
.ins-toggle svg{transition:transform .3s}.ins-toggle.open svg{transform:rotate(180deg)}
.ins-toggle-count{background:rgba(184,146,79,.12);color:var(--gold-500);border-radius:999px;font:700 10px/1 'Inter Tight';padding:2px 7px}
.t5-concierge-line{font-family:'Inter Tight',system-ui;font-size:12.5px;color:var(--ink-500);margin:10px 0 0;font-style:italic;line-height:1.4}
.t5-carrier-link{color:#14525B;font-size:13px;text-decoration:none;display:inline-block;margin-top:6px}
.t5-carrier-link:hover{text-decoration:underline}
.t5-edu-link{text-align:center;padding:12px 0;border-top:1px solid var(--border)}
.t5-edu-link a{font-family:'Inter Tight',system-ui;font-size:12px;color:#5E8C92;text-decoration:none}
.t5-edu-link a:hover{color:#14525B;text-decoration:underline}
</style>

<!-- ALERT BAR -->
<div class="alert-bar">No insurance? PPO plans from ~$30/month &mdash; <a href="${BASE_URL}/compare-ppo-dental-plans">compare individual PPO plans, effective dates and waiting periods</a>.</div>

<!-- BREADCRUMB -->
<nav class="crumb" aria-label="Breadcrumb"><div class="wrap">
  <a href="${BASE_URL}/">CoverCapy</a><span class="sep">/</span>
  <a href="${BASE_URL}/dental/${stSlug}/">${esc(state)}</a><span class="sep">/</span>
  <a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/">${esc(market_area)}</a><span class="sep">/</span>
  <a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/${cSlug}/">${esc(city)}</a><span class="sep">/</span>
  <b>${esc(name)}</b>
</div></nav>

<!-- SECTION NAV -->
<nav class="section-nav" aria-label="Sections">
  <div class="sn-inner">
    <div class="ts-wrap">
      <div class="theme-switch" id="theme-switch" data-active="gold" role="switch" aria-checked="false" tabindex="0" aria-label="Switch between Gold and Jade themes">
        <span class="ts-thumb"></span>
        <span class="ts-opt ts-gold"><span class="ts-dot"></span>Gold</span>
        <span class="ts-opt ts-jade"><span class="ts-dot"></span>Jade</span>
      </div>
    </div>
    <ul class="sn-links">
      <li><a href="#overview">Overview</a></li>
      <li><a href="#insurance">Insurance</a></li>
      <li><a href="#book">Book</a></li>
      <li><a href="#treatments">Treatments</a></li>
      <li><a href="#location">Hours &amp; location</a></li>
      <li><a href="#costs">Costs</a></li>
      <li><a href="#faqs">FAQs</a></li>
      <li><a href="#nearby">Nearby</a></li>
    </ul>
  </div>
</nav>

<div class="wrap"><div class="layout">
<main class="main-col" id="main-content">

  <!-- HERO -->
  <section class="module" id="overview">
    <span class="eyebrow">PPO Dentist · ${esc(city)}, ${abbr}</span>
    <div class="hero-top">
      <div class="headshot" aria-hidden="true"><span class="mono">${esc(monogram)}</span></div>
      <div style="flex:1;min-width:0">
        <div class="hero-name">
          <h1>${esc(name)}</h1>
          <span class="accr-badge" id="accr-badge">${esc(accreditationStatus || '')}</span>
        </div>
        ${doctorName ? `<p class="hero-doctor">Led by ${esc(doctorName)}</p>` : ''}
        <div class="hero-meta">
          ${rating && reviews > 0 ? `<span class="rating"><span class="stars">${esc(ratingStars)}</span><b>${rating}</b><span class="src">· ${reviews.toLocaleString()} reviews</span></span>` : ''}
          <span class="open-pill" id="open-pill"></span>
        </div>
      </div>
    </div>
    <p class="hero-lede">${esc(name)} ${networks.length > 0 ? 'lists ' + networks.slice(0,3).map(n=>esc(n)).join(', ') + (networks.length > 3 ? ' and more' : '') + '.' : 'works with major PPO dental insurance.'} Check whether your exact PPO plan is likely accepted, then book or prepare a coverage request.</p>
    <div class="hero-ctas">
      <button class="btn btn-primary" data-open="insurance"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/></svg>Verify my Insurance</button>
      <a class="btn btn-secondary" href="#book">Book an Appointment</a>
    </div>
    <p class="t5-concierge-line">We don't just list which PPOs this office accepts. We ask them on your behalf.</p>
    <p class="hero-claim-link" id="hero-claim"><a href="${BASE_URL}/for-dentists/claim/${esc(dSlug)}-${esc(cSlug.toLowerCase())}">Is this your practice? Claim it free</a></p>
    <p class="data-checked"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>Data sourced from the office's public Google listing. Last updated ${esc(lastChecked)}.</p>
  </section>

  <!-- GALLERY -->
  <section class="module" id="gallery" style="padding-top:0;border-top:none">
    <div class="gallery">
      <div class="gphoto stock">
        <svg viewBox="0 0 320 240" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block"><rect width="320" height="240" fill="#E8F0EE"/><rect x="60" y="40" width="200" height="160" rx="8" fill="#C8D9D6"/><rect x="80" y="60" width="80" height="100" rx="4" fill="#8BA8A3"/><rect x="170" y="80" width="70" height="80" rx="4" fill="#9BB8B3"/><rect x="80" y="170" width="160" height="10" rx="2" fill="#8BA8A3"/><rect x="90" y="60" width="60" height="40" rx="3" fill="#A8C4BF"/><circle cx="115" cy="45" r="12" fill="#B8924F" opacity=".7"/><rect x="100" y="95" width="30" height="35" rx="2" fill="#6E9490"/><rect x="170" y="95" width="25" height="20" rx="2" fill="#7AA09B"/><rect x="170" y="120" width="25" height="15" rx="2" fill="#6E9490"/></svg>
        <span class="stock-tag">Sample image</span>
      </div>
      <button class="gphoto upload" type="button">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <span class="lbl">Upload office photo</span>
      </button>
      <button class="gphoto upload" type="button">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <span class="lbl">Upload office photo</span>
      </button>
    </div>
    <p class="gallery-note">This dentist hasn't uploaded photos of their office yet. Are you the practice? Add photos to improve your ranking.</p>
  </section>

  <!-- INSURANCE -->
  <section class="module" id="insurance">
    <span class="eyebrow">Insurance</span>
    <h2>Will this office take your PPO plan?</h2>
    <div class="ins-intro"><h3>Listed carriers</h3><p>These carriers are listed for this office. A listing is a starting point — not a guarantee for every plan or network tier. Check your exact plan, then confirm with the office.</p></div>
    <div class="carrier-rows" id="carrier-rows"></div>
    <button class="ins-toggle" id="ins-toggle" style="display:none">Show all ${networks.length} carriers</button>
    <div class="ins-actions"><button class="btn btn-primary" data-open="insurance">Check my exact plan</button><a class="btn btn-ghost" href="${BASE_URL}/learn/ppo-network-tiers">Learn about PPO tiers</a></div>
    <p class="ins-disclaimer">Carrier listings do not guarantee that every plan or network tier is accepted, and CoverCapy does not perform a live eligibility check on this page. Last checked ${esc(lastChecked)}.</p>
  </section>

  <!-- BOOKING WIDGET -->
  <section class="module" id="book">
    <span class="eyebrow">Booking</span>
    <h2>Book a visit</h2>
    <p class="sec-p">Pick a visit type and time to get started. Online booking activates when the office connects its scheduler.</p>
    <div class="bookwidget" id="bookwidget" data-state="preview">
      <div class="bw-head"><span class="t">Book at ${esc(name)}</span><span class="bw-badge" id="bw-badge">Preview</span></div>
      <div class="bw-body">
        <p class="bw-row-label">Visit type</p>
        <div class="bw-chips" id="bw-chips" role="group" aria-label="Visit type"></div>
        <p class="bw-row-label">Date</p>
        <div class="bw-dates" id="bw-dates" role="group" aria-label="Select a date"></div>
        <p class="bw-row-label">Time</p>
        <div class="bw-slots" id="bw-slots" role="group" aria-label="Example times"></div>
        <div class="bw-cta" id="bw-cta"></div>
        <p class="bw-foot" id="bw-foot"></p>
        <div class="bw-claim" id="bw-claim"><strong>Own this practice?</strong> This is what your live booking widget looks like. <a href="${BASE_URL}/for-dentists/claim/${esc(dSlug)}-${esc(cSlug.toLowerCase())}">Claim your profile</a> to turn on real online booking.</div>
      </div>
    </div>
  </section>

  <!-- TREATMENTS -->
  <section class="module" id="treatments">
    <span class="eyebrow">Treatments &amp; services</span>
    <h2>What this office offers</h2>
    <ul class="pillrow" id="proc-pills" style="margin-top:14px"></ul>
  </section>

  <!-- ABOUT -->
  <section class="module">
    <span class="eyebrow">About this practice</span>
    <h2>${esc(name)}, ${esc(city)}</h2>
    <div style="margin-top:12px;font-size:15px;line-height:1.74;color:var(--ink-700)">
      <p style="margin-bottom:14px">${esc(name)} is a dental office${d.address ? ` at ${esc(d.address)}` : ` in ${esc(city)}, ${abbr}`}${doctorName ? `, led by ${esc(doctorName)}` : ''}. ${networks.length > 0 ? `The practice lists ${networks.length} PPO insurance network${networks.length !== 1 ? 's' : ''}, including ${networks.slice(0,3).map(n=>esc(n)).join(', ')}${networks.length > 3 ? ' and others' : ''}.` : 'The office works with major PPO dental insurance plans.'}</p>
      <p>If you already have dental insurance, CoverCapy helps you check whether your exact PPO plan is likely accepted and prepare a short coverage request. ${d.open_weekends ? `${esc(name)} offers weekend appointments. ` : ''}The nearby PPO dentists below are also listed on CoverCapy.</p>
      ${(() => { const primaryCarrier = (networks)[0] || ''; const carrierUrl = carrierHubLink(primaryCarrier); return carrierUrl ? `<a href="${carrierUrl}" class="t5-carrier-link">See ${esc(primaryCarrier)} plan details</a>` : ''; })()}
    </div>
  </section>

  <!-- HOURS & LOCATION -->
  <section class="module" id="location">
    <span class="eyebrow">Hours &amp; location</span>
    <h2>When and where</h2>
    <div class="hours-loc" style="margin-top:14px">
      <div class="hours-table" id="hours-table"></div>
      <div>
        ${mapsEmbed ? `<div class="map-tile"><iframe title="Map of ${esc(name)}" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allow="fullscreen" src="${mapsEmbed}"></iframe></div>` : ''}
        <div class="loc-actions">
          <a class="btn btn-secondary" href="${mapsDir}" target="_blank" rel="noopener">Get directions</a>
          ${websiteClean ? `<button class="btn btn-ghost" data-ext-site>Official website</button>` : ''}
          ${d.phone ? `<a class="btn btn-ghost" href="${phoneTel}">${esc(phoneRaw)}</a>` : ''}
        </div>
      </div>
    </div>
  </section>

  <!-- COSTS -->
  <section class="module" id="costs">
    <span class="eyebrow">Costs &amp; financing</span>
    <h2>Plan for treatment cost</h2>
    <p class="sec-p">Estimate what common treatments may cost with and without PPO coverage, then compare financing.</p>
    <div class="planning-box">
      <button class="planning-link" data-cost="Crown"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 8l4 3 4-6 4 6 4-3v9H4z"/></svg>Estimate crown cost</button>
      <button class="planning-link" data-cost="Implant"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3c3 0 4 2 4 5 0 4-1 6-1 9h-6c0-3-1-5-1-9 0-3 1-5 4-5z"/></svg>Estimate implant cost</button>
      <button class="planning-link" data-cost="Root canal"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3c3 0 4 2 4 5 0 4-1 6-1 9h-6c0-3-1-5-1-9 0-3 1-5 4-5z"/></svg>Estimate root-canal cost</button>
      <a class="planning-link" href="${BASE_URL}/learn/financing"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="M3 10h18"/></svg>Dental financing</a>
      <a class="planning-link" href="${BASE_URL}/learn/ppo-vs-cash"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1v22M5 8h9a3 3 0 0 1 0 6H7"/></svg>PPO vs cash pricing</a>
    </div>
  </section>

  <!-- GUIDES -->
  <section class="module" id="guides">
    <span class="eyebrow">Before you book</span>
    <h2>PPO &amp; cost guides</h2>
    <p class="sec-p">Short reads to help you use your dental benefits well.</p>
    <div class="guide-grid" id="guide-grid"></div>
  </section>

  <!-- FAQ -->
  <section class="module" id="faqs">
    <span class="eyebrow">Frequently asked</span>
    <h2 style="margin-bottom:16px">Questions about this office</h2>
    ${faqs.map((f,i) => `<details class="faq"${i===0?' open':''}><summary>${esc(f.q)}</summary><div class="fbody">${esc(f.a)}</div></details>`).join('\n')}
  </section>

  <!-- CLAIM -->
  <section class="module" id="claim">
    <div class="claim-block" id="claim-block">
      <span class="eyebrow">For the practice</span>
      <h2>Is this your practice?</h2>
      <p class="lede">Claim ${esc(name)} to keep your listing accurate and unlock the booking widget, photos, and patient coverage requests. Claiming is free, and a claimed, accredited listing ranks above an unclaimed one.</p>
      <div class="claim-grid">
        <div class="claim-feat"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Turn on real online booking</div>
        <div class="claim-feat"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Add cover, headshot, and office photos</div>
        <div class="claim-feat"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Manage the insurance networks you accept</div>
        <div class="claim-feat"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Receive patient coverage requests by email</div>
        <div class="claim-feat"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Apply for Capy Accredited and Platinum Elite</div>
        <div class="claim-feat"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Rank higher in nearby and city search</div>
      </div>
      <div class="claim-ctas"><a class="btn btn-mint" href="${BASE_URL}/for-dentists/claim/${esc(dSlug)}-${esc(cSlug.toLowerCase())}">Claim this profile — free</a><a class="btn btn-line" href="${BASE_URL}/for-dentists/">How accreditation works</a></div>
    </div>
    <div class="owner-note" id="owner-note">This listing is claimed. <a href="${BASE_URL}/for-dentists/">Manage this listing</a></div>
  </section>

  <!-- NEARBY (dynamic via Supabase JS) -->
  <section class="module" id="nearby">
    <span class="eyebrow">Also on CoverCapy</span>
    <h2>PPO dentists near ${esc(city)}</h2>
    <p class="sec-p">PPO offices listed on CoverCapy near ${esc(name)}.</p>
    <div class="nearby-grid" id="nearby-grid"><p style="color:var(--ink-500);font-size:13.5px;grid-column:1/-1">Loading nearby offices...</p></div>
  </section>

  <section class="module" id="geo-block" style="display:none">
    <span class="eyebrow" id="geo-eyebrow">Also on CoverCapy</span>
    <h2 id="geo-heading">PPO dentists near this office</h2>
    <div id="geo-prose" style="margin:12px 0 18px;font-size:15px;line-height:1.74;color:var(--ink-700)"></div>
    <div id="geo-offices"></div>
    <div class="geo-tier" id="geo-tier" style="display:none"></div>
  </section>

</main>

<!-- RAIL -->
<aside class="rail" aria-label="Contact and booking">
  <div class="railcard">
    <div class="rc-top">
      <div class="rc-name">${esc(name)}</div>
      <div class="rc-city">${esc(city)}, ${abbr}</div>
      ${rating && reviews > 0 ? `<div class="rc-rating"><span class="stars">${esc(ratingStars)}</span><b>${rating}</b><span class="src">· ${reviews.toLocaleString()} reviews</span></div>` : ''}
      <div class="rc-badge" id="rc-badge">${esc(accreditationStatus || '')}</div>
    </div>
    <div class="rc-body">
      <div class="rc-open" id="rc-open"></div>
      ${d.address ? `<div class="rc-addr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-7-5.2-7-11a7 7 0 0 1 14 0c0 5.8-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg><div>${esc(d.address)}<a href="${mapsDir}" target="_blank" rel="noopener">Get directions</a></div></div>` : ''}
      ${d.phone ? `<div class="rc-phone"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L17 13l5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 4 7a2 2 0 0 1 1-3z"/></svg><a href="${phoneTel}">${esc(phoneRaw)}</a></div>` : ''}
      <div class="rc-stack">
        <a class="rc-btn mint" href="#book">Book a visit</a>
        <button class="rc-btn solid" data-open="insurance">Check my insurance — free</button>
      </div>
      <div class="rc-secondary">
        ${d.address ? `<a class="rc-btn ghost" href="${mapsDir}" target="_blank" rel="noopener">Directions</a>` : ''}
        ${websiteClean ? `<button class="rc-btn ghost" data-ext-site>Website</button>` : ''}
      </div>
      <div class="rc-note">Insurance verification is always free.</div>
    </div>
  </div>
</aside>

</div></div>

<div class="t5-edu-link"><a href="/dental-insurance/">New to PPO dental insurance? How in-network coverage works</a></div>

<!-- STICKY BAR -->
<div class="sticky-bar" id="sticky-bar" role="region" aria-label="Coverage actions">
  <div class="sticky-inner">
    <div class="sticky-ctx">
      <span class="sticky-name">${esc(name)}</span>
      <span class="sticky-sub">${esc(city)} &middot; PPO Dentist &middot; Coverage check</span>
    </div>
    <div class="sticky-actions">
      <button class="btn-sticky-primary" data-open="insurance">Verify my coverage — free</button>
      <a class="btn-sticky-secondary" href="${BASE_URL}/compare-ppo-dental-plans">Plans from ~$30/mo</a>
    </div>
  </div>
</div>

<!-- DIALOG: INSURANCE CHECK -->
<dialog id="dlg-insurance" aria-labelledby="ins-title"><div class="dlg-inner">
  <div class="dlg-accent"></div><button class="dlg-close" data-close aria-label="Close">&#215;</button>
  <div class="step active" data-step="1">
    <span class="dlg-overline">Check current insurance · Step 1 of 2</span>
    <h2 class="dlg-h" id="ins-title">Which dental insurance do you have?</h2>
    <p class="dlg-sub">Choose the carrier shown on your dental insurance card.</p>
    <div class="privacy-line"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/></svg>Never enter an SSN or Member ID here.</div>
    <div class="carrier-group-label">Listed for this office</div><div class="carrier-grid" id="carrier-listed"></div>
    <div class="carrier-group-label">Other dental carriers</div><div class="carrier-grid" id="carrier-other"></div>
    <div class="note-box" id="metlife-note"><strong>MetLife</strong> sometimes uses a Social Security Number as the member identifier. Do not enter that here. The office can tell you the safest way to complete verification.</div>
    <button class="btn-block primary" id="ins-next" disabled>Continue</button>
  </div>
  <div class="step" data-step="2">
    <button class="dlg-back" data-back>&larr; Back</button>
    <span class="dlg-overline">Check current insurance · Step 2 of 2</span>
    <h2 class="dlg-h">Prepare your coverage request</h2>
    <p class="dlg-sub">We will create a message you can review and send from your email app.</p>
    <div class="field-group">
      <div class="field-wrap"><label class="field-label" for="v-fname">First name</label><input class="field-input" id="v-fname" type="text" autocomplete="given-name" placeholder="First name" aria-describedby="err-fname"/><span class="field-error" id="err-fname">Please enter your first name.</span></div>
      <div class="field-wrap"><label class="field-label" for="v-email">Email</label><input class="field-input" id="v-email" type="email" autocomplete="email" placeholder="you@email.com" aria-describedby="err-email"/><span class="field-error" id="err-email">Please enter a valid email address.</span></div>
    </div>
    <div class="field-group full"><div class="field-wrap"><label class="field-label" for="v-phone">Mobile <span class="opt">optional</span></label><input class="field-input" id="v-phone" type="tel" autocomplete="tel" placeholder="(optional)"/></div></div>
    <div class="radio-opts">
      <label class="radio-opt"><input type="radio" name="phonepref" value="exclude" checked/><div><div class="radio-opt-title">Keep my phone number out of the message</div></div></label>
      <label class="radio-opt"><input type="radio" name="phonepref" value="include"/><div><div class="radio-opt-title">Include my phone number so the office may contact me directly</div></div></label>
    </div>
    <button class="review-toggle" id="review-toggle" aria-expanded="false" aria-controls="review-body">Review the message<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
    <div class="review-body" id="review-body"><div class="msg-to">To: <code id="msg-dest">${esc(officeEmail || (d.phone ? '[office phone on file]' : '[office contact on file]'))}</code></div><textarea class="msg-textarea" id="msg-body" rows="8" aria-label="Coverage request message (editable)"></textarea></div>
    <div id="send-zone"></div>
    <p class="send-caption">No Member ID, Group Number, or Social Security number is included in this message. CoverCapy does not send this for you.</p>
  </div>
  <div class="step" data-step="done"><div class="done-wrap"><div class="done-icon">&#10003;</div><h2 class="done-h">Your email app is ready.</h2><p class="done-p">Your prepared message opened in your email app. Send it whenever you are ready. Nothing was sent automatically.</p><button class="btn-block sec" data-close>Done</button></div></div>
</div></dialog>

<!-- DIALOG: COST -->
<dialog id="dlg-cost" aria-labelledby="cost-title"><div class="dlg-inner">
  <div class="dlg-accent"></div><button class="dlg-close" data-close aria-label="Close">&#215;</button>
  <span class="dlg-overline">Treatment cost</span><h2 class="dlg-h" id="cost-title">Estimate treatment cost</h2>
  <p class="dlg-sub">Typical range for this treatment with and without PPO coverage.</p>
  <span class="proto-flag"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>Prototype estimator — no live prices yet</span>
  <div class="field-group"><div class="field-wrap"><label class="field-label" for="c-zip">ZIP code</label><input class="field-input" id="c-zip" type="text" inputmode="numeric" maxlength="5" placeholder="${esc(d.address ? (d.address.match(/\d{5}/) || [''])[0] : '')}"/></div><div class="field-wrap"><label class="field-label" for="c-ins">Insurance</label><select class="field-input" id="c-ins"><option>I have PPO coverage</option><option>No coverage (cash)</option><option>Not sure yet</option></select></div></div>
  <div style="font-size:12.5px;color:var(--ink-500);line-height:1.5;margin-bottom:14px">When a pricing source is connected, this will show a typical local range and your estimated out-of-pocket.</div>
  <button class="btn-block primary" data-open="insurance">Check my coverage first</button>
  <div class="send-row"><button class="btn-block sec" data-close>Close</button><a class="btn-block sec" href="${BASE_URL}/learn/ppo-vs-cash">PPO vs cash</a></div>
</div></dialog>

<!-- DIALOG: BOOKING REQUEST -->
<dialog id="dlg-book" aria-labelledby="bk-title"><div class="dlg-inner">
  <div class="dlg-accent"></div><button class="dlg-close" data-close aria-label="Close">&#215;</button>
  <div class="step active" data-bstep="1">
    <span class="dlg-overline">Request an appointment</span>
    <h2 class="dlg-h" id="bk-title">Request a time at ${esc(name)}</h2>
    <p class="dlg-sub">Tell us where to reach you and we will send your request to the office.</p>
    <div class="bk-summary" id="bk-summary"><span id="bk-summary-text"></span><button class="e" type="button" data-close>Edit</button></div>
    <div class="field-group">
      <div class="field-wrap"><label class="field-label" for="bk-fname">First name</label><input class="field-input" id="bk-fname" type="text" autocomplete="given-name" placeholder="First name" aria-describedby="bkerr-fname"/><span class="field-error" id="bkerr-fname">Please enter your first name.</span></div>
      <div class="field-wrap"><label class="field-label" for="bk-email">Email</label><input class="field-input" id="bk-email" type="email" autocomplete="email" placeholder="you@email.com" aria-describedby="bkerr-email"/><span class="field-error" id="bkerr-email">Please enter a valid email.</span></div>
    </div>
    <div class="field-group full"><div class="field-wrap"><label class="field-label" for="bk-phone">Mobile <span class="opt">optional</span></label><input class="field-input" id="bk-phone" type="tel" autocomplete="tel" placeholder="(optional)"/></div></div>
    <div class="field-group full"><div class="field-wrap"><label class="field-label" for="bk-note">Anything the office should know? <span class="opt">optional</span></label><textarea class="field-textarea" id="bk-note" placeholder="New patient, tooth pain, etc."></textarea></div></div>
    <button class="btn-block primary" id="bk-submit">Request appointment</button>
    <p class="send-caption">No payment details or insurance ID are collected. CoverCapy is not this office's scheduler.</p>
  </div>
  <div class="step" data-bstep="done">
    <div class="done-wrap">
      <div class="done-icon" id="bk-done-icon" style="background:var(--gold-bg);color:var(--gold-500);font-weight:700">!</div>
      <h2 class="done-h" id="bk-done-h">Online booking not set up yet</h2>
      <p class="done-p" id="bk-done-p">${esc(name)} has not turned on instant online booking with CoverCapy. We have prepared your request — open it in your email to send it.</p>
      <div id="bk-send"></div>
    </div>
  </div>
</div></dialog>

<!-- TOAST -->
<div class="toast" id="toast" role="status" aria-live="polite"><span id="toast-msg"></span><button id="toast-close" aria-label="Dismiss">&#215;</button></div>

<script>
/* THEME */
(function(){
var html = document.documentElement;
var ts = document.getElementById('theme-switch');
function applyTheme(t, slow) {
  var dur = slow ? '1.4s' : '0.45s';
  var styleTag = document.getElementById('theme-transition-style');
  if (!styleTag) { styleTag = document.createElement('style'); styleTag.id = 'theme-transition-style'; document.head.appendChild(styleTag); }
  styleTag.textContent = 'html,html *{transition:background ' + dur + ' ease,color ' + dur + ' ease,border-color ' + dur + ' ease,box-shadow ' + dur + ' ease !important}';
  html.setAttribute('data-theme', t);
  ts.setAttribute('data-active', t);
  ts.setAttribute('aria-checked', t === 'jade' ? 'true' : 'false');
  setTimeout(function() { if (styleTag) styleTag.textContent = ''; }, slow ? 1600 : 600);
}
ts.addEventListener('click', function() {
  applyTheme(html.getAttribute('data-theme') === 'gold' ? 'jade' : 'gold', false);
});
ts.addEventListener('keydown', function(e) {
  if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); ts.click(); }
});
window.addEventListener('load', function() {
  setTimeout(function() {
    ts.classList.add('flipping');
    applyTheme('jade', true);
    setTimeout(function() { ts.classList.remove('flipping'); }, 2000);
  }, 900);
});
})();

/* T5 CONFIG — baked from Supabase */
var T5={
  name:${JSON.stringify(name)},
  doctorName:${JSON.stringify(doctorName)},
  officeEmail:${JSON.stringify(officeEmail)},
  website:${JSON.stringify(websiteClean)},
  phone:${JSON.stringify(phoneRaw)},
  phoneTel:${JSON.stringify(phoneTel)},
  address:${JSON.stringify(d.address||'')},
  lat:${d.latitude||0},
  lon:${d.longitude||0},
  slug:${JSON.stringify(dSlug)},
  city:${JSON.stringify(city)},
  market:${JSON.stringify(mkSlug)},
  state:${JSON.stringify(stSlug)},
  accreditationStatus:${accrJS},
  isClaimed:${isClaimed},
  bookingUrl:${bookingUrl ? JSON.stringify(bookingUrl) : 'null'},
  hours:[],
  listedCarriers:${listedCarriersJS},
  services:${servicesJS},
  guides:${guidesJS}
};
var ALL_CARRIERS=["UnitedHealthcare","Aetna","Ameritas","Guardian","Mutual of Omaha","Humana","Delta Dental PPO","Delta Dental Premier","Cigna DPPO","MetLife","Blue Cross Blue Shield Dental","Other PPO"];
var BOOKING_ENDPOINT="https://hfvbeqlefwwjlrbyxpbj.supabase.co/functions/v1/book-request";
var SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhmdmJlcWxlZnd3amxyYnl4cGJqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk2NTk1NzQsImV4cCI6MjA5NTIzNTU3NH0.AIP9Y5rQ4Ey5gbvxZT5jEVfCL7mxEAJX0KfX50JWmDQ";

var T5V7=(function(){
  var state={carrier:null,phonePref:'exclude',reviewBuilt:false,visit:null,dateLabel:null,slot:null};
  var el={};var lastFocus=null;var insExpanded=false;
  function qs(s,r){return (r||document).querySelector(s);}
  function qsa(s,r){return Array.prototype.slice.call((r||document).querySelectorAll(s));}
  function openDialog(d){lastFocus=document.activeElement;d.showModal();document.body.style.overflow='hidden';var f=d.querySelector('button,[href],input,select,textarea');if(f)f.focus();}
  function closeDialog(d){d.close();document.body.style.overflow='';if(lastFocus&&lastFocus.focus)lastFocus.focus();}
  function parseHM(s){var p=s.split(':').map(Number);return p[0]*60+p[1];}
  function todayIdx(){return (new Date().getDay()+6)%7;}
  function fmt(hm){var p=hm.split(':').map(Number),h=p[0],m=p[1],ap=h>=12?'p.m.':'a.m.';h=h%12||12;return h+(m?':'+String(m).padStart(2,'0'):'') +' '+ap;}
  function hasHours(){return Array.isArray(T5.hours)&&T5.hours.some(function(h){return h.o;});}
  function openState(){var i=todayIdx(),h=T5.hours[i],now=new Date(),mins=now.getHours()*60+now.getMinutes();if(h&&h.o&&mins>=parseHM(h.o)&&mins<parseHM(h.c))return{open:true,text:'Open now',next:'Closes '+fmt(h.c)};for(var k=0;k<7;k++){var j=(i+k)%7,hh=T5.hours[j];if(hh&&hh.o&&(k>0||mins<parseHM(hh.o)))return{open:false,text:'Closed',next:(k===0?'Opens '+fmt(hh.o):'Opens '+hh.d+' '+fmt(hh.o))};}return{open:false,text:'Closed',next:''};}
  function renderOpen(){
    var pill=qs('#open-pill'),rc=qs('#rc-open');
    if(!hasHours()){if(pill)pill.style.display='none';if(rc)rc.style.display='none';return;}
    var s=openState();
    if(pill){pill.style.display='';pill.className='open-pill '+(s.open?'open':'closed');pill.innerHTML='<span class="open-dot"></span>'+s.text+(s.next?' · '+s.next:'');}
    if(rc){rc.style.display='';rc.innerHTML='<span style="width:7px;height:7px;border-radius:50%;background:'+(s.open?'#2C7A52':'#888')+';display:inline-block;margin-right:6px"></span>'+s.text+(s.next?' · '+s.next:'');}
  }
  var DEFAULT_HOURS=[{d:'Mon',o:'09:00',c:'17:00'},{d:'Tue',o:'09:00',c:'17:00'},{d:'Wed',o:'09:00',c:'17:00'},{d:'Thu',o:'09:00',c:'17:00'},{d:'Fri',o:'09:00',c:'17:00'},{d:'Sat',o:null,c:null},{d:'Sun',o:null,c:null}];
  function renderHours(){
    var confirmed=hasHours(),hrs=confirmed?T5.hours:DEFAULT_HOURS,i=todayIdx();
    var rows=hrs.map(function(h,k){return '<div class="hours-row'+(k===i?' today':'')+'"><span class="h-day">'+h.d+'</span><span class="'+(h.o?'':'h-closed')+'">'+(h.o?fmt(h.o)+' – '+fmt(h.c):'Closed')+'</span></div>';}).join('');
    if(!confirmed)rows+='<div class="hours-disclaimer">Hours not confirmed by this office. A standard schedule is shown as an estimate. Please call before visiting.</div>';
    qs('#hours-table').innerHTML=rows;
  }
  function renderCarrierRows(){
    var lc=T5.listedCarriers;
    qs('#carrier-rows').innerHTML=lc.map(function(c,i){return '<div class="carrier-row'+(i>=2?' hidden':'')+'"><div><div class="carrier-name">'+c+'</div><div class="carrier-status"><span class="status-dot"></span>Publicly reported</div></div><button class="carrier-check" data-open="insurance">Check my plan</button></div>';}).join('');
    var tog=qs('#ins-toggle');if(tog)tog.style.display=lc.length>2?'block':'none';
  }
  function toggleIns(){
    insExpanded=!insExpanded;
    qsa('.carrier-row').forEach(function(r,i){if(i>=2)r.classList.toggle('hidden',!insExpanded);});
    var tog=qs('#ins-toggle');if(tog)tog.textContent=insExpanded?'Show fewer':'Show all '+T5.listedCarriers.length+' carriers';
  }
  function renderTreatments(){
    var sv=T5.services||[];
    qs('#proc-pills').innerHTML=sv.length?sv.map(function(s){return '<li class="pill">'+s+'</li>';}).join(''):'<li class="pill" style="color:var(--ink-500)">Services not listed</li>';
  }
  function renderGuides(){
    qs('#guide-grid').innerHTML=T5.guides.map(function(g){return '<a class="guide-link" href="'+g[1]+'"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4h9l3 3v13H6z"/><path d="M15 4v3h3"/></svg>'+g[0]+'</a>';}).join('');
  }
  function applyMembership(){
    var acc=(T5.accreditationStatus||'').trim(),accredited=!!acc;
    var star='<svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.3 6.9.7-5.1 4.6 1.4 6.7L12 17.8 5.9 20.3l1.4-6.7L2.2 9l6.9-.7z"/></svg>';
    var b=qs('#accr-badge');
    if(b){if(accredited){b.className='accr-badge';b.innerHTML=star+acc;}else{b.className='unclaimed-chip';b.textContent=T5.isClaimed?'Listed':'Unclaimed';}}
    var rb=qs('#rc-badge');
    if(rb){if(accredited){rb.style.display='';rb.innerHTML=star.replace('width="11" height="11"','width="10" height="10"')+acc;}else{rb.style.display='none';}}
    var cb=qs('#claim-block'),on=qs('#owner-note'),hc=qs('#hero-claim');
    if(cb)cb.style.display=accredited?'none':'';
    if(on)on.style.display=accredited?'block':'none';
    if(hc)hc.style.display=accredited?'none':'block';
    renderBooking();
  }
  var SLOTS=['9:00 AM','11:00 AM','2:00 PM','4:00 PM'];
  var DOW=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'],MON=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  function dateLabel(d){return DOW[d.getDay()]+', '+MON[d.getMonth()]+' '+d.getDate();}
  function renderBooking(){
    var live=!!T5.bookingUrl,accredited=!!(T5.accreditationStatus||'').trim();
    var w=qs('#bookwidget');if(!w)return;w.dataset.state=live?'live':'request';
    qs('#bw-badge').textContent=live?'Book online':'Request';
    var visits=['New patient','Cleaning','Consult','Emergency'];
    qs('#bw-chips').innerHTML=visits.map(function(v,i){return '<button class="bw-chip" type="button" aria-pressed="'+(i===0?'true':'false')+'">'+v+'</button>';}).join('');
    state.visit=visits[0];
    var dates='',now=new Date();
    for(var i=0;i<7;i++){var d=new Date(now);d.setDate(now.getDate()+i);dates+='<button class="bw-date" type="button" aria-pressed="'+(i===0?'true':'false')+'" data-label="'+dateLabel(d)+'"><span class="dow">'+DOW[d.getDay()]+'</span><span class="dn">'+d.getDate()+'</span></button>';}
    qs('#bw-dates').innerHTML=dates;state.dateLabel=dateLabel(now);
    qs('#bw-slots').innerHTML=SLOTS.map(function(s,i){return '<button class="bw-slot" type="button" aria-pressed="'+(i===0?'true':'false')+'">'+s+'</button>';}).join('');state.slot=SLOTS[0];
    qsa('.bw-chip').forEach(function(b){b.addEventListener('click',function(){qsa('.bw-chip').forEach(function(x){x.setAttribute('aria-pressed','false');});b.setAttribute('aria-pressed','true');state.visit=b.textContent.trim();});});
    qsa('.bw-date').forEach(function(b){b.addEventListener('click',function(){qsa('.bw-date').forEach(function(x){x.setAttribute('aria-pressed','false');});b.setAttribute('aria-pressed','true');state.dateLabel=b.dataset.label;});});
    qsa('.bw-slot').forEach(function(b){b.addEventListener('click',function(){qsa('.bw-slot').forEach(function(x){x.setAttribute('aria-pressed','false');});b.setAttribute('aria-pressed','true');state.slot=b.textContent.trim();});});
    var cta=qs('#bw-cta');cta.innerHTML='';
    if(live){
      var a=document.createElement('a');a.className='btn-block primary';a.textContent='Book online';a.href=T5.bookingUrl;a.target='_blank';a.rel='noopener';cta.appendChild(a);
    }else{
      var req=document.createElement('button');req.className='btn-block primary';req.textContent='Request this appointment';req.addEventListener('click',openBook);cta.appendChild(req);
      var row=document.createElement('div');row.className='send-row';
      var call=document.createElement('a');call.className='btn-block sec';call.textContent='Call the office';call.href=T5.phoneTel;row.appendChild(call);cta.appendChild(row);
      qs('#bw-foot').textContent='Pick a day and preferred time, then send your request. Nothing is confirmed until the office replies.';
      qs('#bw-claim').style.display=accredited?'none':'block';
    }
  }
  function openBook(){
    qs('#bk-summary-text').textContent=state.visit+' · '+state.dateLabel+' · '+state.slot;
    qsa('.step',qs('#dlg-book')).forEach(function(s){s.classList.toggle('active',s.dataset.bstep==='1');});
    openDialog(qs('#dlg-book'));
  }
  function bkValidate(show){var f=qs('#bk-fname').value.trim(),e=qs('#bk-email').value.trim(),fo=f.length>0,eo=validEmail(e);if(show){qs('#bk-fname').setAttribute('aria-invalid',fo?'false':'true');qs('#bkerr-fname').classList.toggle('show',!fo);qs('#bk-email').setAttribute('aria-invalid',eo?'false':'true');qs('#bkerr-email').classList.toggle('show',!eo);}return fo&&eo;}
  function bkMessage(){var f=qs('#bk-fname').value.trim(),e=qs('#bk-email').value.trim(),p=qs('#bk-phone').value.trim(),n=qs('#bk-note').value.trim();return 'New appointment request via CoverCapy\\n\\nOffice: '+T5.name+'\\nAddress: '+T5.address+'\\nOffice phone: '+T5.phone+'\\n\\nPatient: '+f+'\\nEmail: '+e+'\\nPhone: '+(p||'—')+'\\n\\nVisit type: '+state.visit+'\\nPreferred day: '+state.dateLabel+'\\nPreferred time: '+state.slot+'\\nNotes: '+(n||'—');}
  function bkRenderDone(sent){
    var icon=qs('#bk-done-icon'),zone=qs('#bk-send');zone.innerHTML='';
    if(sent){icon.textContent='\\u2713';icon.style.background='var(--mint-100)';icon.style.color='var(--teal-650)';qs('#bk-done-h').textContent='Request received';qs('#bk-done-p').textContent='Thanks. This office has not turned on instant online booking yet, so the CoverCapy team will follow up to confirm a time.';var close=document.createElement('button');close.className='btn-block primary';close.type='button';close.textContent='Done';close.addEventListener('click',function(){closeDialog(qs('#dlg-book'));});zone.appendChild(close);}
    else{icon.textContent='!';icon.style.background='var(--gold-bg)';icon.style.color='var(--gold-500)';qs('#bk-done-h').textContent='Could not submit';qs('#bk-done-p').textContent='Something went wrong. Please try again or call the office directly.';var call2=document.createElement('a');call2.className='btn-block primary';call2.href=T5.phoneTel;call2.textContent='Call the office';zone.appendChild(call2);}
  }
  async function bkSubmit(){if(!bkValidate(true))return;
    var payload={office:T5.slug,officeName:T5.name,address:T5.address,officePhone:T5.phone,name:qs('#bk-fname').value.trim(),email:qs('#bk-email').value.trim(),phone:qs('#bk-phone').value.trim(),visit:state.visit,day:state.dateLabel,time:state.slot,note:qs('#bk-note').value.trim()};
    var sent=false;
    try{var r=await fetch(BOOKING_ENDPOINT,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});sent=r.ok;}catch(e){sent=false;}
    bkRenderDone(sent);qsa('.step',qs('#dlg-book')).forEach(function(s){s.classList.toggle('active',s.dataset.bstep==='done');});
  }
  function buildCarriers(){
    var mk=function(c){var b=document.createElement('button');b.type='button';b.className='ct-btn';b.setAttribute('aria-pressed','false');b.innerHTML='<span class="ck" aria-hidden="true">&#10003;</span><span>'+c+'</span>';b.addEventListener('click',function(){selectCarrier(b,c);});return b;};
    T5.listedCarriers.forEach(function(c){qs('#carrier-listed').appendChild(mk(c));});
    ALL_CARRIERS.filter(function(c){return !T5.listedCarriers.some(function(l){return c.startsWith(l)||l.startsWith(c);});}).forEach(function(c){qs('#carrier-other').appendChild(mk(c));});
  }
  function selectCarrier(btn,c){qsa('.ct-btn').forEach(function(b){b.setAttribute('aria-pressed','false');});btn.setAttribute('aria-pressed','true');state.carrier=c;qs('#metlife-note').classList.toggle('show',c==='MetLife');qs('#ins-next').disabled=false;}
  function validEmail(v){return /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(v);}
  function validateStep2(show){var f=el.fname.value.trim(),e=el.email.value.trim(),fo=f.length>0,eo=validEmail(e);if(show){el.fname.setAttribute('aria-invalid',fo?'false':'true');qs('#err-fname').classList.toggle('show',!fo);el.email.setAttribute('aria-invalid',eo?'false':'true');qs('#err-email').classList.toggle('show',!eo);}return fo&&eo;}
  function buildMessage(){var f=el.fname.value.trim()||'[your name]',c=state.carrier||'my dental plan';var m='Hello '+T5.name+',\\n\\nI found your practice through CoverCapy and would like to confirm whether you currently accept my '+c+' dental plan.\\n\\nPlease let me know whether the office is accepting new patients and what information you need to confirm coverage.\\n\\nThank you,\\n'+f;if(state.phonePref==='include'){var p=el.phone.value.trim(),e=el.email.value.trim();m+='\\n\\nYou can reach me directly:';if(e)m+='\\nEmail: '+e;if(p)m+='\\nPhone: '+p;}el.msgBody.value=m;qs('#msg-dest').textContent=T5.officeEmail;}
  function renderSendZone(){var z=qs('#send-zone');z.innerHTML='';var mail=document.createElement('button');mail.type='button';mail.className='btn-block primary';mail.textContent='Open prepared email';mail.addEventListener('click',function(){buildMessage();var s=encodeURIComponent('Coverage question via CoverCapy'),b=encodeURIComponent(el.msgBody.value);window.location.href='mailto:'+T5.officeEmail+'?subject='+s+'&body='+b;showDone();});z.appendChild(mail);var row=document.createElement('div');row.className='send-row';var copy=document.createElement('button');copy.type='button';copy.className='btn-block sec';copy.textContent='Copy message';copy.addEventListener('click',function(){buildMessage();navigator.clipboard.writeText(el.msgBody.value).then(function(){copy.textContent='Copied';setTimeout(function(){copy.textContent='Copy message';},2000);}).catch(function(){copy.textContent='Press Ctrl/Cmd+C';});});row.appendChild(copy);z.appendChild(row);}
  function showDone(){qsa('.step',el.dlgIns).forEach(function(s){s.classList.toggle('active',s.dataset.step==='done');});}
  function toast(msg){qs('#toast-msg').textContent=msg;qs('#toast').classList.add('show');clearTimeout(window._tt);window._tt=setTimeout(function(){qs('#toast').classList.remove('show');},5000);}
  function initScroll(){
    var links=qsa('.sn-links a');var secs=links.map(function(a){return qs(a.getAttribute('href'));}).filter(Boolean);
    var obs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){var id='#'+e.target.id;links.forEach(function(a){a.classList.toggle('active',a.getAttribute('href')===id);});}});},{rootMargin:'-90px 0px -68% 0px'});
    secs.forEach(function(s){obs.observe(s);});
    var anchor=qs('.crumb');if(anchor){var sObs=new IntersectionObserver(function(es){es.forEach(function(e){qs('#sticky-bar').classList.toggle('show',!e.isIntersecting);});},{rootMargin:'0px'});sObs.observe(anchor);}
  }
  async function refreshMembership(){
    var q=new URLSearchParams(location.search);if(q.get('acc')||q.get('tier'))return;
    try{var r=await fetch('https://hfvbeqlefwwjlrbyxpbj.supabase.co/rest/v1/dentists?slug=eq.'+T5.slug+'&select=accreditation_status,is_claimed,booking_url&limit=1',{headers:{apikey:SUPABASE_ANON_KEY,Authorization:'Bearer '+SUPABASE_ANON_KEY}});if(r.ok){var j=await r.json();if(j&&j.length){T5.accreditationStatus=j[0].accreditation_status||null;T5.isClaimed=!!j[0].is_claimed;if(j[0].booking_url)T5.bookingUrl=j[0].booking_url;applyMembership();}}}catch(e){}
  }
  function init(){
    el.dlgIns=qs('#dlg-insurance');el.fname=qs('#v-fname');el.email=qs('#v-email');el.phone=qs('#v-phone');el.msgBody=qs('#msg-body');
    renderOpen();renderHours();renderCarrierRows();renderTreatments();renderGuides();buildCarriers();renderSendZone();applyMembership();initScroll();
    setInterval(renderOpen,60000);
    qs('#ins-toggle').addEventListener('click',toggleIns);
    qsa('[data-open]').forEach(function(b){b.addEventListener('click',function(){var k=b.dataset.open;if(k==='insurance'){qsa('.step',el.dlgIns).forEach(function(s){s.classList.toggle('active',s.dataset.step==='1');});openDialog(el.dlgIns);}else if(k==='cost'){openDialog(qs('#dlg-cost'));}});});
    qsa('[data-cost]').forEach(function(b){b.addEventListener('click',function(){qs('#cost-title').textContent='Estimate '+b.dataset.cost.toLowerCase()+' cost';openDialog(qs('#dlg-cost'));});});
    qsa('[data-close]').forEach(function(b){b.addEventListener('click',function(){closeDialog(b.closest('dialog'));});});
    qsa('[data-ext-site]').forEach(function(b){b.addEventListener('click',function(){window.open(T5.website,'_blank','noopener');toast('The official practice website opened in a new tab.');});});
    qs('#toast-close').addEventListener('click',function(){qs('#toast').classList.remove('show');});
    qs('#ins-next').addEventListener('click',function(){buildMessage();qsa('.step',el.dlgIns).forEach(function(s){s.classList.toggle('active',s.dataset.step==='2');});el.fname.focus();});
    qs('[data-back]',el.dlgIns).addEventListener('click',function(){qsa('.step',el.dlgIns).forEach(function(s){s.classList.toggle('active',s.dataset.step==='1');});});
    el.fname.addEventListener('blur',function(){validateStep2(true);});el.email.addEventListener('blur',function(){validateStep2(true);});
    qsa('input[name="phonepref"]').forEach(function(r){r.addEventListener('change',function(){state.phonePref=qs('input[name="phonepref"]:checked').value;if(state.reviewBuilt)buildMessage();});});
    qs('#review-toggle').addEventListener('click',function(e){validateStep2(true);var b=qs('#review-body'),o=b.classList.toggle('show');e.currentTarget.setAttribute('aria-expanded',o?'true':'false');if(o){buildMessage();state.reviewBuilt=true;}});
    qs('#bk-submit').addEventListener('click',bkSubmit);
    qs('#bk-fname').addEventListener('blur',function(){bkValidate(true);});qs('#bk-email').addEventListener('blur',function(){bkValidate(true);});
    refreshMembership();
  }
  document.addEventListener('DOMContentLoaded',init);
  return{init:init};
})();
<\/script>

<!-- SUPABASE NEARBY -->
<script>
(function(){
  var SUPA='https://hfvbeqlefwwjlrbyxpbj.supabase.co',KEY=SUPABASE_ANON_KEY;
  var lat=T5.lat,lon=T5.lon,THIS_SLUG=T5.slug,THIS_CITY=T5.city,MARKET=T5.market,STATE=T5.state;
  var marketName=MARKET.replace(/-/g,' ').replace(/\\b\\w/g,function(c){return c.toUpperCase();});
  function hav(a,b,c,d){var R=3958.8,p=Math.PI/180,dLat=(c-a)*p,dLon=(d-b)*p,x=Math.pow(Math.sin(dLat/2),2)+Math.cos(a*p)*Math.cos(c*p)*Math.pow(Math.sin(dLon/2),2);return R*2*Math.atan2(Math.sqrt(x),Math.sqrt(1-x));}
  function sg(s){return(s||'').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');}
  function cardDir(a,b,c,d){var ang=Math.atan2(d-b,c-a)*180/Math.PI;return['north','northeast','east','southeast','south','southwest','west','northwest'][Math.round(((ang+360)%360)/45)%8];}
  function tierRank(acc){acc=(acc||'').toLowerCase();return acc==='platinum elite'?0:acc==='capy accredited'?1:acc==='verified'?2:3;}
  function tierTag(acc){if(!acc)return'';var a=acc.toLowerCase(),bg,fg,bd;if(a==='platinum elite'){bg='var(--gold-bg)';fg='var(--gold-500)';bd='rgba(184,146,79,.45)';}else if(a==='capy accredited'){bg='var(--mint-100)';fg='#2C7A52';bd='rgba(91,224,160,.45)';}else return'';return'<span class="ncard-badge" style="background:'+bg+';color:'+fg+';border:1px solid '+bd+'">'+acc+'</span>';}
  function ratingOf(d){var w=parseFloat(d.weighted_rating||0);if(w>0)return w;var g=parseFloat(d.google_rating||0);return g>0?g:0;}
  function pu(d){return'/dental/'+STATE+'/'+MARKET+'/'+sg(d.city||'')+'/'+(d.slug||sg(d.name||''))+'/';} 
  async function load(){
    var grid=document.getElementById('nearby-grid');var bbox=0.32;
    var url=SUPA+'/rest/v1/dentists?select=name,slug,city,state,latitude,longitude,weighted_rating,google_rating,google_review_count,accreditation_status&latitude=gte.'+(lat-bbox)+'&latitude=lte.'+(lat+bbox)+'&longitude=gte.'+(lon-bbox)+'&longitude=lte.'+(lon+bbox)+'&slug=neq.'+THIS_SLUG+'&limit=120';
    try{
      var res=await fetch(url,{headers:{apikey:KEY,Authorization:'Bearer '+KEY}});if(!res.ok)throw 0;
      var raw=await res.json();
      var all=raw.filter(function(d){return d.latitude&&d.longitude;}).map(function(d){var la=+d.latitude,lo=+d.longitude;return Object.assign({},d,{dist:hav(lat,lon,la,lo),dir:cardDir(lat,lon,la,lo),_r:Math.random()});});
      all.sort(function(a,b){return tierRank(a.accreditation_status)-tierRank(b.accreditation_status)||a._r-b._r;});
      if(!all.length){grid.innerHTML='<p style="color:var(--ink-500);font-size:13.5px;grid-column:1/-1">No nearby offices found.</p>';return;}
      grid.innerHTML=all.slice(0,8).map(function(d){var r=ratingOf(d);var st=r>0?'\\u2605 '+r.toFixed(1)+(d.google_review_count?' · '+d.google_review_count+' reviews':''):'';return'<a class="ncard" href="'+pu(d)+'"><div class="ncard-name">'+d.name+'</div><div class="ncard-loc">'+(d.city||'')+' · '+d.dist.toFixed(1)+' mi '+d.dir+'</div>'+(st?'<div class="ncard-meta">'+st+'</div>':'')+tierTag(d.accreditation_status)+'</a>';}).join('');
      var geo=all.slice(0,8),cn=[];geo.forEach(function(d){if(d.city&&cn.indexOf(d.city)===-1)cn.push(d.city);});
      document.getElementById('geo-heading').textContent='PPO dentists near '+T5.name+' in '+marketName;
      document.getElementById('geo-prose').innerHTML='<p>'+T5.name+' is a PPO dental office in '+THIS_CITY+'. Browse other PPO dentists in <a href="/dental/'+STATE+'/'+MARKET+'/'+sg(THIS_CITY)+'/">'+THIS_CITY+'</a> or explore the full <a href="/dental/'+STATE+'/'+MARKET+'/">'+marketName+' PPO network</a> on CoverCapy.</p>';
      document.getElementById('geo-offices').innerHTML=geo.map(function(d){var r=ratingOf(d);var st=r>0?'<span style="color:var(--teal-650);font-weight:600;font-size:12px;margin-right:4px">\\u2605 '+r.toFixed(1)+'</span>':'';return'<div class="geo-office"><div class="geo-dist">'+d.dist.toFixed(1)+'<span>mi</span></div><div><div class="geo-name">'+st+'<a href="'+pu(d)+'">'+d.name+'</a> '+tierTag(d.accreditation_status)+'</div><div class="geo-desc"><a href="'+pu(d)+'">'+d.name+'</a> is a dental office in '+d.city+', about '+d.dist.toFixed(1)+' miles '+d.dir+' of '+THIS_CITY+'.</div><a class="geo-dir" href="/dental/'+STATE+'/'+MARKET+'/'+sg(d.city)+'/">More PPO dentists in '+d.city+'</a></div></div>';}).join('');
      var cityNavItems=[{label:'This city',name:THIS_CITY,href:'/dental/'+STATE+'/'+MARKET+'/'+sg(THIS_CITY)+'/',active:true}].concat(cn.slice(0,5).filter(function(c){return c!==THIS_CITY;}).map(function(c){var match=geo.find(function(d){return d.city===c;});var dist=match?match.dist.toFixed(1)+' MI':'';return{label:dist,name:c,href:'/dental/'+STATE+'/'+MARKET+'/'+sg(c)+'/',active:false};})).concat([{label:'All',name:marketName,href:'/dental/'+STATE+'/'+MARKET+'/',active:false}]);
      var navHtml='<div class="city-nav" aria-label="Browse PPO dentists by city"><div class="city-nav-fade-l"></div><div class="city-nav-fade-r"></div><div class="city-nav-track">'+cityNavItems.map(function(item){return'<a class="city-nav-item'+(item.active?' active':'')+'" href="'+item.href+'"><span class="cni-label">'+item.label+'</span><span class="cni-name">'+item.name+'</span><span class="cni-count"><span class="cni-arrow">&#8594;</span></span></a>';}).join('')+'</div></div>';
      var tier=document.getElementById('geo-tier');tier.outerHTML=navHtml;document.getElementById('geo-block').style.display='';
    }catch(e){grid.innerHTML='<p style="color:var(--ink-500);font-size:13.5px;grid-column:1/-1">Nearby offices unavailable right now.</p>';}
  }
  if(lat&&lon)load();else grid.innerHTML='<p style="color:var(--ink-500);font-size:13.5px;grid-column:1/-1">Location data unavailable for nearby search.</p>';
  var grid=document.getElementById('nearby-grid');
})();
<\/script>`;

  // ──────────────────────────────────────────────────────────────
  // END NEW V7 BODY — old body removed
  // ──────────────────────────────────────────────────────────────


  const geoPos = (d.latitude && d.longitude) ? `${d.latitude};${d.longitude}` : null;
  return pageShell({ title, desc, canonical, geo: { region:`US-${abbr}`, placename:`${city}, ${state}`, position: geoPos }, schemas, body, footerCta: '' });
}

/* ── File writer ──────────────────────────────────────────── */

function writeFile(relPath, content) {
  if (DRY_RUN) {
    console.log(`  [DRY-RUN] ${relPath} (${Math.round(content.length/1024)}KB)`);
    return;
  }
  const full = path.join(OUT_DIR, relPath);
  fs.mkdirSync(path.dirname(full), { recursive: true });
  fs.writeFileSync(full, content, 'utf8');
  console.log(`  ✓ ${relPath} (${Math.round(content.length/1024)}KB)`);
}

/* ── Local area hub page (T4b) ───────────────────────────── */

function buildLocalAreaHub(localArea, state, parentMarket, dentists, cities, plans) {
  const abbr      = stateAbbr(state);
  const stSlug    = stateSlug(state);
  const laSlug    = slugify(localArea);
  const mkSlug    = slugify(parentMarket.seo_area || parentMarket.market_area);
  const canonical = `${BASE_URL}/dental/${stSlug}/${laSlug}/`;
  const office_count = dentists.length;
  const ratings   = dentists.map(d => parseFloat(d.weighted_rating)).filter(v => v > 0);
  const avg_rating = ratings.length ? (ratings.reduce((a,b)=>a+b,0)/ratings.length).toFixed(1) : null;
  const total_reviews = dentists.reduce((s,d) => s+(parseInt(d.google_review_count)||0), 0);
  const today     = new Date().toISOString().slice(0,10);
  const monthYear = new Date().toLocaleDateString('en-US',{month:'long',year:'numeric'});

  // Single-city wrapper detection (brief: Coronado Island case). When a local
  // area resolves to exactly one real child city, canonical points at the city
  // page so the two near-identical URLs do not self-cannibalize.
  const childCities = cities.filter(c => c && c.city);
  const isSingleCityWrapper = childCities.length === 1;
  const canonicalTarget = isSingleCityWrapper
    ? `${BASE_URL}/dental/${stSlug}/${mkSlug}/${slugify(childCities[0].city)}/`
    : canonical;

  const laCarriers = cityCarrierLabels(dentists);
  // SEO title/meta (template brief): data-driven, no em-dash, exact count.
  let title = `PPO Dentists in ${localArea}, ${abbr} | ${plural(office_count, 'In-Network Office', 'In-Network Offices')}`;
  if (title.length > 60) title = `PPO Dentists in ${localArea}, ${abbr} (${office_count})`;
  const laCarrierSentence = laCarriers.length
    ? ` Check ${laCarriers.slice(0, 3).join(', ')} acceptance and`
    : ' Check carrier acceptance and';
  let desc = `Compare ${plural(office_count, 'PPO-participating dentist', 'PPO-participating dentists')} in ${localArea}, ${abbr}.${laCarrierSentence} verify your plan free before booking.`;
  if (desc.length > 155) desc = `Compare ${plural(office_count, 'PPO-participating dentist', 'PPO-participating dentists')} in ${localArea}, ${abbr}. Verify your plan free before booking.`;

  const schemas = [{
    '@context':'https://schema.org','@graph':[
      {'@type':'Organization','@id':`${BASE_URL}/#organization`,'name':'CoverCapy','url':BASE_URL},
      {'@type':'MedicalWebPage','@id':`${canonical}#webpage`,'url':canonical,'name':title,
        'description':desc,'inLanguage':'en-US','datePublished':today,'dateModified':today,
        'isPartOf':{'@id':`${BASE_URL}/#website`},'breadcrumb':{'@id':`${canonical}#breadcrumb`}},
      {'@type':'Place','@id':`${canonical}#place`,'name':`${localArea}, ${state}`,
        'containedInPlace':{'@type':'City','name':parentMarket.market_area}},
      {'@type':'BreadcrumbList','@id':`${canonical}#breadcrumb`,'itemListElement':[
        {'@type':'ListItem','position':1,'name':'CoverCapy','item':`${BASE_URL}/`},
        {'@type':'ListItem','position':2,'name':`${state} Dentists`,'item':`${BASE_URL}/dental/${stSlug}/`},
        {'@type':'ListItem','position':3,'name':`${parentMarket.market_area} PPO Dentists`,'item':`${BASE_URL}/dental/${stSlug}/${mkSlug}/`},
        {'@type':'ListItem','position':4,'name':`${localArea} PPO Dentists`,'item':canonical},
      ]},
      {'@type':'ItemList','@id':`${canonical}#dentist-list`,'name':`PPO Dentists in ${localArea}`,
        'itemListElement':dentists.slice(0,15).map((d,i)=>({'@type':'ListItem','position':i+1,'item':{
          '@type':'Dentist','name':d.name,
          '@id':`${BASE_URL}/dental/${stSlug}/${mkSlug}/${slugify(d.city||'')}/${d.slug||slugify(d.name)}/`,
          ...(d.address?{'address':d.address}:{}),
          ...(d.phone?{'telephone':d.phone}:{}),
        }}))},
    ]
  }];

  const cityPills = cities.map(c =>
    `<a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/${slugify(c.city)}" class="city-pill-link">${esc(c.city)} <span class="city-pill-count">${c.office_count}</span></a>`
  ).join('');

  const cityRail = cities.slice(0,10).map(c =>
    `<div class="rail-city-row"><a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/${slugify(c.city)}">${esc(c.city)}</a><span class="rail-city-count">${c.office_count}</span></div>`
  ).join('');

  const cards      = dentists.slice(0,15).map((d,i) => dentistCard(d, stSlug, mkSlug, i===0)).join('\n');
  const carrierCard = carrierRailCard(dentists, office_count);
  const planRows   = plans.slice(0,3).map(p=>`<div class="plan-row">
  <div><div class="plan-name">${esc(p.name)}</div><div class="plan-carrier">${esc(p.carrier)}</div>${p.timing?`<div class="plan-timing">${esc(p.timing)}</div>`:''}</div>
  <div class="plan-price">$${p.monthly}<span>/mo</span></div>
</div>`).join('');

  // Only render a rating pill when real, sourced per-office data exists.
  const laRatedOffices = dentists.filter(d => parseFloat(d.weighted_rating) > 0 && parseInt(d.google_review_count) > 0);
  const ratingPill = (avg_rating && parseFloat(avg_rating) > 0 && laRatedOffices.length > 0)
    ? `<span class="stat-pill">${parseFloat(avg_rating).toFixed(1)}★ avg Google rating across ${plural(laRatedOffices.length, 'listed office', 'listed offices')}</span>` : '';

  const body = `
<div class="alert-bar">No insurance? PPO plans from $30/month. <a href="${BASE_URL}/compare-ppo-dental-plans">Compare individual PPO plans, effective dates and waiting periods.</a></div>

<main id="main-content" data-page-type="local-area-hub" data-local-area="${esc(localArea)}" data-market="${esc(parentMarket.market_area)}">
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="wrap">
      <ol class="breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="${BASE_URL}/" itemprop="item"><span itemprop="name">CoverCapy</span></a>
          <meta itemprop="position" content="1" />
        </li>
        <li><span aria-hidden="true"> / </span></li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="${BASE_URL}/dental/${stSlug}/" itemprop="item"><span itemprop="name">${esc(state)} Dentists</span></a>
          <meta itemprop="position" content="2" />
        </li>
        <li><span aria-hidden="true"> / </span></li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/" itemprop="item"><span itemprop="name">${esc(parentMarket.market_area)}</span></a>
          <meta itemprop="position" content="3" />
        </li>
        <li><span aria-hidden="true"> / </span></li>
        <li><span>${esc(localArea)}</span></li>
      </ol>
    </div>
  </nav>

  <section class="hero">
    <div class="wrap">
      <div class="hero-overline">PPO Dentist Directory · ${esc(localArea)}, ${abbr}</div>
      <h1 class="hero-headline">PPO Dentists in ${esc(localArea)}, ${abbr}</h1>
      <p class="hero-subheadline about-prose">PPO-participating offices in ${esc(localArea)}, serving the ${esc(parentMarket.market_area)} area. Check your plan before you book.</p>
      <div class="stat-pills-row">
        <span class="stat-pill">${plural(office_count, 'office', 'offices')} listed, updated ${monthYear}</span>
        ${childCities.length > 1 ? `<span class="stat-pill">${plural(childCities.length, 'city', 'cities')} covered</span>` : ''}
        ${ratingPill}
      </div>
      <div class="hero-ctas">
        <a href="${BASE_URL}/find-my-dentist" class="btn-hero-primary">Verify my PPO, free</a>
        <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-hero-secondary">No insurance? Plans from $30/mo</a>
      </div>
    </div>
  </section>

  <section class="about-prose-section">
    <div class="wrap">
      <div class="layout">
        <div class="main-col">
          <div class="about-prose">
            <p>${esc(cityLocalContext(localArea, parentMarket.market_area, state, dentists, childCities))}</p>
            ${isSingleCityWrapper ? `<p>Most listings here are in <a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/${slugify(childCities[0].city)}/" style="color:var(--skytext);text-decoration:underline;font-weight:600">${esc(childCities[0].city)}</a>. See that city page for the full ${esc(childCities[0].city)} directory.</p>` : ''}
          </div>

          ${cityCarrierSection(localArea, dentists, stSlug, mkSlug)}

          <div class="verify-steps">
            <h2>How to verify your plan in ${esc(localArea)}</h2>
            <ol class="verify-steps-list">
              ${cityVerifySteps(localArea).map(s => `<li>${esc(s)}</li>`).join('\n              ')}
            </ol>
          </div>

          ${childCities.length > 1 ? `<div class="city-strip-inline">
            <h2>PPO Dentists by City in ${esc(localArea)}</h2>
            <div class="city-pills-grid">${cityPills}</div>
          </div>` : ''}

          <div class="dentist-list-section" id="dentist-list">
            <h2 class="dentist-list-heading">PPO Dental Offices in ${esc(localArea)} <span class="list-meta">${plural(office_count, 'office', 'offices')} as of ${monthYear}</span></h2>
            ${cards}
            ${office_count > 15 ? `<div class="more-link">Showing top 15 of ${plural(office_count, 'office', 'offices')}. <a href="${BASE_URL}/find-my-dentist?q=${encodeURIComponent(localArea)}">Browse all on the map</a></div>` : ''}
          </div>

          <p class="provenance-note">How this list is built: offices shown are recorded as PPO-participating. Names, addresses, and any ratings reflect public Google data as of ${monthYear}. Verification is free and confirmed with the office at booking. Listed networks are a starting point, not a guarantee for your specific plan tier.</p>

          <div class="concierge-cta">
            <div class="wrap">
              <h2>Check your plan before you book.</h2>
              <ul class="cta-benefits">
                <li>See each office's listed PPO carriers and ratings</li>
                <li>New-patient availability: confirm directly with the office</li>
                <li>Listed PPO carriers shown per office, a starting point, not a guarantee</li>
              </ul>
              <a href="${BASE_URL}/find-my-dentist" class="btn-concierge-primary">Avoid the surprise bill, verify free</a>
              <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-concierge-secondary">Plans from $30/mo</a>
            </div>
          </div>
        </div>

        <aside class="rail" aria-label="Plan and location information">
          <div class="cta-box">
            <h3>No insurance? We fix that.</h3>
            <p>PPO plans from $30/month. Next-day activation available.</p>
            <a href="${BASE_URL}/compare-ppo-dental-plans" class="cta-btn">Browse PPO Plans</a>
            <a href="${BASE_URL}/find-my-dentist" class="cta-btn-sec">Find In-Network Dentist</a>
          </div>

          <div class="rail-card">
            <div class="rail-head">PPO Plans Available</div>
            ${planRows}
            <div style="padding:12px 16px"><a href="${BASE_URL}/compare-ppo-dental-plans" style="font-size:13px;color:var(--skytext);text-decoration:underline;font-weight:600">Compare all plans</a></div>
          </div>

          ${carrierCard}

          ${childCities.length > 1 ? `<div class="rail-card">
            <div class="rail-head">Cities in ${esc(localArea)}</div>
            ${cityRail}
            <div style="padding:10px 16px">
              <a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/" style="font-size:13px;color:var(--skytext);font-weight:600">All ${esc(parentMarket.market_area)} PPO dentists</a>
            </div>
          </div>` : `<div class="rail-card">
            <div class="rail-head">More in ${esc(parentMarket.market_area)}</div>
            <div style="padding:10px 16px">
              <a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/" style="font-size:13px;color:var(--skytext);font-weight:600">All ${esc(parentMarket.market_area)} PPO dentists</a>
            </div>
          </div>`}
        </aside>
      </div>
    </div>
  </section>

  <div class="sticky-bar" role="region" aria-label="Coverage actions">
    <div class="wrap">
      <div class="sticky-bar__context">
        <span class="sticky-bar__headline">PPO Dentists in ${esc(localArea)}</span>
        <span class="sticky-bar__sub">${plural(office_count, 'PPO office', 'PPO offices')} listed · Confirm your plan before booking</span>
      </div>
      <div class="sticky-bar__actions">
        <a href="${BASE_URL}/find-my-dentist" class="btn-sticky-primary">Avoid the surprise bill, verify free</a>
        <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-sticky-secondary">Plans from $30/mo</a>
      </div>
    </div>
  </div>
</main>`;

  return pageShell({ title, desc, canonical: canonicalTarget, geo: null, schemas, body, footerCta: '' });
}

/* ── Regional hub page (T3.5) ────────────────────────────── */

/* ── State hub page (T3) ─────────────────────────────────── */

function buildStateHub(stateName, markets, regionalHubs, plans) {
  const stSlug    = stateSlug(stateName);
  const abbr      = stateAbbr(stateName);
  const canonical = `${BASE_URL}/dental/${stSlug}/`;
  const totalOffices = markets.reduce((s, m) => s + m.office_count, 0);
  const today     = new Date().toISOString().slice(0,10);
  const monthYear = new Date().toLocaleDateString('en-US', { month:'long', year:'numeric' });
  const title     = `PPO Dentists in ${stateName} — ${totalOffices}+ PPO Offices Listed | CoverCapy`;
  const desc      = `Find ${totalOffices}+ PPO dental offices listed across ${stateName}. Browse by city or metro area, verify your insurance, and book with confidence. Plans from $30/month if you need coverage.`;

  // State-specific descriptions
  const STATE_DESC = {
    'California': `California has more PPO-participating dental offices than any other state — ${totalOffices}+ listed across Southern California, the Bay Area, Sacramento, and beyond. Whether you're in Los Angeles, San Diego, or the Central Valley, Confirm which offices accept your specific plan with the office before you go.`,
    'Texas': `Texas has ${totalOffices}+ PPO dental offices listed across Dallas, Houston, Austin, San Antonio, and dozens of smaller markets. CoverCapy maintains real-time network participation data so you know which offices take your specific carrier before you book.`,
    'Florida': `Florida has ${totalOffices}+ PPO-participating dental offices listed by CoverCapy — from Miami and Fort Lauderdale to Tampa, Orlando, and Jacksonville. Compare PPO-participating offices and confirm your plan before booking.`,
    'Nevada': `Nevada has ${totalOffices}+ PPO dental offices listed, concentrated in Las Vegas, Henderson, and Reno. CoverCapy lists carrier acceptance so you can see which offices take Delta Dental, UHC, or Guardian — confirm your plan before booking.`,
    'Arizona': `Arizona has ${totalOffices}+ PPO dental offices listed across Phoenix, Scottsdale, Tempe, and Tucson. CoverCapy checks network participation at the plan-tier level — not just "accepts PPO" but your exact carrier.`,
    'New York': `New York has ${totalOffices}+ PPO dental offices listed from NYC to Buffalo, Albany, and beyond. Confirm insurance acceptance with the office so you know your out-of-pocket before you sit in the chair.`,
    'New Jersey': `New Jersey has ${totalOffices}+ PPO dental offices listed across Bergen County, Essex, Middlesex, and the Jersey Shore corridor. CoverCapy confirms network participation and new-patient availability.`,
  };
  const stateDesc = STATE_DESC[stateName] || `${stateName} has ${totalOffices}+ PPO dental offices listed. Confirm insurance acceptance with the office so you know your coverage before you book.`;

  const schemas = [{
    '@context':'https://schema.org','@graph':[
      {'@type':'Organization','@id':`${BASE_URL}/#organization`,'name':'CoverCapy','url':BASE_URL,'logo':`${BASE_URL}/assets/img/covercapy-logo.png`},
      {'@type':'WebSite','@id':`${BASE_URL}/#website`,'url':`${BASE_URL}/`,'name':'CoverCapy'},
      {
        '@type':'MedicalWebPage','@id':`${canonical}#webpage`,'url':canonical,
        'name':title,'description':desc,'inLanguage':'en-US',
        'datePublished':today,'dateModified':today,
        'isPartOf':{'@id':`${BASE_URL}/#website`},'breadcrumb':{'@id':`${canonical}#breadcrumb`},
      },
      {
        '@type':'BreadcrumbList','@id':`${canonical}#breadcrumb`,'itemListElement':[
          {'@type':'ListItem','position':1,'name':'CoverCapy','item':`${BASE_URL}/`},
          {'@type':'ListItem','position':2,'name':`${stateName} PPO Dentists`,'item':canonical},
        ]
      },
      {
        '@type':'FAQPage','@id':`${canonical}#faq`,
        'mainEntity':[
          {'@type':'Question','name':`How many PPO dentists are in ${stateName}?`,'acceptedAnswer':{'@type':'Answer','text':`CoverCapy lists ${totalOffices}+ PPO-participating dental offices across ${stateName}, spanning ${markets.length} metro areas and dozens of cities.`}},
          {'@type':'Question','name':`How do I find an in-network dentist in ${stateName}?`,'acceptedAnswer':{'@type':'Answer','text':`Browse your city or metro area to see PPO-participating offices, then confirm your specific plan with the office before you call.`}},
          {'@type':'Question','name':`What PPO dental insurance plans work in ${stateName}?`,'acceptedAnswer':{'@type':'Answer','text':`Major PPO carriers with strong networks in ${stateName} include Delta Dental, UnitedHealthCare, Guardian, Aetna, and Cigna. Coverage varies by county — CoverCapy shows which offices accept your specific carrier and plan tier.`}},
        ]
      },
    ]
  }];

  // Regional hub cards (if any for this state)
  const regionCards = regionalHubs.length ? `
  <div class="state-section">
    <h2 class="state-section-head">Browse by Region</h2>
    <div class="state-region-grid">
      ${regionalHubs.map(h => `
      <a href="${BASE_URL}/dental/${h.stSlug}/${h.slug}/" class="state-region-card">
        <div class="src-label">${esc(h.label)}</div>
        <div class="src-markets">${h.markets.length} metro areas</div>
        <div class="src-arrow">Explore →</div>
      </a>`).join('')}
    </div>
  </div>` : '';

  // Metro hub cards
  const metroCards = markets.map(m => {
    const mkSlug = slugify(m.seo_area || m.market_area);
    return `<a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/" class="state-metro-card">
      <div class="smc-name">${esc(m.market_area)}</div>
      <div class="smc-count">${m.office_count} offices</div>
      <div class="smc-cities">${m.cities.slice(0,3).join(', ')}${m.cities.length > 3 ? ` +${m.cities.length-3} more` : ''}</div>
    </a>`;
  }).join('');

  const planRows = plans.slice(0, 3).map(p => `<div class="plan-row">
  <div><div class="plan-name">${esc(p.name)}</div><div class="plan-carrier">${esc(p.carrier)}</div>${p.timing ? `<div class="plan-timing">${esc(p.timing)}</div>` : ''}</div>
  <div class="plan-price">$${p.monthly}<span>/mo</span></div>
</div>`).join('');

  const body = `
<div class="alert-bar">No insurance? PPO plans from $30/month — <a href="${BASE_URL}/compare-ppo-dental-plans">compare individual PPO plans, effective dates and waiting periods</a>.</div>

<main id="main-content" data-page-type="state-hub" data-state="${esc(stateName)}">

  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="wrap">
      <ol class="breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="${BASE_URL}/" itemprop="item"><span itemprop="name">CoverCapy</span></a>
          <meta itemprop="position" content="1" />
        </li>
        <li><span aria-hidden="true"> / </span></li>
        <li><span>${esc(stateName)} Dentists</span></li>
      </ol>
    </div>
  </nav>

  <section class="hero">
    <div class="wrap">
      <div class="hero-overline">PPO Dentist Directory · ${esc(stateName)}</div>
      <h1 class="hero-headline">${totalOffices}+ PPO Dentists in ${esc(stateName)}</h1>
      <p class="hero-subheadline about-prose">PPO-participating offices across ${markets.length} ${esc(stateName)} markets. Check your plan before you book.</p>
      <div class="stat-pills-row">
        <span class="stat-pill">${totalOffices}+ offices listed, updated ${monthYear}</span>
        <span class="stat-pill">${markets.length} metro areas</span>
        <span class="stat-pill">Free insurance eligibility check</span>
      </div>
      <div class="hero-ctas">
        <a href="${BASE_URL}/find-my-dentist" class="btn-hero-primary">Verify my PPO — free</a>
        <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-hero-secondary">No insurance? Plans from $30/mo</a>
      </div>
    </div>
  </section>

  <section class="about-prose-section">
    <div class="wrap">
      <div class="layout">
        <div class="main-col">

          <div class="about-prose"><p>${stateDesc}</p></div>

          ${regionCards}

          <div class="state-section">
            <h2 class="state-section-head">Browse PPO Dentists by Metro Area</h2>
            <div class="state-metro-grid">${metroCards}</div>
          </div>

          <div class="concierge-cta">
            <div class="wrap">
              <h2>Check your insurance before you go.</h2>
              <ul class="cta-benefits">
                <li>See each office's listed PPO carriers and ratings</li>
                <li>Confirmed in-network status at your plan tier, not just carrier level</li>
                <li>New-patient availability verified — no surprise "we're not accepting" at the door</li>
              </ul>
              <a href="${BASE_URL}/find-my-dentist" class="btn-concierge-primary">Verify my coverage — free</a>
              <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-concierge-secondary">Plans from $30/mo</a>
            </div>
          </div>

          <section class="faq-section" id="faq">
            <h2>PPO Dentists in ${esc(stateName)} — Common Questions</h2>
            <div class="faq">
              <details open><summary>How many PPO dentists are in ${esc(stateName)}?</summary><p>CoverCapy lists ${totalOffices}+ PPO-participating dental offices across ${stateName}, spanning ${markets.length} metro areas. The largest concentrations are in ${markets.slice(0,3).map(m => m.market_area).join(', ')}.</p></details>
              <details><summary>How do I find an in-network dentist in ${esc(stateName)}?</summary><p>Select your city or metro area above. CoverCapy shows which offices list your carrier — not just "accepts PPO" but the exact networks each office lists. Confirm your exact plan with the office before you book.</p></details>
              <details><summary>What PPO dental plans work in ${esc(stateName)}?</summary><p>Major PPO carriers with strong ${stateName} networks include Delta Dental, UnitedHealthCare, Guardian, Aetna, and Cigna. CoverCapy shows which offices accept your specific carrier and plan tier in your city. Plans start at $30/month if you need coverage — next-day activation available.</p></details>
            </div>
          </section>

        </div>

        <aside class="rail" aria-label="Plan and location information">
          <div class="cta-box">
            <h3>No insurance?</h3>
            <p>PPO plans from $30/month. Next-day activation. No waiting period for cleanings.</p>
            <a href="${BASE_URL}/compare-ppo-dental-plans" class="cta-btn">Browse PPO Plans</a>
            <a href="${BASE_URL}/find-my-dentist" class="cta-btn-sec">Find In-Network Dentist</a>
          </div>
          <div class="rail-card">
            <div class="rail-head">PPO Plans Available</div>
            ${planRows}
            <div style="padding:12px 16px"><a href="${BASE_URL}/compare-ppo-dental-plans" style="font-size:13px;color:var(--skytext);text-decoration:underline;font-weight:600">Compare all plans →</a></div>
          </div>
          <div class="rail-card">
            <div class="rail-head">${esc(stateName)} Metro Areas</div>
            ${markets.slice(0, 12).map(m => {
              const mkSlug = slugify(m.seo_area || m.market_area);
              return `<div class="rail-city-row"><a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/">${esc(m.market_area)}</a><span class="rail-city-count">${m.office_count}</span></div>`;
            }).join('')}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <div class="sticky-bar" role="region" aria-label="Coverage actions">
    <div class="wrap">
      <div class="sticky-bar__context">
        <span class="sticky-bar__headline">PPO Dentists in ${esc(stateName)}</span>
        <span class="sticky-bar__sub">${totalOffices}+ PPO offices listed · Confirm your plan before booking</span>
      </div>
      <div class="sticky-bar__actions">
        <a href="${BASE_URL}/find-my-dentist" class="btn-sticky-primary">Verify my PPO — free</a>
        <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-sticky-secondary">Plans from $30/mo</a>
      </div>
    </div>
  </div>
</main>`;

  return pageShell({ title, desc, canonical, geo: { region:`US-${abbr}`, placename:stateName }, schemas, body, footerCta: '' });
}

function buildRegionalHub(hub, marketSummaries, plans) {
  const { slug, label, state, stSlug, desc } = hub;
  const canonical   = `${BASE_URL}/dental/${stSlug}/${slug}/`;
  const abbr        = stateAbbr(state);
  const office_count = marketSummaries.reduce((s,m) => s+m.office_count, 0);
  const today       = new Date().toISOString().slice(0,10);
  const monthYear   = new Date().toLocaleDateString('en-US',{month:'long',year:'numeric'});
  const title       = `PPO Dentists in ${label} — ${office_count}+ PPO Offices Listed | CoverCapy`;

  const schemas = [{
    '@context':'https://schema.org','@graph':[
      {'@type':'Organization','@id':`${BASE_URL}/#organization`,'name':'CoverCapy','url':BASE_URL},
      {'@type':'MedicalWebPage','@id':`${canonical}#webpage`,'url':canonical,'name':title,
        'description':desc,'inLanguage':'en-US','datePublished':today,'dateModified':today},
      {'@type':'BreadcrumbList','@id':`${canonical}#breadcrumb`,'itemListElement':[
        {'@type':'ListItem','position':1,'name':'CoverCapy','item':`${BASE_URL}/`},
        {'@type':'ListItem','position':2,'name':`${state} Dentists`,'item':`${BASE_URL}/dental/${stSlug}/`},
        {'@type':'ListItem','position':3,'name':`${label} PPO Dentists`,'item':canonical},
      ]},
    ]
  }];

  const metroCards = marketSummaries.map(m => {
    const mkSlug = slugify(m.seo_area || m.market_area);
    return `<a href="${BASE_URL}/dental/${stSlug}/${mkSlug}/" class="metro-card">
  <div class="metro-card-name">${esc(m.market_area)}</div>
  <div class="metro-card-count">${m.office_count} offices</div>
  <div class="metro-card-cities">${m.city_count} cities covered</div>
</a>`;
  }).join('\n');

  const planRows = plans.slice(0,3).map(p=>`<div class="plan-row">
  <div><div class="plan-name">${esc(p.name)}</div><div class="plan-carrier">${esc(p.carrier)}</div>${p.timing?`<div class="plan-timing">${esc(p.timing)}</div>`:''}</div>
  <div class="plan-price">$${p.monthly}<span>/mo</span></div>
</div>`).join('');

  const body = `
<div class="alert-bar">No insurance? PPO plans from $30/month — <a href="${BASE_URL}/compare-ppo-dental-plans">compare individual PPO plans, effective dates and waiting periods</a>.</div>

<main id="main-content" data-page-type="regional-hub" data-region="${esc(label)}">
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="wrap">
      <ol class="breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="${BASE_URL}/" itemprop="item"><span itemprop="name">CoverCapy</span></a>
          <meta itemprop="position" content="1" />
        </li>
        <li><span aria-hidden="true"> / </span></li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="${BASE_URL}/dental/${stSlug}/" itemprop="item"><span itemprop="name">${esc(state)} Dentists</span></a>
          <meta itemprop="position" content="2" />
        </li>
        <li><span aria-hidden="true"> / </span></li>
        <li><span>${esc(label)}</span></li>
      </ol>
    </div>
  </nav>

  <section class="hero">
    <div class="wrap">
      <div class="hero-overline">PPO Dentist Directory · ${esc(label)}</div>
      <h1 class="hero-headline">${office_count}+ PPO Dentists in ${esc(label)}</h1>
      <p class="hero-subheadline about-prose">${esc(desc)}</p>
      <div class="stat-pills-row">
        <span class="stat-pill">${office_count}+ offices listed, updated ${monthYear}</span>
        <span class="stat-pill">${marketSummaries.length} metro areas</span>
      </div>
      <div class="hero-ctas">
        <a href="${BASE_URL}/find-my-dentist" class="btn-hero-primary">Verify my PPO — free</a>
        <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-hero-secondary">No insurance? Plans from $30/mo</a>
      </div>
    </div>
  </section>

  <section class="about-prose-section">
    <div class="wrap">
      <div class="layout">
        <div class="main-col">
          <div class="about-prose">
            <p>CoverCapy lists ${office_count}+ PPO-participating dental offices across ${esc(label)}. All offices are verified for insurance network participation. Select a metro area below to browse by city and filter by your PPO carrier.</p>
          </div>

          <div class="city-strip-inline">
            <h2>Browse by Metro Area</h2>
            <div class="metro-cards-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;margin-top:16px">
              ${metroCards}
            </div>
          </div>

          <div class="concierge-cta">
            <div class="wrap">
              <h2>Check your plan before you book.</h2>
              <ul class="cta-benefits">
                <li>See each office's listed PPO carriers and ratings</li>
                <li>New-patient availability — confirm directly with the office</li>
                <li>Listed PPO carriers shown per office — a starting point, not a guarantee</li>
              </ul>
              <a href="${BASE_URL}/find-my-dentist" class="btn-concierge-primary">Avoid the surprise bill — verify free</a>
            </div>
          </div>
        </div>

        <aside class="rail" aria-label="Plan information">
          <div class="cta-box">
            <h3>No insurance? We fix that.</h3>
            <p>PPO plans from $30/month. Next-day activation available.</p>
            <a href="${BASE_URL}/compare-ppo-dental-plans" class="cta-btn">Browse PPO Plans</a>
            <a href="${BASE_URL}/find-my-dentist" class="cta-btn-sec">Find In-Network Dentist</a>
          </div>
          <div class="rail-card">
            <div class="rail-head">PPO Plans Available</div>
            ${planRows}
            <div style="padding:12px 16px"><a href="${BASE_URL}/compare-ppo-dental-plans" style="font-size:13px;color:var(--skytext);text-decoration:underline;font-weight:600">Compare all plans →</a></div>
          </div>
          <div class="rail-card">
            <div class="rail-head">Metro Areas</div>
            ${marketSummaries.map(m=>`<div class="rail-city-row"><a href="${BASE_URL}/dental/${stSlug}/${slugify(m.seo_area||m.market_area)}/">${esc(m.market_area)}</a><span class="rail-city-count">${m.office_count}</span></div>`).join('')}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <div class="sticky-bar" role="region" aria-label="Coverage actions">
    <div class="wrap">
      <div class="sticky-bar__context">
        <span class="sticky-bar__headline">PPO Dentists in ${esc(label)}</span>
        <span class="sticky-bar__sub">${office_count}+ PPO offices listed across ${marketSummaries.length} metro areas</span>
      </div>
      <div class="sticky-bar__actions">
        <a href="${BASE_URL}/find-my-dentist" class="btn-sticky-primary">Verify my PPO — free</a>
        <a href="${BASE_URL}/compare-ppo-dental-plans" class="btn-sticky-secondary">Plans from $30/mo</a>
      </div>
    </div>
  </div>
</main>`;

  return pageShell({ title, desc, canonical, geo: null, schemas, body, footerCta: '' });
}

/* ── Sitemap ──────────────────────────────────────────────── */

function writeSitemap(urls) {
  const today = new Date().toISOString().slice(0,10);
  const entries = urls.map(u => `
  <url>
    <loc>${u.loc}</loc>
    <lastmod>${today}</lastmod>
    <changefreq>${u.freq || 'weekly'}</changefreq>
    <priority>${u.priority || '0.7'}</priority>
  </url>`).join('');
  const xml = `<?xml version="1.0" encoding="UTF-8"?>\n<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">${entries}\n</urlset>`;
  writeFile('dental/sitemap-dental.xml', xml);
}

/* ── Location page orchestrator ──────────────────────────── */

async function generateLocationPages() {
  console.log('\n[locations] Fetching markets...');
  const markets = await fetchMarkets();
  console.log(`[locations] ${markets.length} markets qualify (≥${MIN_OFFICES} offices)`);

  // Fetch plan data for rail cards
  let plans;
  try {
    plans = await sb('/rest/v1/ppo_plans?is_active=eq.true&order=sort_order.asc&select=plan_key,name,carrier,monthly,timing,best_for');
    if (!Array.isArray(plans) || !plans.length) throw new Error('empty');
  } catch {
    plans = [
      { plan_key:'uhc',      carrier:'UnitedHealthCare', name:'UHC Primary Dental',         monthly:30,  timing:'1–3 business day activation' },
      { plan_key:'aetna',    carrier:'Aetna',            name:'Aetna Dental Access',         monthly:50,  timing:'Standard enrollment' },
      { plan_key:'ameritas', carrier:'Ameritas',         name:'Ameritas PrimeStar Complete', monthly:60,  timing:'Day 1 active, no waiting periods' },
      { plan_key:'guardian', carrier:'Guardian',         name:'Guardian DentalGuard',        monthly:70,  timing:'Standard enrollment' },
    ];
    console.log('[locations] Using fallback plan data for rail cards');
  }

  const sitemapUrls = [];
  let totalMarkets = 0, totalCities = 0;

  // Build a lookup map: market_area → market object (for local area hub parent lookup)
  const marketByName = {};
  for (const m of markets) marketByName[m.market_area] = m;

  for (const market of markets) {
    const stSlug = stateSlug(market.state);
    const mkSlug = slugify(market.seo_area || market.market_area);
    console.log(`\n▶ ${market.market_area} (${market.state}) — ${market.office_count} offices`);

    try {
      const dentists = await fetchDentists(market.market_area);
      const cities   = groupByCities(dentists);
      console.log(`  ${cities.length} cities with ≥${MIN_OFFICES} offices`);

      // Market hub (T4a)
      const hubHtml = buildMarketHub(market, cities, dentists, plans);
      writeFile(`dental/${stSlug}/${mkSlug}/index.html`, hubHtml);
      totalMarkets++;
      sitemapUrls.push({ loc:`${BASE_URL}/dental/${stSlug}/${mkSlug}/`, priority:'0.8' });

      // City pages (T4c) — skip if city slug === market slug (e.g. Beaumont market + Beaumont city)
      for (const cityData of cities) {
        const cSlug = slugify(cityData.city);
        if (cSlug === mkSlug) {
          console.log(`  ↳ skipping city page for "${cityData.city}" — same slug as market hub`);
          continue;
        }
        const cityHtml = buildCityPage(cityData, market, cities, plans);
        writeFile(`dental/${stSlug}/${mkSlug}/${cSlug}/index.html`, cityHtml);
        totalCities++;
        sitemapUrls.push({ loc:`${BASE_URL}/dental/${stSlug}/${mkSlug}/${cSlug}/`, priority:'0.7' });
      }
    } catch (e) {
      console.error(`  ✗ ERROR generating ${market.market_area}: ${e.message}`);
      console.error(`    Stack: ${e.stack?.split('\n')[1]?.trim() || 'n/a'}`);
    }
  }

  // State hub pages (T3) — one per state
  console.log(`\n[locations] Generating state hubs (T3)...`);
  let totalStateHubs = 0;
  const marketsByState = {};
  for (const m of markets) {
    if (!marketsByState[m.state]) marketsByState[m.state] = [];
    marketsByState[m.state].push(m);
  }
  for (const [stateName, stateMarkets] of Object.entries(marketsByState)) {
    const stSlug = stateSlug(stateName);
    const stateRegionalHubs = REGIONAL_HUBS.filter(h => h.state === stateName);
    try {
      const html = buildStateHub(stateName, stateMarkets, stateRegionalHubs, plans);
      writeFile(`dental/${stSlug}/index.html`, html);
      totalStateHubs++;
      sitemapUrls.push({ loc:`${BASE_URL}/dental/${stSlug}/`, priority:'0.9' });
      console.log(`  ✓ ${stateName} — ${stateMarkets.length} markets, ${stateMarkets.reduce((s,m)=>s+m.office_count,0)} offices`);
    } catch (e) {
      console.error(`  ✗ ${stateName} state hub: ${e.message}`);
    }
  }

  // Local area hubs (T4b) — only for local_areas in LOCAL_AREA_HUBS set
  console.log(`\n[locations] Generating local area hubs (T4b)...`);
  let totalLocalAreaHubs = 0;
  for (const localArea of LOCAL_AREA_HUBS) {
    const laDentists = await fetchLocalAreaDentists(localArea);
    if (laDentists.length < MIN_OFFICES) {
      console.log(`  ↷ ${localArea} — only ${laDentists.length} offices, skipping`);
      continue;
    }
    // Determine parent market from the dentists (take the most common market_area)
    const marketCounts = {};
    for (const d of laDentists) {
      if (d.market_area) marketCounts[d.market_area] = (marketCounts[d.market_area] || 0) + 1;
    }
    const parentMarketName = Object.entries(marketCounts).sort((a,b) => b[1]-a[1])[0]?.[0];
    let parentMarket = marketByName[parentMarketName];
    if (!parentMarket) {
      // Parent market may not have cleared MIN_OFFICES or may have a slightly different name.
      // Build a synthetic parent so we can still emit the hub page.
      const firstDentist = laDentists[0];
      parentMarket = {
        market_area: parentMarketName || localArea,
        state:       firstDentist?.state || 'California',
        seo_area:    null,
        office_count: laDentists.length,
      };
      console.log(`  ℹ  ${localArea} — synthetic parent "${parentMarket.market_area}" (market hub may not exist yet)`);
    }
    const state  = parentMarket.state;
    const stSlug = stateSlug(state);
    const laSlug = slugify(localArea);
    const laCities = groupByCities(laDentists);
    console.log(`  ◆ ${localArea} → /${stSlug}/${laSlug}/ (${laDentists.length} offices, ${laCities.length} cities)`);
    const laHtml = buildLocalAreaHub(localArea, state, parentMarket, laDentists, laCities, plans);
    writeFile(`dental/${stSlug}/${laSlug}/index.html`, laHtml);
    totalLocalAreaHubs++;
    sitemapUrls.push({ loc:`${BASE_URL}/dental/${stSlug}/${laSlug}/`, priority:'0.75' });
  }

  // Individual dentist pages (T5)
  // Only generate if --dentist-pages flag is passed (large output — run separately)
  const DENTIST_PAGES = process.argv.includes('--dentist-pages');
  let totalDentistPages = 0;
  if (DENTIST_PAGES) {
    console.log(`\n[locations] Generating individual dentist pages (T5)...`);
    for (const market of markets) {
      const stSlug = stateSlug(market.state);
      const mkSlug = slugify(market.seo_area || market.market_area);
      let marketDentists;
      try {
        marketDentists = await fetchDentists(market.market_area);
      } catch (e) {
        console.error(`  ✗ fetchDentists failed for ${market.market_area}: ${e.message}`);
        continue;
      }
      // Group by city for nearby-dentist cards
      const byCity = {};
      for (const d of marketDentists) {
        if (!d.city) continue;
        if (!byCity[d.city]) byCity[d.city] = [];
        byCity[d.city].push(d);
      }
      console.log(`  ▶ ${market.market_area} — ${marketDentists.length} dentist pages`);
      for (const d of marketDentists) {
        if (!d.slug && !d.name) continue;
        const dSlug = d.slug || slugify(d.name);
        const cSlug = slugify(d.city || '');
        if (!cSlug || !dSlug) continue;
        try {
          const cityDentists = byCity[d.city] || [];
          const html = buildDentistPage(d, market, cityDentists, plans, Object.keys(byCity));
          writeFile(`dental/${stSlug}/${mkSlug}/${cSlug}/${dSlug}/index.html`, html);
          totalDentistPages++;
          sitemapUrls.push({ loc:`${BASE_URL}/dental/${stSlug}/${mkSlug}/${cSlug}/${dSlug}/`, priority:'0.6' });
        } catch (e) {
          console.error(`    ✗ ${d.name}: ${e.message}`);
        }
      }
    }
    console.log(`[locations] T5: ${totalDentistPages} dentist pages generated`);
  }

  // Regional hubs (T3.5)
  console.log(`\n[locations] Generating regional hubs (T3.5)...`);
  let totalRegionalHubs = 0;
  for (const hub of REGIONAL_HUBS) {
    const regDentists = await fetchRegionalDentists(hub.markets);
    if (regDentists.length < MIN_OFFICES) {
      console.log(`  ↷ ${hub.label} — only ${regDentists.length} offices, skipping`);
      continue;
    }
    // Build per-market summaries for the metro card grid
    const mktMap = {};
    for (const d of regDentists) {
      if (!d.market_area) continue;
      if (!mktMap[d.market_area]) mktMap[d.market_area] = { market_area: d.market_area, seo_area: d.seo_area, cities: new Set(), count: 0 };
      mktMap[d.market_area].count++;
      if (d.city) mktMap[d.market_area].cities.add(d.city);
    }
    const marketSummaries = hub.markets
      .map(name => mktMap[name])
      .filter(Boolean)
      .map(m => ({ market_area: m.market_area, seo_area: m.seo_area, office_count: m.count, city_count: m.cities.size }));
    console.log(`  ◆ ${hub.label} → /${hub.stSlug}/${hub.slug}/ (${regDentists.length} offices, ${hub.markets.length} metros)`);
    const regHtml = buildRegionalHub(hub, marketSummaries, plans);
    writeFile(`dental/${hub.stSlug}/${hub.slug}/index.html`, regHtml);
    totalRegionalHubs++;
    sitemapUrls.push({ loc:`${BASE_URL}/dental/${hub.stSlug}/${hub.slug}/`, priority:'0.85' });
  }

  writeSitemap(sitemapUrls);

  console.log(`\n[locations] Done: ${totalStateHubs} state hubs, ${totalMarkets} market hubs, ${totalCities} city pages, ${totalLocalAreaHubs} local area hubs, ${totalRegionalHubs} regional hubs — ${sitemapUrls.length} sitemap URLs`);
}

/* ══════════════════════════════════════════════════════════
   MAIN
══════════════════════════════════════════════════════════ */

async function main() {
  console.log('[covercapy] generate-plans.js starting');

  try {
    if (!LOCATIONS_ONLY) await injectPlanTable();
  } catch (e) {
    console.warn('[plans] WARNING:', e.message, '— deploying with existing HTML');
  }

  try {
    if (!PLANS_ONLY) await generateLocationPages();
  } catch (e) {
    console.error('[locations] FATAL:', e.message);
    if (!LOCATIONS_ONLY) process.exit(0); // don't block deploy if only locations fail
    process.exit(1);
  }

  console.log('[covercapy] generate-plans.js complete');
}

main();
